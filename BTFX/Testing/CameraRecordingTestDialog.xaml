<UserControl
    x:Class="BTFX.Testing.CameraRecordingTestDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Width="980"
    MaxWidth="1100"
    MaxHeight="760"
    d:DesignHeight="720"
    d:DesignWidth="980"
    mc:Ignorable="d">

    <Border Padding="28" Style="{StaticResource DialogSurfaceBorderStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon
                        Width="30"
                        Height="30"
                        Margin="0,0,10,0"
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                        Kind="Video4KBox" />
                    <StackPanel>
                        <TextBlock
                            FontSize="22"
                            FontWeight="SemiBold"
                            Text="临时相机录制测试" />
                        <TextBlock
                            Margin="0,4,0,0"
                            FontSize="13"
                            Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}"
                            Text="复现 Python 脚本的 DirectShow 录制、AVI 保存和 MP4 转码流程" />
                    </StackPanel>
                </StackPanel>

                <Border
                    Grid.Column="1"
                    Padding="12,5"
                    VerticalAlignment="Top"
                    Background="#FFF4F0"
                    CornerRadius="4">
                    <TextBlock
                        FontSize="12"
                        Foreground="#A84300"
                        Text="{Binding StatusText}" />
                </Border>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="360" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                    <StackPanel IsEnabled="{Binding IsRecording, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                        <TextBlock
                            Margin="0,0,0,6"
                            FontWeight="SemiBold"
                            Text="FFmpeg 路径" />
                        <TextBox
                            Margin="0,0,0,14"
                            materialDesign:HintAssist.Hint="C:\ffmpeg\bin\ffmpeg.exe"
                            Text="{Binding FfmpegPath, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock
                            Margin="0,0,0,6"
                            FontWeight="SemiBold"
                            Text="保存目录" />
                        <TextBox
                            Margin="0,0,0,14"
                            materialDesign:HintAssist.Hint="D:\ZUT_test\video"
                            Text="{Binding SaveDirectory, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock
                            Margin="0,0,0,6"
                            FontWeight="SemiBold"
                            Text="相机名称 / 编号" />
                        <TextBox
                            Height="88"
                            Margin="0,0,0,14"
                            AcceptsReturn="True"
                            Text="{Binding CameraNamesText, UpdateSourceTrigger=PropertyChanged}"
                            TextWrapping="Wrap"
                            VerticalScrollBarVisibility="Auto" />

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock
                                    Margin="0,0,0,6"
                                    FontWeight="SemiBold"
                                    Text="分辨率" />
                                <ComboBox
                                    ItemsSource="{Binding Resolutions}"
                                    SelectedItem="{Binding SelectedResolution}" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock
                                    Margin="0,0,0,6"
                                    FontWeight="SemiBold"
                                    Text="帧率" />
                                <TextBox Text="{Binding FrameRate, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Grid>

                        <TextBlock
                            Margin="0,0,0,6"
                            FontWeight="SemiBold"
                            Text="录制时长（秒）" />
                        <TextBox
                            Margin="0,0,0,14"
                            Text="{Binding DurationSeconds, UpdateSourceTrigger=PropertyChanged}" />

                        <CheckBox
                            Margin="0,0,0,8"
                            Content="录制完成后转码为 MP4"
                            IsChecked="{Binding TranscodeToMp4}" />
                        <CheckBox
                            Margin="0,0,0,20"
                            Content="MP4 转码成功后删除临时 AVI"
                            IsChecked="{Binding DeleteAviAfterMp4}" />
                    </StackPanel>
                </ScrollViewer>

                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border
                        Grid.Row="0"
                        Padding="12"
                        Background="#101418"
                        CornerRadius="6">
                        <DockPanel>
                            <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontWeight="SemiBold"
                                    Foreground="#DCE3EA"
                                    Text="运行日志" />
                                <Button
                                    HorizontalAlignment="Right"
                                    Command="{Binding ClearLogCommand}"
                                    Foreground="#DCE3EA"
                                    Style="{StaticResource MaterialDesignFlatButton}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon
                                            Width="16"
                                            Height="16"
                                            Margin="0,0,4,0"
                                            Kind="Broom" />
                                        <TextBlock Text="清空" />
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <ListBox
                                Background="Transparent"
                                BorderThickness="0"
                                FontFamily="Consolas"
                                FontSize="12"
                                Foreground="#DCE3EA"
                                ItemsSource="{Binding LogLines}"
                                ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                ScrollViewer.VerticalScrollBarVisibility="Auto" />
                        </DockPanel>
                    </Border>

                    <Border
                        Grid.Row="2"
                        Padding="12"
                        Background="#F7F9FB"
                        BorderBrush="#E1E6EC"
                        BorderThickness="1"
                        CornerRadius="6">
                        <StackPanel>
                            <TextBlock
                                Margin="0,0,0,8"
                                FontWeight="SemiBold"
                                Text="输出文件" />
                            <ItemsControl ItemsSource="{Binding OutputFiles}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock
                                            Margin="0,0,0,4"
                                            FontFamily="Consolas"
                                            FontSize="12"
                                            Text="{Binding}"
                                            TextWrapping="Wrap" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <Grid Grid.Row="2" Margin="0,20,0,0">
                <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                    <Button
                        Command="{Binding StartRecordingCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon
                                Width="18"
                                Height="18"
                                Margin="0,0,6,0"
                                Kind="RecordRec" />
                            <TextBlock Text="开始录制" />
                        </StackPanel>
                    </Button>
                    <Button
                        Margin="10,0,0,0"
                        Command="{Binding CancelRecordingCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon
                                Width="18"
                                Height="18"
                                Margin="0,0,6,0"
                                Kind="StopCircleOutline" />
                            <TextBlock Text="取消" />
                        </StackPanel>
                    </Button>
                    <Button
                        Margin="10,0,0,0"
                        Command="{Binding OpenSaveDirectoryCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon
                                Width="18"
                                Height="18"
                                Margin="0,0,6,0"
                                Kind="FolderOpenOutline" />
                            <TextBlock Text="打开目录" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <Button
                    HorizontalAlignment="Right"
                    Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                    IsEnabled="{Binding IsRecording, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                    Style="{StaticResource MaterialDesignFlatButton}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon
                            Width="18"
                            Height="18"
                            Margin="0,0,6,0"
                            Kind="Close" />
                        <TextBlock Text="关闭" />
                    </StackPanel>
                </Button>
            </Grid>
        </Grid>
    </Border>
</UserControl>
