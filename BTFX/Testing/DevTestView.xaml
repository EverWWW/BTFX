<UserControl x:Class="BTFX.Testing.DevTestView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{DynamicResource MaterialDesign.Brush.Background}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 顶部控制面板 -->
        <Border Grid.Row="0" Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                Padding="16" Margin="0,0,0,1">
            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- 标题 -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="TestTube" Width="24" Height="24"
                                             VerticalAlignment="Center" Foreground="#FF9800" Margin="0,0,8,0" />
                        <TextBlock Text="UI 测试模拟器" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" />
                        <TextBlock Text=" — 评估与报告模块界面预览" FontSize="13" Foreground="Gray"
                               VerticalAlignment="Center" Margin="8,0,0,0" />
                        <Border Background="#FFF3E0" CornerRadius="3" Padding="8,2" Margin="16,0,0,0" VerticalAlignment="Center">
                            <TextBlock FontSize="11" Foreground="#E65100">
                            <Run Text="当前场景: " />
                            <Run Text="{Binding CurrentScenario, Mode=OneWay}" FontWeight="Medium" />
                            </TextBlock>
                        </Border>
                        <Button Content="清除预览" Command="{Binding ClearPreviewCommand}" Margin="12,0,0,0"
                            Style="{StaticResource MaterialDesignFlatButton}" Foreground="Gray" Padding="8,2" Height="24" FontSize="11" />
                    </StackPanel>

                    <!-- Step1 新建测量场景 -->
                    <StackPanel Grid.Row="2">
                        <TextBlock Text="📋 Step1 新建测量" FontSize="13" FontWeight="Medium" Foreground="#00796B" Margin="0,0,0,4" />
                        <WrapPanel>
                            <Button Content="空表单（无患者）" Command="{Binding ShowStep1EmptyCommand}" Margin="0,0,6,4"
                                Style="{StaticResource MaterialDesignOutlinedButton}" Padding="12,4" Height="30" FontSize="12" />
                            <Button Content="已填表单（有患者）" Command="{Binding ShowStep1FilledCommand}" Margin="0,0,6,4"
                                Style="{StaticResource MaterialDesignOutlinedButton}" Padding="12,4" Height="30" FontSize="12" />
                        </WrapPanel>
                    </StackPanel>

                    <!-- Step2 导入/采集场景 -->
                    <StackPanel Grid.Row="4">
                        <TextBlock Text="🎬 Step2 导入/采集" FontSize="13" FontWeight="Medium" Foreground="#0277BD" Margin="0,0,0,4" />
                        <WrapPanel>
                            <Button Content="导入（空状态）" Command="{Binding ShowStep2ImportEmptyCommand}" Margin="0,0,6,4"
                                Style="{StaticResource MaterialDesignOutlinedButton}" Padding="12,4" Height="30" FontSize="12" />
                            <Button Content="导入（已选视频）" Command="{Binding ShowStep2ImportWithVideoCommand}" Margin="0,0,6,4"
                                Style="{StaticResource MaterialDesignOutlinedButton}" Padding="12,4" Height="30" FontSize="12" />
                            <Button Content="采集·双视频·待机" Command="{Binding ShowStep2CaptureDualIdleCommand}" Margin="0,0,6,4"
                                Style="{StaticResource MaterialDesignOutlinedButton}" Foreground="#0277BD" Padding="12,4" Height="30" FontSize="12" />
                            <Button Content="采集·单视频·待机" Command="{Binding ShowStep2CaptureSingleIdleCommand}" Margin="0,0,6,4"
                                Style="{StaticResource MaterialDesignOutlinedButton}" Foreground="#0277BD" Padding="12,4" Height="30" FontSize="12" />
                            <Button Content="采集·录制中" Command="{Binding ShowStep2CaptureRecordingCommand}" Margin="0,0,6,4"
                                Style="{StaticResource MaterialDesignFlatButton}" Foreground="#F44336" Padding="12,4" Height="30" FontSize="12" />
                            <Button Content="采集·录制完成" Command="{Binding ShowStep2CaptureCompletedCommand}" Margin="0,0,6,4"
                                Style="{StaticResource MaterialDesignFlatButton}" Foreground="#4CAF50" Padding="12,4" Height="30" FontSize="12" />
                        </WrapPanel>
                    </StackPanel>

                    <!-- Step3 回放检查场景 -->
                    <StackPanel Grid.Row="6">
                        <TextBlock Text="▶ Step3 回放检查" FontSize="13" FontWeight="Medium" Foreground="#5C6BC0" Margin="0,0,0,4" />
                        <WrapPanel>
                            <Button Content="双视频回放" Command="{Binding ShowStep3ReviewCommand}" Margin="0,0,6,4"
                                Style="{StaticResource MaterialDesignOutlinedButton}" Padding="12,4" Height="30" FontSize="12" />
                            <Button Content="单视频回放" Command="{Binding ShowStep3SingleVideoCommand}" Margin="0,0,6,4"
                                Style="{StaticResource MaterialDesignOutlinedButton}" Padding="12,4" Height="30" FontSize="12" />
                        </WrapPanel>
                    </StackPanel>

                    <!-- Step4 评估模块场景 -->
                    <StackPanel Grid.Row="8">
                        <TextBlock Text="📊 Step4 评估模块" FontSize="13" FontWeight="Medium" Foreground="#1976D2" Margin="0,0,0,4" />
                        <WrapPanel>
                            <Button Content="就绪 (Ready)" Command="{Binding ShowStep4ReadyCommand}" Margin="0,0,6,4"
                                Style="{StaticResource MaterialDesignOutlinedButton}" Padding="12,4" Height="30" FontSize="12" />
                            <Button Content="运行中 (Running)" Command="{Binding ShowStep4RunningCommand}" Margin="0,0,6,4"
                                Style="{StaticResource MaterialDesignOutlinedButton}" Padding="12,4" Height="30" FontSize="12" />
                            <Button Content="预览 A级" Command="{Binding ShowStep4PreviewingGradeACommand}" Margin="0,0,6,4"
                                Style="{StaticResource MaterialDesignFlatButton}" Foreground="#4CAF50" Padding="12,4" Height="30" FontSize="12" />
                            <Button Content="预览 B级" Command="{Binding ShowStep4PreviewingGradeBCommand}" Margin="0,0,6,4"
                                Style="{StaticResource MaterialDesignFlatButton}" Foreground="#FF9800" Padding="12,4" Height="30" FontSize="12" />
                            <Button Content="预览 C级" Command="{Binding ShowStep4PreviewingGradeCCommand}" Margin="0,0,6,4"
                                Style="{StaticResource MaterialDesignFlatButton}" Foreground="#F44336" Padding="12,4" Height="30" FontSize="12" />
                            <Button Content="参数概览" Command="{Binding ShowStep4ParamsViewCommand}" Margin="0,0,6,4"
                                Style="{StaticResource MaterialDesignOutlinedButton}" Padding="12,4" Height="30" FontSize="12" />
                            <Button Content="失败 (Failed)" Command="{Binding ShowStep4FailedCommand}" Margin="0,0,6,4"
                                Style="{StaticResource MaterialDesignOutlinedButton}" Foreground="#F44336" Padding="12,4" Height="30" FontSize="12" />
                            <Button Content="单视频(仅正面)" Command="{Binding ShowStep4SingleFrontReadyCommand}" Margin="0,0,6,4"
                                Style="{StaticResource MaterialDesignOutlinedButton}" Foreground="#0277BD" Padding="12,4" Height="30" FontSize="12" />
                            <Button Content="单视频(仅侧面)" Command="{Binding ShowStep4SingleSideReadyCommand}" Margin="0,0,6,4"
                                Style="{StaticResource MaterialDesignOutlinedButton}" Foreground="#0277BD" Padding="12,4" Height="30" FontSize="12" />
                        </WrapPanel>
                    </StackPanel>

                    <!-- 降级场景 -->
                    <StackPanel Grid.Row="10">
                        <TextBlock Text="⚠ 降级场景" FontSize="13" FontWeight="Medium" Foreground="#E65100" Margin="0,0,0,4" />
                        <WrapPanel>
                            <Button Content="无视频" Command="{Binding ShowStep4NoVideoCommand}" Margin="0,0,6,4"
                                Style="{StaticResource MaterialDesignOutlinedButton}" Foreground="#E65100" Padding="12,4" Height="30" FontSize="12" />
                            <Button Content="无曲线" Command="{Binding ShowStep4NoChartCommand}" Margin="0,0,6,4"
                                Style="{StaticResource MaterialDesignOutlinedButton}" Foreground="#E65100" Padding="12,4" Height="30" FontSize="12" />
                            <Button Content="全降级" Command="{Binding ShowStep4FullDegradationCommand}" Margin="0,0,6,4"
                                Style="{StaticResource MaterialDesignOutlinedButton}" Foreground="#D32F2F" Padding="12,4" Height="30" FontSize="12" />
                        </WrapPanel>
                    </StackPanel>

                    <!-- 报告模块场景 -->
                    <StackPanel Grid.Row="12">
                        <TextBlock Text="📝 报告模块" FontSize="13" FontWeight="Medium" Foreground="#7B1FA2" Margin="0,0,0,4" />
                        <WrapPanel>
                            <Button Content="新分析详情页" Command="{Binding ShowAnalysisDetailPreviewCommand}" Margin="0,0,6,4"
                                Style="{StaticResource MaterialDesignFlatButton}" Foreground="#1976D2" Padding="12,4" Height="30" FontSize="12" />
                            <Button Content="新报告预览页" Command="{Binding ShowReportPreviewPageCommand}" Margin="0,0,6,4"
                                Style="{StaticResource MaterialDesignFlatButton}" Foreground="#7B1FA2" Padding="12,4" Height="30" FontSize="12" />
                            <Button Content="报告列表" Command="{Binding ShowReportListCommand}" Margin="0,0,6,4"
                                Style="{StaticResource MaterialDesignOutlinedButton}" Foreground="#7B1FA2" Padding="12,4" Height="30" FontSize="12" />
                            <Button Content="生成报告" Command="{Binding ShowReportGenerateCommand}" Margin="0,0,6,4"
                                Style="{StaticResource MaterialDesignOutlinedButton}" Foreground="#7B1FA2" Padding="12,4" Height="30" FontSize="12" />
                        </WrapPanel>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Border>

        <!-- 预览区域 -->
        <Grid Grid.Row="1" Background="#FFF3F6FA">
            <!-- 有内容时显示预览 -->
            <ScrollViewer
                Padding="20"
                HorizontalScrollBarVisibility="Auto"
                VerticalScrollBarVisibility="Auto"
                Visibility="{Binding PreviewContent, Converter={StaticResource NullableToVisibilityConverter}}">
                <ContentPresenter Content="{Binding PreviewContent}" />
            </ScrollViewer>

            <!-- 无内容时显示占位 -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding PreviewContent, Converter={StaticResource NullableToVisibilityConverter}, ConverterParameter=Inverse}">
                <materialDesign:PackIcon Kind="MonitorScreenshot" Width="64" Height="64"
                                         HorizontalAlignment="Center" Foreground="#BDBDBD" Margin="0,0,0,12" />
                <TextBlock Text="点击上方按钮选择一个场景进行预览" Foreground="#9E9E9E" FontSize="14" TextAlignment="Center" />
                <TextBlock Text="{Binding StatusText}" Foreground="#BDBDBD" FontSize="12"
                           TextAlignment="Center" Margin="0,8,0,0" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
