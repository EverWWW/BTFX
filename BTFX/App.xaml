<Application
    x:Class="BTFX.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:BTFX.Converters"
    xmlns:local="clr-namespace:BTFX"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    ShutdownMode="OnMainWindowClose">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!--  Material Design 主题  -->
                <materialDesign:BundledTheme
                    BaseTheme="Light"
                    PrimaryColor="Blue"
                    SecondaryColor="LightBlue" />

                <!--  Material Design 默认样式  -->
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml" />

                <!--  多语言资源 - 默认中文  -->
                <ResourceDictionary Source="Resources/Localization/Strings.zh.xaml" />

                <!--  自定义样式  -->
                <ResourceDictionary Source="Resources/Styles/ButtonStyles.xaml" />
                <ResourceDictionary Source="Resources/Styles/SelectionStyles.xaml" />
                <ResourceDictionary Source="Resources/Styles/TextBoxStyles.xaml" />
                <ResourceDictionary Source="Resources/Styles/DataGridStyles.xaml" />

            </ResourceDictionary.MergedDictionaries>

            <!--  Override framework default background so DynamicResource MaterialDesign.Brush.Background 使用公司颜色  -->
            <SolidColorBrush x:Key="MaterialDesign.Brush.Primary" Color="#FF009EDB" />

            <!--  Converters  -->
            <converters:NullableToVisibilityConverter x:Key="NullableToVisibilityConverter" />
            <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <converters:InverseBooleanConverter x:Key="InverseBooleanConverter" />
            <converters:EnumToDescriptionConverter x:Key="EnumToDescriptionConverter" />
            <converters:EmptyDataVisibilityConverter x:Key="EmptyDataVisibilityConverter" />
            <converters:EnumToIndexConverter x:Key="EnumToIndexConverter" />
            <converters:StringToColorBrushConverter x:Key="StringToColorBrushConverter" />
            <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />
            <converters:GreaterThanOneConverter x:Key="GreaterThanOneConverter" />
            <converters:CountToVisibilityConverter x:Key="CountToVisibilityConverter" />
            <converters:EnumToBooleanConverter x:Key="EnumToBooleanConverter" />
            <converters:BooleanToValueConverter x:Key="BooleanToValueConverter" />
            <converters:AnalysisStateToVisibilityConverter x:Key="AnalysisStateToVisibilityConverter" />
            <converters:ProgressToStageStatusConverter x:Key="ProgressToStageStatusConverter" />
            <converters:PrerequisiteStatusToColorConverter x:Key="PrerequisiteStatusToColorConverter" />
            <converters:PrerequisiteStatusToIconConverter x:Key="PrerequisiteStatusToIconConverter" />
            <converters:QualityBoolToStatusConverter x:Key="QualityBoolToStatusConverter" />

            <!--
                字体资源
                Alibaba PuHuiTi 3.0 仅包含 Regular (55) 字重文件，
                Medium / Bold 等字重在该字体中无真实字形，WPF 会合成粗体导致显示异常。
                因此使用"Microsoft YaHei UI"作为主字体（系统自带 Light / Regular / Bold），
                Alibaba PuHuiTi 3.0 保留作为备选。如需完整使用 Alibaba PuHuiTi，
                请将 65-Medium、75-SemiBold、85-Bold 等字重 TTF 文件放入 Resources/Fonts 文件夹。
            -->
            <FontFamily x:Key="AppFont">Microsoft YaHei UI, pack://application:,,,/Resources/Fonts/#Alibaba PuHuiTi 3.0</FontFamily>

            <!--
                全局字体样式 —— 通过 TextElement.FontFamily 向下继承到所有子元素，
                不覆盖 TextBlock / Button / TextBox 等控件的隐式样式，
                避免破坏 MaterialDesign 内部控件模板
            -->
            <Style BasedOn="{StaticResource {x:Type Window}}" TargetType="Window">
                <Setter Property="TextElement.FontFamily" Value="{StaticResource AppFont}" />
                <Setter Property="TextElement.FontSize" Value="14" />
                <Setter Property="UseLayoutRounding" Value="True" />
                <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
            </Style>

            <CubicEase x:Key="DialogAnimationEase" EasingMode="EaseOut" />

            <Style x:Key="DialogAnimatedSurfaceStyle" TargetType="FrameworkElement">
                <Setter Property="Opacity" Value="0" />
                <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <ScaleTransform ScaleX="0.96" ScaleY="0.96" />
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                        <BeginStoryboard>
                            <Storyboard FillBehavior="HoldEnd">
                                <DoubleAnimation
                                    EasingFunction="{StaticResource DialogAnimationEase}"
                                    Storyboard.TargetProperty="Opacity"
                                    To="1"
                                    Duration="0:0:0.2" />
                                <DoubleAnimation
                                    EasingFunction="{StaticResource DialogAnimationEase}"
                                    Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                    To="1"
                                    Duration="0:0:0.22" />
                                <DoubleAnimation
                                    EasingFunction="{StaticResource DialogAnimationEase}"
                                    Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                    To="1"
                                    Duration="0:0:0.22" />
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Style.Triggers>
            </Style>

            <Style
                x:Key="DialogSurfaceBorderStyle"
                BasedOn="{StaticResource DialogAnimatedSurfaceStyle}"
                TargetType="Border">
                <Setter Property="Background" Value="#FFFFFF" />
                <Setter Property="CornerRadius" Value="2" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect
                            BlurRadius="24"
                            Direction="270"
                            Opacity="0.16"
                            ShadowDepth="8"
                            Color="#1F2A37" />
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="DialogScrollBarThumbStyle" TargetType="Thumb">
                <Setter Property="Background" Value="#CCD8E2" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Thumb">
                            <Border
                                Margin="2,0"
                                Background="{TemplateBinding Background}"
                                CornerRadius="3" />
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#B7C6D3" />
                    </Trigger>
                    <Trigger Property="IsDragging" Value="True">
                        <Setter Property="Background" Value="#9FB4C5" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="DialogScrollBarPageButtonStyle" TargetType="RepeatButton">
                <Setter Property="Focusable" Value="False" />
                <Setter Property="IsTabStop" Value="False" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RepeatButton">
                            <Border Background="Transparent" />
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="DialogLightScrollBarStyle" TargetType="ScrollBar">
                <Setter Property="Width" Value="8" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Margin" Value="4,0,0,0" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ScrollBar">
                            <Grid Background="Transparent">
                                <Track x:Name="PART_Track" IsDirectionReversed="True">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Command="ScrollBar.PageUpCommand" Style="{StaticResource DialogScrollBarPageButtonStyle}" />
                                    </Track.DecreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource DialogScrollBarThumbStyle}" />
                                    </Track.Thumb>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Command="ScrollBar.PageDownCommand" Style="{StaticResource DialogScrollBarPageButtonStyle}" />
                                    </Track.IncreaseRepeatButton>
                                </Track>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="Orientation" Value="Horizontal">
                                    <Setter Property="Height" Value="8" />
                                    <Setter Property="Width" Value="Auto" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="DialogLightweightScrollViewerStyle" TargetType="ScrollViewer">
                <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
                <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
                <Setter Property="CanContentScroll" Value="True" />
                <Setter Property="PanningMode" Value="VerticalOnly" />
            </Style>

        </ResourceDictionary>
    </Application.Resources>

</Application>
