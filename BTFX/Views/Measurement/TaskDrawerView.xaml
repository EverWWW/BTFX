<UserControl x:Class="BTFX.Views.Measurement.TaskDrawerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BTFX.Views.Measurement"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:BTFX.ViewModels.Measurement"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=vm:MeasurementViewModel}"
             d:DesignHeight="200" d:DesignWidth="800"
             Background="{DynamicResource MaterialDesign.Brush.Card.Background}">

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="300" />
        </Grid.ColumnDefinitions>

        <!-- 左侧：当前任务 -->
        <StackPanel Grid.Column="0">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <materialDesign:PackIcon Kind="Play" 
                                         VerticalAlignment="Center"
                                         Margin="0,0,8,0" />
                <TextBlock Text="{DynamicResource MA.Task.CurrentTask}"
                           Style="{StaticResource MaterialDesignSubtitle1TextBlock}" />
            </StackPanel>

            <!-- 有任务时显示 -->
            <StackPanel Visibility="{Binding IsAnalyzing, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Text="{Binding CurrentTaskName}"
                           Style="{StaticResource MaterialDesignBody1TextBlock}"
                           Margin="0,0,0,8" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <ProgressBar Grid.Column="0" 
                                 Value="{Binding AnalysisProgress}"
                                 Height="8"
                                 VerticalAlignment="Center" />

                    <TextBlock Grid.Column="1"
                               Margin="12,0,0,0"
                               VerticalAlignment="Center">
                        <Run Text="{Binding AnalysisProgress}" /><Run Text="%" />
                    </TextBlock>
                </Grid>

                <Button Content="{DynamicResource MA.Step4.Run.Cancel}"
                        Command="{Binding CancelAnalyzeCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        HorizontalAlignment="Left"
                        Margin="0,12,0,0" />
            </StackPanel>

            <!-- 无任务时显示 -->
            <TextBlock Text="{DynamicResource MA.Task.NoTask}"
                       Foreground="Gray"
                       Visibility="{Binding IsAnalyzing, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverse}" />
        </StackPanel>

        <!-- 右侧：日志 -->
        <Border Grid.Column="2" 
                BorderBrush="{DynamicResource MaterialDesign.Brush.TextBox.HoverBackground}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" 
                           Text="{DynamicResource MA.Task.Log}"
                           Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                           Margin="0,0,0,8" />

                <ListBox Grid.Row="1"
                         ItemsSource="{Binding TaskLogs}"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" 
                                       TextWrapping="Wrap"
                                       FontSize="11"
                                       FontFamily="Consolas" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- 关闭按钮 -->
        <Button Style="{StaticResource MaterialDesignIconButton}"
                Command="{Binding ToggleTaskDrawerCommand}"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,-8,-8,0">
            <materialDesign:PackIcon Kind="Close" />
        </Button>
    </Grid>
</UserControl>
