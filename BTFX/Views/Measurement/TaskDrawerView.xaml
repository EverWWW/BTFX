<UserControl
    x:Class="BTFX.Views.Measurement.TaskDrawerView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:BTFX.Views.Measurement"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:BTFX.ViewModels.Measurement"
    d:DataContext="{d:DesignInstance Type=vm:MeasurementViewModel}"
    d:DesignHeight="200"
    d:DesignWidth="800"
    Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
    mc:Ignorable="d">

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="300" />
        </Grid.ColumnDefinitions>

        <!--  左侧：当前任务  -->
        <StackPanel Grid.Column="0">
            <StackPanel Margin="0,0,0,12" Orientation="Horizontal">
                <materialDesign:PackIcon
                    Margin="0,0,8,0"
                    VerticalAlignment="Center"
                    Kind="Play" />
                <TextBlock Style="{StaticResource MaterialDesignSubtitle1TextBlock}" Text="{DynamicResource MA.Task.CurrentTask}" />
            </StackPanel>

            <!--  有任务时显示  -->
            <StackPanel Visibility="{Binding IsAnalyzing, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock
                    Margin="0,0,0,8"
                    Style="{StaticResource MaterialDesignBody1TextBlock}"
                    Text="{Binding CurrentTaskName}" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <ProgressBar
                        Grid.Column="0"
                        Height="8"
                        VerticalAlignment="Center"
                        Value="{Binding AnalysisProgress, Mode=OneWay}" />

                    <TextBlock
                        Grid.Column="1"
                        Margin="12,0,0,0"
                        VerticalAlignment="Center">
                        <Run Text="{Binding AnalysisProgress}" /><Run Text="%" />
                    </TextBlock>
                </Grid>

                <Button
                    Margin="0,12,0,0"
                    HorizontalAlignment="Left"
                    Command="{Binding CancelAnalyzeCommand}"
                    Content="{DynamicResource MA.Step4.Run.Cancel}"
                    Style="{StaticResource MaterialDesignOutlinedButton}" />
            </StackPanel>

            <!--  无任务时显示  -->
            <TextBlock
                Foreground="Gray"
                Text="{DynamicResource MA.Task.NoTask}"
                Visibility="{Binding IsAnalyzing, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverse}" />
        </StackPanel>

        <!--  右侧：日志  -->
        <Border
            Grid.Column="2"
            Padding="8"
            BorderBrush="{DynamicResource MaterialDesign.Brush.TextBox.HoverBackground}"
            BorderThickness="1"
            CornerRadius="4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock
                    Grid.Row="0"
                    Margin="0,0,0,8"
                    Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                    Text="{DynamicResource MA.Task.Log}" />

                <ListBox
                    Grid.Row="1"
                    Background="Transparent"
                    BorderThickness="0"
                    ItemsSource="{Binding TaskLogs}"
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock
                                FontFamily="Consolas"
                                FontSize="11"
                                Text="{Binding}"
                                TextWrapping="Wrap" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!--  关闭按钮  -->
        <Button
            Margin="0,-8,-8,0"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Command="{Binding ToggleTaskDrawerCommand}"
            Style="{StaticResource MaterialDesignIconButton}">
            <materialDesign:PackIcon Kind="Close" />
        </Button>
    </Grid>
</UserControl>
