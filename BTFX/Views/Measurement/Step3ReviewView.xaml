<UserControl x:Class="BTFX.Views.Measurement.Step3ReviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BTFX.Views.Measurement"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:BTFX.ViewModels.Measurement"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=vm:MeasurementViewModel}"
             d:DesignHeight="650" d:DesignWidth="750">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0" 
                   Text="{DynamicResource MA.Step3.Title}"
                   Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                   Margin="0,0,0,16" />

        <!-- 内容区 -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- 视频区：单/双视频自适应布局 -->
            <Grid Grid.Row="0">

                <!-- 双视频模式：播放已合成的并排预览视频 -->
                <Grid Visibility="{Binding HasDualVideo, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <materialDesign:Card>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0"
                                       Text="正面 / 侧面视频合成预览"
                                       Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                                       Margin="12,8" />
                            <Border Grid.Row="1" Background="Black" MinHeight="320">
                                <Grid>
                                    <MediaElement x:Name="DualPreviewMediaElement"
                                                  LoadedBehavior="Manual"
                                                  UnloadedBehavior="Manual"
                                                  Stretch="Uniform"
                                                  ScrubbingEnabled="True"
                                                  MediaOpened="PreviewMediaElement_OnMediaOpened"
                                                  MediaEnded="PreviewMediaElement_OnMediaEnded"
                                                  MediaFailed="PreviewMediaElement_OnMediaFailed" />
                                    <Image x:Name="FrontDualImage" Visibility="Collapsed" />
                                    <Image x:Name="SideDualImage" Visibility="Collapsed" />
                                </Grid>
                            </Border>
                        </Grid>
                    </materialDesign:Card>
                </Grid>

                <!-- 单视频模式：居中单个播放卡片 -->
                <Grid Visibility="{Binding HasDualVideo, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <materialDesign:Card Grid.Column="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <!-- 标题根据哪个视频存在决定 -->
                            <TextBlock Grid.Row="0" Margin="12,8">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource MaterialDesignSubtitle1TextBlock}">
                                        <Setter Property="Text" Value="{DynamicResource MA.Step3.FrontView}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasFrontVideo}" Value="False">
                                                <Setter Property="Text" Value="{DynamicResource MA.Step3.SideView}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <Border Grid.Row="1" Background="Black" MinHeight="280">
                                <Grid>
                                    <MediaElement x:Name="SinglePreviewMediaElement"
                                                  LoadedBehavior="Manual"
                                                  UnloadedBehavior="Manual"
                                                  Stretch="Uniform"
                                                  ScrubbingEnabled="True"
                                                  MediaOpened="PreviewMediaElement_OnMediaOpened"
                                                  MediaEnded="PreviewMediaElement_OnMediaEnded"
                                                  MediaFailed="PreviewMediaElement_OnMediaFailed" />
                                    <Image x:Name="FrontSingleImage"
                                           Stretch="Uniform"
                                           Visibility="Collapsed" />
                                    <Image x:Name="SideSingleImage"
                                           Stretch="Uniform"
                                           Visibility="Collapsed" />
                                </Grid>
                            </Border>
                        </Grid>
                    </materialDesign:Card>
                </Grid>
            </Grid>

            <!-- 播放控制条 -->
            <materialDesign:Card Grid.Row="1" Margin="0,16,0,0" Padding="16,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- 左侧：播放控制按钮 -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Button x:Name="PrevFrameButton"
                                Style="{StaticResource MaterialDesignIconButton}"
                                ToolTip="{DynamicResource MA.Step3.Controls.PrevFrame}"
                                Click="PrevFrameButton_OnClick">
                            <materialDesign:PackIcon Kind="SkipPrevious" />
                        </Button>
                        <Button x:Name="PlayPauseButton"
                                Style="{StaticResource MaterialDesignIconButton}"
                                ToolTip="{DynamicResource MA.Step3.Controls.Play}"
                                Click="PlayPauseButton_OnClick">
                            <materialDesign:PackIcon x:Name="PlayPauseIcon" Kind="Play" />
                        </Button>
                        <Button x:Name="NextFrameButton"
                                Style="{StaticResource MaterialDesignIconButton}"
                                ToolTip="{DynamicResource MA.Step3.Controls.NextFrame}"
                                Click="NextFrameButton_OnClick">
                            <materialDesign:PackIcon Kind="SkipNext" />
                        </Button>
                    </StackPanel>

                    <!-- 中间：进度条 -->
                    <Grid Grid.Column="1" Margin="16,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="PlaybackStatusTextBlock"
                                   Grid.Column="0"
                                   VerticalAlignment="Center"
                                   Margin="0,0,12,0"
                                   Foreground="Gray" />
                        <Slider x:Name="ProgressSlider"
                                Grid.Column="1"
                                Minimum="0"
                                Maximum="0"
                                Value="0"
                                VerticalAlignment="Center"
                                PreviewMouseDown="ProgressSlider_OnPreviewMouseDown"
                                PreviewMouseMove="ProgressSlider_OnPreviewMouseMove"
                                PreviewMouseUp="ProgressSlider_OnPreviewMouseUp"
                                ValueChanged="ProgressSlider_OnValueChanged" />
                        <TextBlock x:Name="TimeTextBlock"
                                   Grid.Column="2"
                                   Text="00:00.0 / 00:00.0"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0"
                                   Foreground="Gray" />
                    </Grid>

                    <!-- 右侧：倍速选择 -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <TextBlock Text="{DynamicResource MA.Step3.Controls.Speed}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0" />
                        <ComboBox x:Name="SpeedComboBox"
                                  Width="80"
                                  SelectedIndex="1"
                                  SelectionChanged="SpeedComboBox_OnSelectionChanged">
                            <ComboBoxItem Content="0.5x" Tag="0.5" />
                            <ComboBoxItem Content="1x" Tag="1" />
                            <ComboBoxItem Content="2x" Tag="2" />
                        </ComboBox>
                    </StackPanel>
                </Grid>
            </materialDesign:Card>
        </Grid>

        <!-- 底部操作栏 -->
        <Border Grid.Row="2" Padding="0,16,0,0">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button Content="{DynamicResource MA.Step3.BackToImport}"
                            Command="{Binding PreviousStepCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="{DynamicResource MA.Step3.GoAnalyze}"
                            Command="{Binding GoToStepCommand}"
                            CommandParameter="3"
                            IsEnabled="{Binding HasAnyVideo}"
                            Style="{StaticResource MaterialDesignRaisedButton}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
