<UserControl x:Class="BTFX.Views.Measurement.Step3ReviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BTFX.Views.Measurement"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:BTFX.ViewModels.Measurement"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=vm:MeasurementViewModel}"
             d:DesignHeight="650" d:DesignWidth="750">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0" 
                   Text="{DynamicResource MA.Step3.Title}"
                   Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                   Margin="0,0,0,16" />

        <!-- 内容区 -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- 上半区：双画面回放 -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- 正面视频播放区域（占位） -->
                <materialDesign:Card Grid.Column="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" 
                                   Text="{DynamicResource MA.Step3.FrontView}"
                                   Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                                   Margin="12,8" />

                        <!-- 播放器占位 -->
                        <Border Grid.Row="1" Background="Black" MinHeight="200">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="PlayCircleOutline" 
                                                         Width="64" Height="64" 
                                                         Foreground="White"
                                                         HorizontalAlignment="Center" />
                                <TextBlock Foreground="White" 
                                           HorizontalAlignment="Center"
                                           Margin="0,8,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{DynamicResource MA.Step3.Player.NotLoaded}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasFrontVideo}" Value="True">
                                                    <Setter Property="Text" Value="{DynamicResource MA.Step3.Player.Loaded}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </Grid>
                </materialDesign:Card>

                <!-- 侧面视频播放区域（占位） -->
                <materialDesign:Card Grid.Column="2">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" 
                                   Text="{DynamicResource MA.Step3.SideView}"
                                   Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                                   Margin="12,8" />

                        <!-- 播放器占位 -->
                        <Border Grid.Row="1" Background="Black" MinHeight="200">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="PlayCircleOutline" 
                                                         Width="64" Height="64" 
                                                         Foreground="White"
                                                         HorizontalAlignment="Center" />
                                <TextBlock Foreground="White" 
                                           HorizontalAlignment="Center"
                                           Margin="0,8,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{DynamicResource MA.Step3.Player.NotLoaded}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasSideVideo}" Value="True">
                                                    <Setter Property="Text" Value="{DynamicResource MA.Step3.Player.Loaded}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </Grid>
                </materialDesign:Card>
            </Grid>

            <!-- 播放控制条 -->
            <materialDesign:Card Grid.Row="1" Margin="0,16,0,0" Padding="16,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- 左侧：播放控制按钮 -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Button Style="{StaticResource MaterialDesignIconButton}"
                                ToolTip="{DynamicResource MA.Step3.Controls.PrevFrame}"
                                IsEnabled="False">
                            <materialDesign:PackIcon Kind="SkipPrevious" />
                        </Button>
                        <Button Style="{StaticResource MaterialDesignIconButton}"
                                ToolTip="{DynamicResource MA.Step3.Controls.Play}"
                                IsEnabled="False">
                            <materialDesign:PackIcon Kind="Play" />
                        </Button>
                        <Button Style="{StaticResource MaterialDesignIconButton}"
                                ToolTip="{DynamicResource MA.Step3.Controls.NextFrame}"
                                IsEnabled="False">
                            <materialDesign:PackIcon Kind="SkipNext" />
                        </Button>
                    </StackPanel>

                    <!-- 中间：进度条 -->
                    <Grid Grid.Column="1" Margin="16,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Slider Grid.Column="0" 
                                Minimum="0" Maximum="100" Value="0"
                                IsEnabled="False"
                                VerticalAlignment="Center" />

                        <TextBlock Grid.Column="1" 
                                   Text="00:00 / 00:00"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0"
                                   Foreground="Gray" />
                    </Grid>

                    <!-- 右侧：倍速选择 -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <TextBlock Text="{DynamicResource MA.Step3.Controls.Speed}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0" />
                        <ComboBox Width="80" SelectedIndex="1" IsEnabled="False">
                            <ComboBoxItem Content="0.5x" />
                            <ComboBoxItem Content="1x" />
                            <ComboBoxItem Content="2x" />
                        </ComboBox>
                    </StackPanel>
                </Grid>
            </materialDesign:Card>

            <!-- 下半区：叠加与事件 -->
            <Grid Grid.Row="2" Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Overlay 叠加显示选项 -->
                <materialDesign:Card Grid.Column="0" Padding="16">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource MA.Step3.Overlay.Title}"
                                   Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                                   Margin="0,0,0,12" />

                        <CheckBox Content="{DynamicResource MA.Step3.Overlay.ShowKeypoints}"
                                  IsEnabled="False"
                                  Margin="0,0,0,8" />
                        <CheckBox Content="{DynamicResource MA.Step3.Overlay.ShowSkeleton}"
                                  IsEnabled="False"
                                  Margin="0,0,0,8" />
                        <CheckBox Content="{DynamicResource MA.Step3.Overlay.ShowConfidence}"
                                  IsEnabled="False"
                                  Margin="0,0,0,12" />

                        <!-- 空状态提示 -->
                        <Border Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                                BorderBrush="{DynamicResource MaterialDesign.Brush.TextBox.HoverBackground}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="12">
                            <TextBlock Text="{DynamicResource MA.Step3.Overlay.NoKeypoints}"
                                       TextWrapping="Wrap"
                                       Foreground="Gray"
                                       FontSize="12" />
                        </Border>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Timeline 事件时间轴 -->
                <materialDesign:Card Grid.Column="2" Padding="16">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource MA.Step3.Timeline.Title}"
                                   Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                                   Margin="0,0,0,12" />

                        <!-- 空状态提示 -->
                        <Border Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                                BorderBrush="{DynamicResource MaterialDesign.Brush.TextBox.HoverBackground}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="12"
                                MinHeight="80">
                            <TextBlock Text="{DynamicResource MA.Step3.Timeline.NoEvents}"
                                       TextWrapping="Wrap"
                                       Foreground="Gray"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center" />
                        </Border>
                    </StackPanel>
                </materialDesign:Card>
            </Grid>
        </Grid>

        <!-- 底部操作栏 -->
        <Border Grid.Row="2" Padding="0,16,0,0">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button Content="{DynamicResource MA.Step3.BackToImport}"
                            Command="{Binding PreviousStepCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="{DynamicResource MA.Step3.GoAnalyze}"
                            Command="{Binding GoToStepCommand}"
                            CommandParameter="4"
                            IsEnabled="{Binding HasDualVideo}"
                            Style="{StaticResource MaterialDesignRaisedButton}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
