<UserControl x:Class="BTFX.Views.Measurement.MeasurementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BTFX.Views.Measurement"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:BTFX.ViewModels.Measurement"
             xmlns:converters="clr-namespace:BTFX.Converters"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=vm:MeasurementViewModel}"
             d:DesignHeight="720" d:DesignWidth="1200"
             Background="{DynamicResource MaterialDesign.Brush.Background}">

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVisConverter" />
        <converters:InverseBooleanConverter x:Key="InverseBoolConverter" />

        <!-- 步骤项样式 -->
        <Style x:Key="StepItemStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
            <Setter Property="Height" Value="64" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Margin" Value="0,2" />
        </Style>
    </UserControl.Resources>

    <!-- 使用 DrawerHost 实现底部抽屉 -->
    <materialDesign:DrawerHost IsBottomDrawerOpen="{Binding IsTaskDrawerOpen}">

        <!-- 底部抽屉内容 -->
        <materialDesign:DrawerHost.BottomDrawerContent>
            <local:TaskDrawerView DataContext="{Binding}" Height="200" />
        </materialDesign:DrawerHost.BottomDrawerContent>

        <!-- 主内容区 -->
        <Grid>
            <Grid.ColumnDefinitions>
                <!-- 左侧 StepBar -->
                <ColumnDefinition Width="200" />
                <!-- 中间内容区 -->
                <ColumnDefinition Width="*" />
                <!-- 右侧信息栏 -->
                <ColumnDefinition Width="280" />
            </Grid.ColumnDefinitions>

            <!-- 左侧 StepBar -->
            <Border Grid.Column="0" 
                    BorderBrush="{DynamicResource MaterialDesign.Brush.Primary.Light}" 
                    BorderThickness="0,0,1,0"
                    Background="{DynamicResource MaterialDesign.Brush.Card.Background}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- 标题 -->
                    <TextBlock Grid.Row="0" 
                               Text="{DynamicResource MA.Common.MeasurementAssessment}"
                               Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                               Margin="16,16,16,8" />

                    <!-- 四步导航 -->
                    <StackPanel Grid.Row="1" Margin="8,8,8,8">

                        <!-- Step 1: 新建测量 -->
                        <Button Style="{StaticResource StepItemStyle}"
                                Command="{Binding GoToStepCommand}"
                                CommandParameter="1">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="32" Height="32" CornerRadius="16">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{DynamicResource MaterialDesign.Brush.Primary.Light}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsStep1}" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource MaterialDesign.Brush.Primary}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="1" Foreground="White" 
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               FontWeight="Bold" />
                                </Border>
                                <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{DynamicResource MA.StepBar.Step1}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontWeight" Value="Normal" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsStep1}" Value="True">
                                                        <Setter Property="FontWeight" Value="Bold" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>
                        </Button>

                        <!-- Step 2: 导入/采集 -->
                        <Button Style="{StaticResource StepItemStyle}"
                                Command="{Binding GoToStepCommand}"
                                CommandParameter="2"
                                IsEnabled="{Binding CanGoToStep2}">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="32" Height="32" CornerRadius="16">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{DynamicResource MaterialDesign.Brush.Primary.Light}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsStep2}" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource MaterialDesign.Brush.Primary}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding CanGoToStep2}" Value="False">
                                                    <Setter Property="Background" Value="Gray" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="2" Foreground="White" 
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               FontWeight="Bold" />
                                </Border>
                                <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{DynamicResource MA.StepBar.Step2}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontWeight" Value="Normal" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsStep2}" Value="True">
                                                        <Setter Property="FontWeight" Value="Bold" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>
                        </Button>

                        <!-- Step 3: 回放检查 -->
                        <Button Style="{StaticResource StepItemStyle}"
                                Command="{Binding GoToStepCommand}"
                                CommandParameter="3"
                                IsEnabled="{Binding CanGoToStep3}">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="32" Height="32" CornerRadius="16">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{DynamicResource MaterialDesign.Brush.Primary.Light}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsStep3}" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource MaterialDesign.Brush.Primary}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding CanGoToStep3}" Value="False">
                                                    <Setter Property="Background" Value="Gray" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="3" Foreground="White" 
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               FontWeight="Bold" />
                                </Border>
                                <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{DynamicResource MA.StepBar.Step3}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontWeight" Value="Normal" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsStep3}" Value="True">
                                                        <Setter Property="FontWeight" Value="Bold" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>
                        </Button>

                        <!-- Step 4: 分析结果 -->
                        <Button Style="{StaticResource StepItemStyle}"
                                Command="{Binding GoToStepCommand}"
                                CommandParameter="4"
                                IsEnabled="{Binding CanGoToStep4}">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="32" Height="32" CornerRadius="16">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{DynamicResource MaterialDesign.Brush.Primary.Light}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsStep4}" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource MaterialDesign.Brush.Primary}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding CanGoToStep4}" Value="False">
                                                    <Setter Property="Background" Value="Gray" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="4" Foreground="White" 
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               FontWeight="Bold" />
                                </Border>
                                <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{DynamicResource MA.StepBar.Step4}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontWeight" Value="Normal" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsStep4}" Value="True">
                                                        <Setter Property="FontWeight" Value="Bold" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>
                        </Button>

                    </StackPanel>
                </Grid>
            </Border>

            <!-- 中间内容区 - 使用 ContentControl 切换步骤视图 -->
            <Border Grid.Column="1" Margin="16">
                <ContentControl>
                    <ContentControl.Style>
                        <Style TargetType="ContentControl">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentStep}" Value="1">
                                    <Setter Property="Content">
                                        <Setter.Value>
                                            <local:Step1CreateMeasurementView DataContext="{Binding}" />
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding CurrentStep}" Value="2">
                                    <Setter Property="Content">
                                        <Setter.Value>
                                            <local:Step2VideoSourceView DataContext="{Binding}" />
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding CurrentStep}" Value="3">
                                    <Setter Property="Content">
                                        <Setter.Value>
                                            <local:Step3ReviewView DataContext="{Binding}" />
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding CurrentStep}" Value="4">
                                    <Setter Property="Content">
                                        <Setter.Value>
                                            <local:Step4AnalyzeView DataContext="{Binding}" />
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ContentControl.Style>
                </ContentControl>
            </Border>

            <!-- 右侧信息栏 -->
            <Border Grid.Column="2" 
                    BorderBrush="{DynamicResource MaterialDesign.Brush.Primary.Light}" 
                    BorderThickness="1,0,0,0"
                    Background="{DynamicResource MaterialDesign.Brush.Card.Background}">
                <local:InfoPanelView DataContext="{Binding}" />
            </Border>

        </Grid>
    </materialDesign:DrawerHost>
</UserControl>
