<UserControl x:Class="BTFX.Views.Measurement.MeasurementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:BTFX.Views.Measurement"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:BTFX.ViewModels.Measurement"
             xmlns:converters="clr-namespace:BTFX.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:MeasurementViewModel}"
             d:DesignHeight="720"
             d:DesignWidth="1200"
             Background="{DynamicResource MaterialDesign.Brush.Background}">

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVisConverter" />
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVisConverter" />

        <DataTemplate x:Key="Step1CreateMeasurementTemplate">
            <local:Step1CreateMeasurementView />
        </DataTemplate>

        <DataTemplate x:Key="Step2ReviewTemplate">
            <local:Step3ReviewView />
        </DataTemplate>

        <DataTemplate x:Key="Step3AnalyzeTemplate">
            <local:Step4AnalyzeView DataContext="{Binding AnalyzeViewModel}" />
        </DataTemplate>

        <Style x:Key="TopStepButtonStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
            <Setter Property="MinHeight" Value="58" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>
    </UserControl.Resources>

    <materialDesign:DrawerHost IsBottomDrawerOpen="{Binding IsTaskDrawerOpen}">
        <materialDesign:DrawerHost.BottomDrawerContent>
            <local:TaskDrawerView DataContext="{Binding}" Height="200" />
        </materialDesign:DrawerHost.BottomDrawerContent>

        <Grid>
            <!-- 封面 -->
            <Grid Margin="32"
                  Visibility="{Binding IsCover, Converter={StaticResource BoolToVisConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.05*" />
                    <ColumnDefinition Width="40" />
                    <ColumnDefinition Width="0.95*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Padding="34"
                        Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                        CornerRadius="8"
                        BorderBrush="#E1E6EC"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="步态智能分析系统测量评估注意事项"
                                   FontSize="26"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,26" />
                        <TextBlock Text="1、在视频采集过程中，请被采集人匀速并自然的走路，不要脱离地垫范围;"
                                   FontSize="17"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,16" />
                        <TextBlock Text="2、请被采集人不要穿太过宽松的衣服，否则会影响识别精度;"
                                   FontSize="17"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,16" />
                        <TextBlock Text="3、请保持现场光源明亮，注意不要太暗;"
                                   FontSize="17"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,16" />
                        <TextBlock Text="4、视频采集相机注意不要被障碍物遮挡;"
                                   FontSize="17"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,16" />
                        <TextBlock Text="5、步态视频采集过程中，请不要挪动相机位置，否则影响测量结果。"
                                   FontSize="17"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Padding="24"
                            Background="#F5F8FA"
                            CornerRadius="8"
                            BorderBrush="#E1E6EC"
                            BorderThickness="1">
                        <Image Source="/Resources/Images/Device/deviceImage.jpeg"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                    </Border>

                    <Button Grid.Row="1"
                            Height="58"
                            Margin="0,22,0,0"
                            Command="{Binding StartMeasurementCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="PlusCircleOutline"
                                                     Width="22"
                                                     Height="22"
                                                     Margin="0,0,8,0" />
                            <TextBlock Text="创建测量" FontSize="18" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Grid>

            <!-- 三步骤流程 -->
            <Grid Visibility="{Binding IsInWorkflow, Converter={StaticResource BoolToVisConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Padding="24,18"
                        Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                        BorderBrush="#E1E6EC"
                        BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="28" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="测量评估"
                                       FontSize="22"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{Binding CurrentStepTitle}"
                                       Margin="0,4,0,0"
                                       Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}" />
                        </StackPanel>

                        <UniformGrid Grid.Column="2"
                                     Columns="3"
                                     VerticalAlignment="Center">
                            <Button Style="{StaticResource TopStepButtonStyle}"
                                    Command="{Binding GoToStepCommand}"
                                    CommandParameter="1">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="34" Height="34" CornerRadius="17">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#B9C4D0" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsStep1}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource MaterialDesign.Brush.Primary}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="1"
                                                   Foreground="White"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Text="新建测量"
                                               Margin="10,0,0,0"
                                               VerticalAlignment="Center"
                                               FontSize="15" />
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource TopStepButtonStyle}"
                                    Command="{Binding GoToStepCommand}"
                                    CommandParameter="2"
                                    IsEnabled="{Binding CanGoToStep2}">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="34" Height="34" CornerRadius="17">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#B9C4D0" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsStep2}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource MaterialDesign.Brush.Primary}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding CanGoToStep2}" Value="False">
                                                        <Setter Property="Background" Value="#D5DADF" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="2"
                                                   Foreground="White"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Text="回放检查"
                                               Margin="10,0,0,0"
                                               VerticalAlignment="Center"
                                               FontSize="15" />
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource TopStepButtonStyle}"
                                    Command="{Binding GoToStepCommand}"
                                    CommandParameter="3"
                                    IsEnabled="{Binding CanGoToStep3}">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="34" Height="34" CornerRadius="17">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#B9C4D0" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsStep3}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource MaterialDesign.Brush.Primary}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding CanGoToStep3}" Value="False">
                                                        <Setter Property="Background" Value="#D5DADF" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="3"
                                                   Foreground="White"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Text="分析结果"
                                               Margin="10,0,0,0"
                                               VerticalAlignment="Center"
                                               FontSize="15" />
                                </StackPanel>
                            </Button>
                        </UniformGrid>
                    </Grid>
                </Border>

                <Grid Grid.Row="1">
                    <Border Margin="24">
                        <ContentControl Content="{Binding}">
                            <ContentControl.Style>
                                <Style TargetType="ContentControl">
                                    <Setter Property="ContentTemplate" Value="{StaticResource Step1CreateMeasurementTemplate}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="1">
                                            <Setter Property="ContentTemplate" Value="{StaticResource Step1CreateMeasurementTemplate}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="2">
                                            <Setter Property="ContentTemplate" Value="{StaticResource Step2ReviewTemplate}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="3">
                                            <Setter Property="ContentTemplate" Value="{StaticResource Step3AnalyzeTemplate}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ContentControl.Style>
                        </ContentControl>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </materialDesign:DrawerHost>
</UserControl>
