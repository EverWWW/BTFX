<UserControl x:Class="BTFX.Views.Measurement.Step2VideoSourceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BTFX.Views.Measurement"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:BTFX.ViewModels.Measurement"
             xmlns:common="clr-namespace:BTFX.Common"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=vm:MeasurementViewModel}"
             d:DesignHeight="600" d:DesignWidth="700">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0" 
                   Text="{DynamicResource MA.Step2.Title}"
                   Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                   Margin="0,0,0,16" />

        <!-- TabControl: 导入 / 采集 -->
        <TabControl Grid.Row="1" Style="{StaticResource MaterialDesignFilledTabControl}">

            <!-- Tab1: 导入视频 -->
            <TabItem Header="{DynamicResource MA.Step2.Tab.Import}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,16,0,0">
                    <StackPanel>

                        <!-- 双视频卡片区域 -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- 正面视频卡片 -->
                            <materialDesign:Card Grid.Column="0" Padding="16">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource MA.Step2.FrontVideo}"
                                               Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                                               Margin="0,0,0,12" />

                                    <!-- 视频路径 -->
                                    <TextBox Text="{Binding FrontVideoPath, Mode=OneWay}"
                                             IsReadOnly="True"
                                             materialDesign:HintAssist.Hint="{DynamicResource MA.Step2.FrontVideo}"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             Margin="0,0,0,12" />

                                    <!-- 元信息（占位） -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <TextBlock Text="{DynamicResource MA.Step2.Meta.Resolution}" Margin="0,0,4,0" />
                                        <TextBlock Text="{DynamicResource MA.Common.NotAvailable}" Foreground="Gray" Margin="0,0,16,0" />
                                        <TextBlock Text="{DynamicResource MA.Step2.Meta.Fps}" Margin="0,0,4,0" />
                                        <TextBlock Text="{DynamicResource MA.Common.NotAvailable}" Foreground="Gray" Margin="0,0,16,0" />
                                        <TextBlock Text="{DynamicResource MA.Step2.Meta.Duration}" Margin="0,0,4,0" />
                                        <TextBlock Text="{DynamicResource MA.Common.NotAvailable}" Foreground="Gray" />
                                    </StackPanel>

                                    <!-- 按钮 -->
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="{DynamicResource MA.Step2.SelectFile}"
                                                Command="{Binding SelectFrontVideoCommand}"
                                                Style="{StaticResource MaterialDesignRaisedButton}"
                                                Margin="0,0,8,0" />
                                        <Button Content="{DynamicResource Clear}"
                                                Command="{Binding ClearFrontVideoCommand}"
                                                Style="{StaticResource MaterialDesignOutlinedButton}" />
                                    </StackPanel>
                                </StackPanel>
                            </materialDesign:Card>

                            <!-- 侧面视频卡片 -->
                            <materialDesign:Card Grid.Column="2" Padding="16">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource MA.Step2.SideVideo}"
                                               Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                                               Margin="0,0,0,12" />

                                    <!-- 视频路径 -->
                                    <TextBox Text="{Binding SideVideoPath, Mode=OneWay}"
                                             IsReadOnly="True"
                                             materialDesign:HintAssist.Hint="{DynamicResource MA.Step2.SideVideo}"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             Margin="0,0,0,12" />

                                    <!-- 元信息（占位） -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <TextBlock Text="{DynamicResource MA.Step2.Meta.Resolution}" Margin="0,0,4,0" />
                                        <TextBlock Text="{DynamicResource MA.Common.NotAvailable}" Foreground="Gray" Margin="0,0,16,0" />
                                        <TextBlock Text="{DynamicResource MA.Step2.Meta.Fps}" Margin="0,0,4,0" />
                                        <TextBlock Text="{DynamicResource MA.Common.NotAvailable}" Foreground="Gray" Margin="0,0,16,0" />
                                        <TextBlock Text="{DynamicResource MA.Step2.Meta.Duration}" Margin="0,0,4,0" />
                                        <TextBlock Text="{DynamicResource MA.Common.NotAvailable}" Foreground="Gray" />
                                    </StackPanel>

                                    <!-- 按钮 -->
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="{DynamicResource MA.Step2.SelectFile}"
                                                Command="{Binding SelectSideVideoCommand}"
                                                Style="{StaticResource MaterialDesignRaisedButton}"
                                                Margin="0,0,8,0" />
                                        <Button Content="{DynamicResource Clear}"
                                                Command="{Binding ClearSideVideoCommand}"
                                                Style="{StaticResource MaterialDesignOutlinedButton}" />
                                    </StackPanel>
                                </StackPanel>
                            </materialDesign:Card>
                        </Grid>

                        <!-- 导入策略卡片 -->
                        <materialDesign:Card Margin="0,16,0,0" Padding="16">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource MA.Step2.ImportStrategy}"
                                           Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                                           Margin="0,0,0,12" />

                                <StackPanel>
                                    <RadioButton Content="{DynamicResource MA.Step2.Strategy.Copy}"
                                                 IsChecked="{Binding SelectedImportStrategy, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static common:ImportStrategy.CopyToFolder}}"
                                                 GroupName="ImportStrategy"
                                                 Margin="0,0,0,8" />
                                    <RadioButton Content="{DynamicResource MA.Step2.Strategy.Reference}"
                                                 IsChecked="{Binding SelectedImportStrategy, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static common:ImportStrategy.ReferenceOnly}}"
                                                 GroupName="ImportStrategy" />
                                </StackPanel>
                            </StackPanel>
                        </materialDesign:Card>

                        <!-- 同步检查卡片（占位） -->
                        <materialDesign:Card Margin="0,16,0,0" Padding="16">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource MA.Step2.SyncCheck}"
                                           Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                                           Margin="0,0,0,12" />

                                <TextBlock Text="{DynamicResource MA.Common.NotAvailable}" 
                                           Foreground="Gray" />
                            </StackPanel>
                        </materialDesign:Card>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Tab2: 实时采集 -->
            <TabItem Header="{DynamicResource MA.Step2.Tab.Capture}">
                <Grid Margin="0,16,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- 顶部配置栏 -->
                    <materialDesign:Card Grid.Row="0" Padding="16" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="32" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- 画面布局 -->
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{DynamicResource MA.Step2.Capture.LayoutLabel}"
                                           Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                                           Margin="0,0,0,8" />
                                <StackPanel Orientation="Horizontal">
                                    <RadioButton Content="{DynamicResource MA.Step2.Capture.Layout.Single}"
                                                 IsChecked="{Binding SelectedCaptureLayout, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static common:CaptureLayout.Single}}"
                                                 GroupName="CaptureLayout"
                                                 Style="{StaticResource MaterialDesignChoiceChipOutlineRadioButton}"
                                                 Margin="0,0,8,0" />
                                    <RadioButton Content="{DynamicResource MA.Step2.Capture.Layout.Dual}"
                                                 IsChecked="{Binding SelectedCaptureLayout, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static common:CaptureLayout.Dual}}"
                                                 GroupName="CaptureLayout"
                                                 Style="{StaticResource MaterialDesignChoiceChipOutlineRadioButton}" />
                                </StackPanel>
                            </StackPanel>

                            <!-- 录制时长 -->
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{DynamicResource MA.Step2.Capture.DurationLabel}"
                                           Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                                           Margin="0,0,0,8" />
                                <StackPanel Orientation="Horizontal">
                                    <RadioButton Content="{DynamicResource MA.Step2.Capture.Duration.30s}"
                                                 IsChecked="{Binding SelectedRecordDuration, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static common:RecordDuration.Seconds30}}"
                                                 GroupName="RecordDuration"
                                                 Style="{StaticResource MaterialDesignChoiceChipOutlineRadioButton}"
                                                 Margin="0,0,8,0" />
                                    <RadioButton Content="{DynamicResource MA.Step2.Capture.Duration.60s}"
                                                 IsChecked="{Binding SelectedRecordDuration, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static common:RecordDuration.Seconds60}}"
                                                 GroupName="RecordDuration"
                                                 Style="{StaticResource MaterialDesignChoiceChipOutlineRadioButton}" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </materialDesign:Card>

                    <!-- 中间相机画面区域 -->
                    <Grid Grid.Row="1">
                        <!-- 双视频模式 -->
                        <Grid Visibility="{Binding IsDualCapture, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- 正面相机 -->
                            <Border Grid.Column="0" Background="#1A1A1A" CornerRadius="8" 
                                    BorderBrush="#333" BorderThickness="1">
                                <Grid>
                                    <!-- 相机标签 -->
                                    <Border Background="#80000000" CornerRadius="4" Padding="8,4" 
                                            HorizontalAlignment="Left" VerticalAlignment="Top" Margin="8">
                                        <TextBlock Text="{DynamicResource MA.Step2.FrontVideo}" 
                                                   Foreground="White" FontSize="12" />
                                    </Border>
                                    <!-- 占位图标 -->
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <materialDesign:PackIcon Kind="Videocam" Width="48" Height="48" 
                                                                  Foreground="#555" HorizontalAlignment="Center" />
                                        <TextBlock Text="{DynamicResource MA.Step2.Capture.CameraPreview}" 
                                                   Foreground="#555" FontSize="12" HorizontalAlignment="Center" Margin="0,8,0,0" />
                                    </StackPanel>
                                    <!-- 录制中红点指示 -->
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" 
                                                Margin="8"
                                                Visibility="{Binding IsCapturing, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <Ellipse Width="10" Height="10" Fill="#F44336" Margin="0,0,6,0" VerticalAlignment="Center" />
                                        <TextBlock Text="REC" Foreground="#F44336" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- 侧面相机 -->
                            <Border Grid.Column="2" Background="#1A1A1A" CornerRadius="8" 
                                    BorderBrush="#333" BorderThickness="1">
                                <Grid>
                                    <Border Background="#80000000" CornerRadius="4" Padding="8,4" 
                                            HorizontalAlignment="Left" VerticalAlignment="Top" Margin="8">
                                        <TextBlock Text="{DynamicResource MA.Step2.SideVideo}" 
                                                   Foreground="White" FontSize="12" />
                                    </Border>
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <materialDesign:PackIcon Kind="Videocam" Width="48" Height="48" 
                                                                  Foreground="#555" HorizontalAlignment="Center" />
                                        <TextBlock Text="{DynamicResource MA.Step2.Capture.CameraPreview}" 
                                                   Foreground="#555" FontSize="12" HorizontalAlignment="Center" Margin="0,8,0,0" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" 
                                                Margin="8"
                                                Visibility="{Binding IsCapturing, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <Ellipse Width="10" Height="10" Fill="#F44336" Margin="0,0,6,0" VerticalAlignment="Center" />
                                        <TextBlock Text="REC" Foreground="#F44336" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- 单视频模式 -->
                        <Border Visibility="{Binding IsDualCapture, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                                Background="#1A1A1A" CornerRadius="8" 
                                BorderBrush="#333" BorderThickness="1">
                            <Grid>
                                <Border Background="#80000000" CornerRadius="4" Padding="8,4" 
                                        HorizontalAlignment="Left" VerticalAlignment="Top" Margin="12">
                                    <TextBlock Text="{DynamicResource MA.Step2.FrontVideo}" 
                                               Foreground="White" FontSize="13" />
                                </Border>
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <materialDesign:PackIcon Kind="Videocam" Width="64" Height="64" 
                                                              Foreground="#555" HorizontalAlignment="Center" />
                                    <TextBlock Text="{DynamicResource MA.Step2.Capture.CameraPreview}" 
                                               Foreground="#555" FontSize="14" HorizontalAlignment="Center" Margin="0,8,0,0" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" 
                                            Margin="12"
                                            Visibility="{Binding IsCapturing, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Ellipse Width="12" Height="12" Fill="#F44336" Margin="0,0,6,0" VerticalAlignment="Center" />
                                    <TextBlock Text="REC" Foreground="#F44336" FontSize="13" FontWeight="Bold" VerticalAlignment="Center" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- 底部录制控制区 -->
                    <materialDesign:Card Grid.Row="2" Padding="16" Margin="0,12,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- 进度条 -->
                            <Grid Grid.Row="0" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding RecordingElapsedDisplay}" 
                                           FontFamily="Consolas" FontSize="13" VerticalAlignment="Center" Margin="0,0,12,0" />
                                <ProgressBar Grid.Column="1" Value="{Binding RecordingProgressPercent, Mode=OneWay}"
                                             Maximum="100" Height="6" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2" Text="{Binding RecordingCountdownDisplay}" 
                                           FontFamily="Consolas" FontSize="13" VerticalAlignment="Center" Margin="12,0,0,0" />
                            </Grid>

                            <!-- 控制按钮区 -->
                            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center">

                                <!-- 待机状态：开始录制 -->
                                <Button Command="{Binding StartRecordingCommand}"
                                        Style="{StaticResource MaterialDesignRaisedButton}"
                                        Background="#4CAF50"
                                        Margin="0,0,8,0"
                                        Visibility="{Binding IsCaptureIdle, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="RadioboxMarked" Width="18" Height="18" 
                                                                  VerticalAlignment="Center" Margin="0,0,6,0" />
                                        <TextBlock Text="{DynamicResource MA.Step2.Capture.StartRecord}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>

                                <!-- 录制中：停止录制 -->
                                <Button Command="{Binding StopRecordingCommand}"
                                        Style="{StaticResource MaterialDesignRaisedButton}"
                                        Background="#F44336"
                                        Margin="0,0,8,0"
                                        Visibility="{Binding IsCapturing, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Stop" Width="18" Height="18" 
                                                                  VerticalAlignment="Center" Margin="0,0,6,0" />
                                        <TextBlock Text="{DynamicResource MA.Step2.Capture.StopRecord}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>

                                <!-- 录制中：倒计时状态标签 -->
                                <Border Margin="8,0,0,0" Padding="12,4" CornerRadius="4"
                                        Background="#FFEBEE"
                                        Visibility="{Binding IsCapturing, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="8" Height="8" Fill="#F44336" VerticalAlignment="Center" Margin="0,0,6,0" />
                                        <TextBlock Foreground="#D32F2F" FontSize="12" VerticalAlignment="Center">
                                            <Run Text="{DynamicResource MA.Step2.Capture.Recording}" />
                                            <Run Text=" " />
                                            <Run Text="{Binding RecordingCountdownDisplay, Mode=OneWay}" FontFamily="Consolas" FontWeight="Bold" />
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <!-- 完成状态：确认 + 重录 -->
                                <Button Command="{Binding ConfirmCaptureCommand}"
                                        Style="{StaticResource MaterialDesignRaisedButton}"
                                        Margin="0,0,8,0"
                                        Visibility="{Binding IsCaptureCompleted, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Check" Width="18" Height="18" 
                                                                  VerticalAlignment="Center" Margin="0,0,6,0" />
                                        <TextBlock Text="{DynamicResource MA.Step2.Capture.Confirm}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding RetakeCaptureCommand}"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                        Visibility="{Binding IsCaptureCompleted, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Refresh" Width="18" Height="18" 
                                                                  VerticalAlignment="Center" Margin="0,0,6,0" />
                                        <TextBlock Text="{DynamicResource MA.Step2.Capture.Retake}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>

                                <!-- 完成状态：绿勾提示 -->
                                <Border Margin="12,0,0,0" Padding="12,4" CornerRadius="4"
                                        Background="#E8F5E9"
                                        Visibility="{Binding IsCaptureCompleted, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="CheckCircle" Width="16" Height="16" 
                                                                  Foreground="#4CAF50" VerticalAlignment="Center" Margin="0,0,6,0" />
                                        <TextBlock Foreground="#2E7D32" FontSize="12" VerticalAlignment="Center">
                                            <Run Text="{DynamicResource MA.Step2.Capture.Completed}" />
                                            <Run Text=" " />
                                            <Run Text="{Binding RecordingElapsedDisplay, Mode=OneWay}" FontFamily="Consolas" />
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </materialDesign:Card>
                </Grid>
            </TabItem>

        </TabControl>

        <!-- 底部操作栏 -->
        <Border Grid.Row="2" Padding="0,16,0,0">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button Content="{DynamicResource Back}"
                            Command="{Binding PreviousStepCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="{DynamicResource MA.Step2.ImportConfirm}"
                            Command="{Binding ConfirmImportCommand}"
                            IsEnabled="{Binding HasAnyVideo}"
                            Style="{StaticResource MaterialDesignRaisedButton}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
