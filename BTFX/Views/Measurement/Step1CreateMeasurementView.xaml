<UserControl x:Class="BTFX.Views.Measurement.Step1CreateMeasurementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:BTFX.ViewModels.Measurement"
             xmlns:common="clr-namespace:BTFX.Common"
             xmlns:converters="clr-namespace:BTFX.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:MeasurementViewModel}"
             d:DesignHeight="720"
             d:DesignWidth="1180">

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVisConverter" />
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVisConverter" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="新建测量"
                           Style="{StaticResource MaterialDesignHeadline5TextBlock}" />
                <TextBlock Text="创建步态分析任务，选择分析模式并准备符合要求的视频。"
                           Margin="0,4,0,0"
                           Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}" />
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.05*" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="0.95*" />
                    </Grid.ColumnDefinitions>

                    <materialDesign:Card Grid.Column="0" Padding="18">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.ColumnSpan="3"
                                       Text="测量信息"
                                       Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                                       Margin="0,0,0,12" />

                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,10">
                                <TextBlock Text="测量名称" Margin="0,0,0,4" />
                                <TextBox Text="{Binding MeasurementName, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}" />
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,10">
                                <TextBlock Text="测量类型" Margin="0,0,0,4" />
                                <ComboBox SelectedValue="{Binding SelectedMeasurementType}"
                                          SelectedValuePath="Tag"
                                          Style="{StaticResource MaterialDesignOutlinedComboBox}">
                                    <ComboBoxItem Content="自然步行" Tag="{x:Static common:MeasurementType.NormalWalk}" />
                                    <ComboBoxItem Content="快走" Tag="{x:Static common:MeasurementType.FastWalk}" />
                                    <ComboBoxItem Content="慢走" Tag="{x:Static common:MeasurementType.SlowWalk}" />
                                    <ComboBoxItem Content="其他" Tag="{x:Static common:MeasurementType.Other}" />
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="0">
                                <TextBlock Text="步道长度（m）" Margin="0,0,0,4" />
                                <TextBox Text="{Binding WalkwayLength, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}" />
                                <TextBlock Text="{Binding WalkwayLengthError}"
                                           Foreground="#D32F2F"
                                           Margin="0,4,0,0"
                                           Visibility="{Binding WalkwayLengthError, Converter={StaticResource NullableToVisibilityConverter}}" />
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="2">
                                <TextBlock Text="备注" Margin="0,0,0,4" />
                                <TextBox Text="{Binding Remark, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         MinHeight="56"
                                         MaxHeight="72"
                                         VerticalScrollBarVisibility="Auto"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}" />
                            </StackPanel>
                        </Grid>
                    </materialDesign:Card>

                    <materialDesign:Card Grid.Column="2" Padding="18">
                        <StackPanel>
                            <TextBlock Text="分析模式"
                                       Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                                       Margin="0,0,0,12" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <RadioButton Grid.Column="0"
                                             GroupName="AnalysisMode"
                                             IsChecked="{Binding SelectedAnalysisMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static vm:AnalysisVideoMode.Single}}">
                                    <RadioButton.Template>
                                        <ControlTemplate TargetType="RadioButton">
                                            <Border Padding="14"
                                                    CornerRadius="8"
                                                    BorderThickness="1"
                                                    Background="#F8FAFC">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="BorderBrush" Value="#DDE4EB" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSingleVideoMode}" Value="True">
                                                                <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesign.Brush.Primary}" />
                                                                <Setter Property="Background" Value="#F2F0FA" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel>
                                                    <TextBlock Text="单视频模式" FontWeight="SemiBold" />
                                                    <TextBlock Text="仅导入侧面视频"
                                                               Margin="0,6,0,0"
                                                               FontSize="12"
                                                               Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>
                                        </ControlTemplate>
                                    </RadioButton.Template>
                                </RadioButton>

                                <RadioButton Grid.Column="2"
                                             GroupName="AnalysisMode"
                                             IsChecked="{Binding SelectedAnalysisMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static vm:AnalysisVideoMode.Dual}}">
                                    <RadioButton.Template>
                                        <ControlTemplate TargetType="RadioButton">
                                            <Border Padding="14"
                                                    CornerRadius="8"
                                                    BorderThickness="1"
                                                    Background="#F8FAFC">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="BorderBrush" Value="#DDE4EB" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsDualVideoMode}" Value="True">
                                                                <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesign.Brush.Primary}" />
                                                                <Setter Property="Background" Value="#F2F0FA" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel>
                                                    <TextBlock Text="双视频模式" FontWeight="SemiBold" />
                                                    <TextBlock Text="侧面和正面视频都必选"
                                                               Margin="0,6,0,0"
                                                               FontSize="12"
                                                               Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>
                                        </ControlTemplate>
                                    </RadioButton.Template>
                                </RadioButton>
                            </Grid>
                        </StackPanel>
                    </materialDesign:Card>
                </Grid>

                <materialDesign:Card Margin="0,14,0,0" Padding="18">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="14" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <StackPanel>
                                <TextBlock Text="视频来源"
                                           Style="{StaticResource MaterialDesignSubtitle1TextBlock}" />
                                <TextBlock Text="视频规格将在选择文件或采集完成后自动读取并校验。"
                                           Margin="0,4,0,0"
                                           Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}" />
                            </StackPanel>

                            <Button HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Background="#403B5B"
                                    Foreground="White"
                                    Command="{Binding OpenCameraRecordingDialogCommand}"
                                    Style="{StaticResource MaterialDesignRaisedButton}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Video"
                                                             Width="18"
                                                             Height="18"
                                                             Margin="0,0,6,0" />
                                    <TextBlock Text="打开视频采集" />
                                </StackPanel>
                            </Button>
                        </Grid>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Padding="14"
                                    Background="#F8FAFC"
                                    CornerRadius="8"
                                    BorderBrush="#E1E6EC"
                                    BorderThickness="1">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0" Margin="0,0,0,10">
                                        <TextBlock Text="侧面视频" FontWeight="SemiBold" />
                                        <Border HorizontalAlignment="Right"
                                                Padding="8,2"
                                                CornerRadius="4">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#ECEFF3" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SideVideoInfo.Status}" Value="{x:Static vm:VideoValidationStatus.Passed}">
                                                            <Setter Property="Background" Value="#E8F5E9" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding SideVideoInfo.Status}" Value="{x:Static vm:VideoValidationStatus.Failed}">
                                                            <Setter Property="Background" Value="#FFEBEE" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding SideVideoInfo.StatusDisplay}" FontSize="12" />
                                        </Border>
                                    </Grid>

                                    <TextBox Grid.Row="1"
                                             Text="{Binding SideVideoInfo.FilePath, Mode=OneWay}"
                                             IsReadOnly="True"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             Margin="0,0,0,10" />

                                    <UniformGrid Grid.Row="2" Columns="3" Margin="0,0,0,10">
                                        <TextBlock Text="{Binding SideVideoInfo.FileName, StringFormat=文件：{0}}" FontSize="12" TextTrimming="CharacterEllipsis" Margin="0,0,8,4" />
                                        <TextBlock Text="{Binding SideVideoInfo.Resolution, StringFormat=分辨率：{0}}" FontSize="12" Margin="0,0,8,4" />
                                        <TextBlock Text="{Binding SideVideoInfo.FrameRateDisplay, StringFormat=帧率：{0}}" FontSize="12" Margin="0,0,8,4" />
                                        <TextBlock Text="{Binding SideVideoInfo.DurationDisplay, StringFormat=时长：{0}}" FontSize="12" Margin="0,0,8,0" />
                                        <TextBlock Text="{Binding SideVideoInfo.FileSizeDisplay, StringFormat=大小：{0}}" FontSize="12" Margin="0,0,8,0" />
                                        <TextBlock Text="{Binding SideVideoInfo.ValidationMessage}" FontSize="12" TextTrimming="CharacterEllipsis" />
                                    </UniformGrid>

                                    <StackPanel Grid.Row="3" Orientation="Horizontal">
                                        <Button Content="选择文件"
                                                Command="{Binding SelectSideVideoCommand}"
                                                Style="{StaticResource MaterialDesignRaisedButton}"
                                                Margin="0,0,8,0" />
                                        <Button Content="预览"
                                                Command="{Binding PreviewSideVideoCommand}"
                                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                                Margin="0,0,8,0" />
                                        <Button Content="清除"
                                                Command="{Binding ClearSideVideoCommand}"
                                                Style="{StaticResource MaterialDesignOutlinedButton}" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Grid.Column="2"
                                    Padding="14"
                                    Background="#F8FAFC"
                                    CornerRadius="8"
                                    BorderBrush="#E1E6EC"
                                    BorderThickness="1"
                                    Visibility="{Binding IsDualVideoMode, Converter={StaticResource BoolToVisConverter}}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0" Margin="0,0,0,10">
                                        <TextBlock Text="正面视频" FontWeight="SemiBold" />
                                        <Border HorizontalAlignment="Right"
                                                Padding="8,2"
                                                CornerRadius="4">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#ECEFF3" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding FrontVideoInfo.Status}" Value="{x:Static vm:VideoValidationStatus.Passed}">
                                                            <Setter Property="Background" Value="#E8F5E9" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding FrontVideoInfo.Status}" Value="{x:Static vm:VideoValidationStatus.Failed}">
                                                            <Setter Property="Background" Value="#FFEBEE" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding FrontVideoInfo.StatusDisplay}" FontSize="12" />
                                        </Border>
                                    </Grid>

                                    <TextBox Grid.Row="1"
                                             Text="{Binding FrontVideoInfo.FilePath, Mode=OneWay}"
                                             IsReadOnly="True"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             Margin="0,0,0,10" />

                                    <UniformGrid Grid.Row="2" Columns="3" Margin="0,0,0,10">
                                        <TextBlock Text="{Binding FrontVideoInfo.FileName, StringFormat=文件：{0}}" FontSize="12" TextTrimming="CharacterEllipsis" Margin="0,0,8,4" />
                                        <TextBlock Text="{Binding FrontVideoInfo.Resolution, StringFormat=分辨率：{0}}" FontSize="12" Margin="0,0,8,4" />
                                        <TextBlock Text="{Binding FrontVideoInfo.FrameRateDisplay, StringFormat=帧率：{0}}" FontSize="12" Margin="0,0,8,4" />
                                        <TextBlock Text="{Binding FrontVideoInfo.DurationDisplay, StringFormat=时长：{0}}" FontSize="12" Margin="0,0,8,0" />
                                        <TextBlock Text="{Binding FrontVideoInfo.FileSizeDisplay, StringFormat=大小：{0}}" FontSize="12" Margin="0,0,8,0" />
                                        <TextBlock Text="{Binding FrontVideoInfo.ValidationMessage}" FontSize="12" TextTrimming="CharacterEllipsis" />
                                    </UniformGrid>

                                    <StackPanel Grid.Row="3" Orientation="Horizontal">
                                        <Button Content="选择文件"
                                                Command="{Binding SelectFrontVideoCommand}"
                                                Style="{StaticResource MaterialDesignRaisedButton}"
                                                Margin="0,0,8,0" />
                                        <Button Content="预览"
                                                Command="{Binding PreviewFrontVideoCommand}"
                                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                                Margin="0,0,8,0" />
                                        <Button Content="清除"
                                                Command="{Binding ClearFrontVideoCommand}"
                                                Style="{StaticResource MaterialDesignOutlinedButton}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>

                        <Border Grid.Row="4"
                                Padding="12,8"
                                CornerRadius="6"
                                Background="#FFF8E1"
                                Visibility="{Binding HasReviewWarning, Converter={StaticResource BoolToVisConverter}}">
                            <TextBlock Text="{Binding VideoConsistencyMessage}"
                                       Foreground="#8A5A00"
                                       TextWrapping="Wrap" />
                        </Border>
                    </Grid>
                </materialDesign:Card>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Padding="0,14,0,0">
            <Grid>
                <Button Content="返回封面"
                        HorizontalAlignment="Left"
                        Command="{Binding GoToStepCommand}"
                        CommandParameter="0"
                        Style="{StaticResource MaterialDesignOutlinedButton}" />

                <StackPanel HorizontalAlignment="Right">
                    <TextBlock Text="{Binding EntryFailureReason}"
                               Foreground="#D32F2F"
                               HorizontalAlignment="Right"
                               Margin="0,0,0,6"
                               Visibility="{Binding CanEnterReview, Converter={StaticResource InverseBoolToVisConverter}}" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="重置"
                                Command="{Binding ResetMeasurementCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Margin="0,0,12,0" />
                        <Button Content="进入回放检查"
                                Command="{Binding ConfirmImportCommand}"
                                IsEnabled="{Binding CanEnterReview}"
                                Background="#403B5B"
                                Foreground="White"
                                Style="{StaticResource MaterialDesignRaisedButton}" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
