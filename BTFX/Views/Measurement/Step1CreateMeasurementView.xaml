<UserControl
    x:Class="BTFX.Views.Measurement.Step1CreateMeasurementView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:common="clr-namespace:BTFX.Common"
    xmlns:converters="clr-namespace:BTFX.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:BTFX.ViewModels.Measurement"
    d:DataContext="{d:DesignInstance Type=vm:MeasurementViewModel}"
    d:DesignHeight="720"
    d:DesignWidth="1180"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVisConverter" />
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVisConverter" />

        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FAFAFA" />
            <Setter Property="BorderBrush" Value="#FFF1ECEF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="20,18" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="Height" Value="33" />
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="FontSize" Value="24" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="Foreground" Value="#403B5B" />
            <Setter Property="LineHeight" Value="33" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,12,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Foreground" Value="#666666" />
        </Style>

        <Style x:Key="RoundedInputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="48" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#D8D8D8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Foreground" Value="#403B5B" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border
                            x:Name="InputBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="16">
                            <ScrollViewer
                                x:Name="PART_ContentHost"
                                Margin="0"
                                VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="InputBorder" Property="BorderBrush" Value="#403B5B" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FilterComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Foreground" Value="#555555" />
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#D1D1D1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Height" Value="48" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="SnapsToDevicePixels" Value="True" />
                        <Setter Property="OverridesDefaultStyle" Value="True" />
                        <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
                        <Setter Property="FontSize" Value="18" />
                        <Setter Property="Foreground" Value="#555555" />
                        <Setter Property="HorizontalContentAlignment" Value="Left" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border
                                        x:Name="ItemBorder"
                                        Padding="18,12"
                                        Background="Transparent"
                                        CornerRadius="10">
                                        <ContentPresenter VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Background" Value="#F0F4F9" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Background" Value="#EEF2F7" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid
                            Width="{TemplateBinding Width}"
                            Height="{TemplateBinding Height}"
                            SnapsToDevicePixels="True">
                            <ToggleButton
                                x:Name="ToggleButton"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                VerticalContentAlignment="Stretch"
                                ClickMode="Press"
                                Cursor="Hand"
                                Focusable="False"
                                IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                OverridesDefaultStyle="True">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border
                                            x:Name="OuterBorder"
                                            Background="{Binding Background, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                            BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                            BorderThickness="{Binding BorderThickness, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                            CornerRadius="16"
                                            SnapsToDevicePixels="True">
                                            <Path
                                                Width="12"
                                                Height="7"
                                                Margin="0,0,18,0"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Data="M0,0 L6,6 L12,0"
                                                Fill="Transparent"
                                                Stroke="#999999"
                                                StrokeThickness="1.5" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#B0B0B0" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter
                                Margin="18,0,40,0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Content="{TemplateBinding SelectionBoxItem}"
                                ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                IsHitTestVisible="False" />
                            <Popup
                                AllowsTransparency="True"
                                Focusable="False"
                                IsOpen="{TemplateBinding IsDropDownOpen}"
                                Placement="Bottom"
                                PopupAnimation="Fade">
                                <Border
                                    Width="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                    Margin="0,6,0,0"
                                    Padding="8"
                                    Background="White"
                                    BorderBrush="#E2E2E2"
                                    BorderThickness="1"
                                    CornerRadius="16">
                                    <ScrollViewer MaxHeight="260" CanContentScroll="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="48" />
            <Setter Property="MinWidth" Value="132" />
            <Setter Property="Padding" Value="22,0" />
            <Setter Property="Background" Value="#403B5B" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="ButtonBorder"
                            Background="{TemplateBinding Background}"
                            CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.92" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.82" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="48" />
            <Setter Property="MinWidth" Value="112" />
            <Setter Property="Padding" Value="20,0" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="#403B5B" />
            <Setter Property="BorderBrush" Value="#403B5B" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="ButtonBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#F7F6FB" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.82" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionButtonTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="VideoInfoTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Foreground" Value="#555555" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource SectionCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="18" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Border
                        Width="4"
                        Height="16"
                        Margin="0,0,12,0"
                        VerticalAlignment="Center"
                        Background="#E4004A"
                        CornerRadius="8" />
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="测量信息" />
                </StackPanel>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.35*" />
                        <ColumnDefinition Width="15" />
                        <ColumnDefinition Width="0.95*" />
                        <ColumnDefinition Width="15" />
                        <ColumnDefinition Width="0.95*" />
                        <ColumnDefinition Width="15" />
                        <ColumnDefinition Width="1.45*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="测量名称" />
                        <TextBox
                            MinWidth="280"
                            Style="{StaticResource RoundedInputTextBoxStyle}"
                            Text="{Binding MeasurementName, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="测量类型" />
                        <ComboBox
                            Width="150"
                            SelectedValue="{Binding SelectedMeasurementType}"
                            SelectedValuePath="Tag"
                            Style="{StaticResource FilterComboBoxStyle}">
                            <ComboBoxItem Content="自然步行" Tag="{x:Static common:MeasurementType.NormalWalk}" />
                            <ComboBoxItem Content="快走" Tag="{x:Static common:MeasurementType.FastWalk}" />
                            <ComboBoxItem Content="慢走" Tag="{x:Static common:MeasurementType.SlowWalk}" />
                            <ComboBoxItem Content="其他" Tag="{x:Static common:MeasurementType.Other}" />
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="4" Orientation="Horizontal">
                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="分析模式" />
                        <ComboBox
                            Width="150"
                            SelectedValue="{Binding SelectedAnalysisMode}"
                            SelectedValuePath="Tag"
                            Style="{StaticResource FilterComboBoxStyle}">
                            <ComboBoxItem Content="单视频模式" Tag="{x:Static vm:AnalysisVideoMode.Single}" />
                            <ComboBoxItem Content="双视频模式" Tag="{x:Static vm:AnalysisVideoMode.Dual}" />
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="6" Orientation="Horizontal">
                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="备注" />
                        <TextBox
                            MinWidth="440"
                            Style="{StaticResource RoundedInputTextBoxStyle}"
                            Text="{Binding Remark, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource SectionCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="18" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <StackPanel Orientation="Horizontal">
                        <Border
                            Width="4"
                            Height="16"
                            Margin="0,0,12,0"
                            VerticalAlignment="Center"
                            Background="#E4004A"
                            CornerRadius="8" />
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="视频来源" />
                    </StackPanel>

                    <Button
                        Width="200"
                        HorizontalAlignment="Right"
                        Command="{Binding OpenCameraRecordingDialogCommand}"
                        Style="{StaticResource PrimaryActionButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon
                                Width="20"
                                Height="20"
                                Margin="0,0,8,0"
                                VerticalAlignment="Center"
                                Kind="Video" />
                            <TextBlock Style="{StaticResource ActionButtonTextStyle}" Text="打开视频采集" />
                        </StackPanel>
                    </Button>
                </Grid>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="18" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border
                        Grid.Column="0"
                        Padding="40,20,20,20"
                        Background="#FFFFFF"
                        BorderBrush="#E1E6EC"
                        BorderThickness="1"
                        CornerRadius="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="300" />
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="80" />
                            </Grid.ColumnDefinitions>

                            <Border
                                Grid.Column="0"
                                Width="300"
                                Height="300"
                                Background="#111111"
                                ClipToBounds="True"
                                CornerRadius="8">
                                <Grid>
                                    <Image
                                        Width="300"
                                        Height="300"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Source="{Binding SideVideoInfo.PreviewImage}"
                                        Stretch="Uniform"
                                        Visibility="{Binding SideVideoInfo.HasFile, Converter={StaticResource BoolToVisConverter}}" />
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontFamily="{StaticResource AppFont}"
                                        FontSize="22"
                                        Foreground="#DDDDDD"
                                        Text="未选择"
                                        Visibility="{Binding SideVideoInfo.HasFile, Converter={StaticResource InverseBoolToVisConverter}}" />
                                    <Button
                                        Width="56"
                                        Height="56"
                                        MinWidth="56"
                                        Padding="0"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Background="#AA403B5B"
                                        BorderThickness="0"
                                        Command="{Binding PreviewSideVideoCommand}"
                                        Style="{StaticResource PrimaryActionButtonStyle}"
                                        Visibility="{Binding SideVideoInfo.HasFile, Converter={StaticResource BoolToVisConverter}}">
                                        <materialDesign:PackIcon
                                            Width="28"
                                            Height="28"
                                            Foreground="White"
                                            Kind="Play" />
                                    </Button>
                                </Grid>
                            </Border>

                            <Grid Grid.Column="2" VerticalAlignment="Center">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="50" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <TextBlock
                                        FontFamily="{StaticResource AppFont}"
                                        FontSize="22"
                                        FontWeight="Medium"
                                        Foreground="#403B5B"
                                        Text="侧面视频" />
                                    <Border
                                        Padding="10,4"
                                        HorizontalAlignment="Right"
                                        CornerRadius="8">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#ECEFF3" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SideVideoInfo.Status}" Value="{x:Static vm:VideoValidationStatus.Passed}">
                                                        <Setter Property="Background" Value="#E8F5E9" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding SideVideoInfo.Status}" Value="{x:Static vm:VideoValidationStatus.Failed}">
                                                        <Setter Property="Background" Value="#FFEBEE" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock
                                            FontFamily="{StaticResource AppFont}"
                                            FontSize="14"
                                            Text="{Binding SideVideoInfo.StatusDisplay}" />
                                    </Border>
                                </Grid>

                                <StackPanel Grid.Row="2">
                                    <TextBlock
                                        Margin="0,0,0,12"
                                        Style="{StaticResource VideoInfoTextStyle}"
                                        Text="{Binding SideVideoInfo.Resolution, StringFormat=分辨率：{0}}" />
                                    <TextBlock
                                        Margin="0,0,0,12"
                                        Style="{StaticResource VideoInfoTextStyle}"
                                        Text="{Binding SideVideoInfo.FrameRateDisplay, StringFormat=帧率：{0}}" />
                                    <TextBlock
                                        Margin="0,0,0,12"
                                        Style="{StaticResource VideoInfoTextStyle}"
                                        Text="{Binding SideVideoInfo.DurationDisplay, StringFormat=时长：{0}}" />
                                    <TextBlock
                                        Margin="0,0,0,26"
                                        Style="{StaticResource VideoInfoTextStyle}"
                                        Text="{Binding SideVideoInfo.FileSizeDisplay, StringFormat=大小：{0}}" />
                                    <Grid>
                                        <Button
                                            HorizontalAlignment="Left"
                                            Command="{Binding SelectSideVideoCommand}"
                                            Style="{StaticResource PrimaryActionButtonStyle}">
                                            <TextBlock Style="{StaticResource ActionButtonTextStyle}" Text="选择文件" />
                                        </Button>
                                        <Button
                                            HorizontalAlignment="Right"
                                            Command="{Binding ClearSideVideoCommand}"
                                            Style="{StaticResource SecondaryActionButtonStyle}">
                                            <TextBlock Style="{StaticResource ActionButtonTextStyle}" Text="清除" />
                                        </Button>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border
                        Grid.Column="2"
                        Padding="40,20,20,20"
                        Background="#FFFFFF"
                        BorderBrush="#E1E6EC"
                        BorderThickness="1"
                        CornerRadius="8"
                        IsEnabled="{Binding IsDualVideoMode}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Opacity" Value="1" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDualVideoMode}" Value="False">
                                        <Setter Property="Opacity" Value="0.45" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="300" />
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="80" />
                            </Grid.ColumnDefinitions>

                            <Border
                                Grid.Column="0"
                                Width="300"
                                Height="300"
                                Background="#111111"
                                ClipToBounds="True"
                                CornerRadius="8">
                                <Grid>
                                    <Image
                                        Width="300"
                                        Height="300"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Source="{Binding FrontVideoInfo.PreviewImage}"
                                        Stretch="Uniform"
                                        Visibility="{Binding FrontVideoInfo.HasFile, Converter={StaticResource BoolToVisConverter}}" />
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontFamily="{StaticResource AppFont}"
                                        FontSize="22"
                                        Foreground="#DDDDDD"
                                        Text="未选择"
                                        Visibility="{Binding FrontVideoInfo.HasFile, Converter={StaticResource InverseBoolToVisConverter}}" />
                                    <Button
                                        Width="56"
                                        Height="56"
                                        MinWidth="56"
                                        Padding="0"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Background="#AA403B5B"
                                        BorderThickness="0"
                                        Command="{Binding PreviewFrontVideoCommand}"
                                        Style="{StaticResource PrimaryActionButtonStyle}"
                                        Visibility="{Binding FrontVideoInfo.HasFile, Converter={StaticResource BoolToVisConverter}}">
                                        <materialDesign:PackIcon
                                            Width="28"
                                            Height="28"
                                            Foreground="White"
                                            Kind="Play" />
                                    </Button>
                                </Grid>
                            </Border>

                            <Grid Grid.Column="2" VerticalAlignment="Center">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="50" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <TextBlock
                                        FontFamily="{StaticResource AppFont}"
                                        FontSize="22"
                                        FontWeight="Medium"
                                        Foreground="#403B5B"
                                        Text="正面视频" />
                                    <Border
                                        Padding="10,4"
                                        HorizontalAlignment="Right"
                                        CornerRadius="8">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#ECEFF3" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding FrontVideoInfo.Status}" Value="{x:Static vm:VideoValidationStatus.Passed}">
                                                        <Setter Property="Background" Value="#E8F5E9" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding FrontVideoInfo.Status}" Value="{x:Static vm:VideoValidationStatus.Failed}">
                                                        <Setter Property="Background" Value="#FFEBEE" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock
                                            FontFamily="{StaticResource AppFont}"
                                            FontSize="14"
                                            Text="{Binding FrontVideoInfo.StatusDisplay}" />
                                    </Border>
                                </Grid>

                                <StackPanel Grid.Row="2">
                                    <TextBlock
                                        Margin="0,0,0,12"
                                        Style="{StaticResource VideoInfoTextStyle}"
                                        Text="{Binding FrontVideoInfo.Resolution, StringFormat=分辨率：{0}}" />
                                    <TextBlock
                                        Margin="0,0,0,12"
                                        Style="{StaticResource VideoInfoTextStyle}"
                                        Text="{Binding FrontVideoInfo.FrameRateDisplay, StringFormat=帧率：{0}}" />
                                    <TextBlock
                                        Margin="0,0,0,12"
                                        Style="{StaticResource VideoInfoTextStyle}"
                                        Text="{Binding FrontVideoInfo.DurationDisplay, StringFormat=时长：{0}}" />
                                    <TextBlock
                                        Margin="0,0,0,26"
                                        Style="{StaticResource VideoInfoTextStyle}"
                                        Text="{Binding FrontVideoInfo.FileSizeDisplay, StringFormat=大小：{0}}" />
                                    <Grid>
                                        <Button
                                            HorizontalAlignment="Left"
                                            Command="{Binding SelectFrontVideoCommand}"
                                            Style="{StaticResource PrimaryActionButtonStyle}">
                                            <TextBlock Style="{StaticResource ActionButtonTextStyle}" Text="选择文件" />
                                        </Button>
                                        <Button
                                            HorizontalAlignment="Right"
                                            Command="{Binding ClearFrontVideoCommand}"
                                            Style="{StaticResource SecondaryActionButtonStyle}">
                                            <TextBlock Style="{StaticResource ActionButtonTextStyle}" Text="清除" />
                                        </Button>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>

                <Border
                    Grid.Row="3"
                    Margin="0,12,0,0"
                    Padding="12,8"
                    Background="#FFF8E1"
                    CornerRadius="6"
                    Visibility="{Binding HasReviewWarning, Converter={StaticResource BoolToVisConverter}}">
                    <TextBlock
                        Foreground="#8A5A00"
                        Text="{Binding VideoConsistencyMessage}"
                        TextWrapping="Wrap" />
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="4">
            <Button
                HorizontalAlignment="Left"
                Command="{Binding GoToStepCommand}"
                CommandParameter="0"
                Style="{StaticResource SecondaryActionButtonStyle}">
                <TextBlock Style="{StaticResource ActionButtonTextStyle}" Text="返回封面" />
            </Button>

            <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                <Button
                    Margin="0,0,14,0"
                    Command="{Binding ResetMeasurementCommand}"
                    Style="{StaticResource SecondaryActionButtonStyle}">
                    <TextBlock Style="{StaticResource ActionButtonTextStyle}" Text="重置" />
                </Button>
                <Button
                    Width="180"
                    Command="{Binding ConfirmImportCommand}"
                    IsEnabled="{Binding CanEnterReview}"
                    Style="{StaticResource PrimaryActionButtonStyle}">
                    <TextBlock Style="{StaticResource ActionButtonTextStyle}" Text="进入回放检查" />
                </Button>
            </StackPanel>

            <TextBlock
                MaxWidth="420"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                FontSize="12"
                Foreground="#D32F2F"
                Text="{Binding EntryFailureReason}"
                TextTrimming="CharacterEllipsis"
                Visibility="{Binding CanEnterReview, Converter={StaticResource InverseBoolToVisConverter}}" />
        </Grid>
    </Grid>
</UserControl>
