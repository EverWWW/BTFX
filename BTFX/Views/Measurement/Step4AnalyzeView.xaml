<UserControl x:Class="BTFX.Views.Measurement.Step4AnalyzeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:BTFX.Views.Measurement"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:BTFX.ViewModels.Measurement"
             xmlns:oxy="http://oxyplot.org/wpf"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:Step4AnalyzeViewModel}"
             d:DesignHeight="700" d:DesignWidth="900">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ==================== 顶部工具栏 ==================== -->
        <Border Grid.Row="0" Padding="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- 状态标题区 -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <!-- Ready 标题 -->
                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding AnalysisState, Converter={StaticResource AnalysisStateToVisibilityConverter}, ConverterParameter=Ready}">
                        <materialDesign:PackIcon Kind="PlayCircleOutline" Width="24" Height="24" VerticalAlignment="Center" Margin="0,0,8,0"
                                                 Foreground="{DynamicResource MaterialDesign.Brush.Primary}" />
                        <TextBlock Text="{DynamicResource MA.Step4.ReadyTitle}"
                                   Style="{StaticResource MaterialDesignHeadline6TextBlock}" VerticalAlignment="Center" />
                    </StackPanel>
                    <!-- Running 标题 -->
                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding AnalysisState, Converter={StaticResource AnalysisStateToVisibilityConverter}, ConverterParameter=Running}">
                        <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                     IsIndeterminate="True" Width="20" Height="20" Margin="0,0,8,0" />
                        <TextBlock Text="{DynamicResource MA.Step4.RunningTitle}"
                                   Style="{StaticResource MaterialDesignHeadline6TextBlock}" VerticalAlignment="Center" />
                    </StackPanel>
                    <!-- Previewing 标题 -->
                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding AnalysisState, Converter={StaticResource AnalysisStateToVisibilityConverter}, ConverterParameter=Previewing}">
                        <materialDesign:PackIcon Kind="CheckCircle" Foreground="#4CAF50" Width="24" Height="24" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="{DynamicResource MA.Step4.CompletedTitle}"
                                   Style="{StaticResource MaterialDesignHeadline6TextBlock}" VerticalAlignment="Center" />
                        <TextBlock Margin="16,0,0,0" VerticalAlignment="Center" Foreground="Gray">
                            <Run Text="{DynamicResource MA.Step4.Duration}" /><Run Text=": " />
                            <Run Text="{Binding AnalysisDurationDisplay, Mode=OneWay}" />
                        </TextBlock>
                    </StackPanel>
                    <!-- Failed 标题 -->
                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding AnalysisState, Converter={StaticResource AnalysisStateToVisibilityConverter}, ConverterParameter=Failed}">
                        <materialDesign:PackIcon Kind="CloseCircle" Foreground="#F44336" Width="24" Height="24" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="{DynamicResource MA.Step4.FailedTitle}"
                                   Style="{StaticResource MaterialDesignHeadline6TextBlock}" Foreground="#F44336" VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>

                <!-- 操作按钮组 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Ready: 开始分析 -->
                    <Button Content="{DynamicResource MA.Step4.Btn.StartAnalyze}"
                            Command="{Binding StartAnalyzeCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Margin="0,0,8,0"
                            Visibility="{Binding AnalysisState, Converter={StaticResource AnalysisStateToVisibilityConverter}, ConverterParameter=Ready}" />
                    <!-- Running: 取消分析 -->
                    <Button Content="{DynamicResource MA.Step4.Btn.CancelAnalyze}"
                            Command="{Binding CancelAnalyzeCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Margin="0,0,8,0"
                            Visibility="{Binding AnalysisState, Converter={StaticResource AnalysisStateToVisibilityConverter}, ConverterParameter=Running}" />
                    <!-- Previewing: 重新分析 / 参数概览|视频预览 / 查看报告 -->
                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding AnalysisState, Converter={StaticResource AnalysisStateToVisibilityConverter}, ConverterParameter=Previewing}">
                        <Button Content="{DynamicResource MA.Step4.Btn.RetryAnalyze}"
                                Command="{Binding RetryAnalyzeCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Margin="0,0,8,0" />
                        <Button Command="{Binding ToggleParamsViewCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Margin="0,0,8,0">
                            <Button.Content>
                                <TextBlock>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{DynamicResource MA.Step4.Btn.ParamsOverview}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsShowingParams}" Value="True">
                                                    <Setter Property="Text" Value="{DynamicResource MA.Step4.Btn.VideoPreview}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Button.Content>
                        </Button>
                        <Button Content="{DynamicResource MA.Step4.Btn.ViewReport}"
                                Command="{Binding ViewReportCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}" />
                    </StackPanel>
                    <!-- Failed: 重试 / 返回步骤2 / 查看日志 -->
                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding AnalysisState, Converter={StaticResource AnalysisStateToVisibilityConverter}, ConverterParameter=Failed}">
                        <Button Content="{DynamicResource MA.Step4.Btn.RetryAnalyze}"
                                Command="{Binding RetryAnalyzeCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Margin="0,0,8,0" />
                        <Button Content="{DynamicResource MA.Step4.Btn.GoToStep2}"
                                Command="{Binding GoToStep2Command}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Margin="0,0,8,0" />
                        <Button Content="{DynamicResource MA.Step4.Btn.ViewLog}"
                                Command="{Binding ViewLogCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ==================== 主内容区（状态驱动切换） ==================== -->
        <Grid Grid.Row="1">

            <!-- ====== 状态 A：待分析 (Ready) ====== -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding AnalysisState, Converter={StaticResource AnalysisStateToVisibilityConverter}, ConverterParameter=Ready}">
                <StackPanel MaxWidth="560" HorizontalAlignment="Center" Margin="0,24,0,24">

                    <!-- 描述文字 -->
                    <TextBlock Text="{DynamicResource MA.Step4.ReadyDesc}"
                               Foreground="Gray" HorizontalAlignment="Center" Margin="0,0,0,24" />

                    <!-- 前置条件检查清单 -->
                    <ItemsControl ItemsSource="{Binding PrerequisiteItems}" Margin="0,0,0,24">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <materialDesign:PackIcon Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,8,0"
                                                             Kind="{Binding IsMet, Converter={StaticResource PrerequisiteStatusToIconConverter}}"
                                                             Foreground="{Binding IsMet, Converter={StaticResource PrerequisiteStatusToColorConverter}}" />
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontSize="14" />
                                    <TextBlock Text=" *" Foreground="#F44336" VerticalAlignment="Center" FontSize="14"
                                               Visibility="{Binding IsRequired, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- 分析选项 -->
                    <TextBlock Text="{DynamicResource MA.Step4.Options.Title}"
                               Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                               Margin="0,0,0,12" />
                    <CheckBox Content="{DynamicResource MA.Step4.Options.GaitEvents}"
                              IsChecked="{Binding CalculateGaitEvents}" Margin="0,4" />
                    <CheckBox Content="{DynamicResource MA.Step4.Options.Kinematics}"
                              IsChecked="{Binding CalculateKinematics}" Margin="0,4" />
                    <CheckBox Content="{DynamicResource MA.Step4.Options.ExportCsv}"
                              IsChecked="{Binding ExportCsv}" Margin="0,4" />
                    <CheckBox Content="{DynamicResource MA.Step4.Options.SmoothCurve}"
                              IsChecked="{Binding SmoothCurve}" Margin="0,4" />
                </StackPanel>
            </ScrollViewer>

            <!-- ====== 状态 B：分析中 (Running) ====== -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding AnalysisState, Converter={StaticResource AnalysisStateToVisibilityConverter}, ConverterParameter=Running}">
                <StackPanel MaxWidth="520" HorizontalAlignment="Center" Margin="0,48,0,24">

                    <!-- 进度条 -->
                    <ProgressBar Value="{Binding Progress}" Height="10" Margin="0,0,0,12" />
                    <TextBlock HorizontalAlignment="Right" Foreground="Gray" Margin="0,0,0,24">
                        <Run Text="{Binding Progress, Mode=OneWay, StringFormat={}{0}%}" />
                    </TextBlock>

                    <!-- 进度详情 -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource MA.Step4.CurrentStage}" Foreground="Gray" />
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding CurrentStage}" FontWeight="Medium" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource MA.Step4.ElapsedTime}" Foreground="Gray" />
                        <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding ElapsedTimeDisplay}" FontWeight="Medium" />

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="{DynamicResource MA.Step4.StatusMessage}" Foreground="Gray" />
                        <TextBlock Grid.Row="4" Grid.Column="2" Text="{Binding StatusMessage}" TextWrapping="Wrap" />
                    </Grid>

                    <!-- 阶段进度指示 -->
                    <materialDesign:Card Padding="16" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource MA.Step4.StageProgress}"
                                       Style="{StaticResource MaterialDesignSubtitle2TextBlock}" Margin="0,0,0,8" />
                            <TextBlock FontFamily="Consolas" FontSize="13" Margin="0,2">
                                <Run Text="{Binding Progress, Converter={StaticResource ProgressToStageStatusConverter}, ConverterParameter=0, Mode=OneWay}" />
                                <Run Text="  初始化" />
                            </TextBlock>
                            <TextBlock FontFamily="Consolas" FontSize="13" Margin="0,2">
                                <Run Text="{Binding Progress, Converter={StaticResource ProgressToStageStatusConverter}, ConverterParameter=10, Mode=OneWay}" />
                                <Run Text="  检测关键点" />
                            </TextBlock>
                            <TextBlock FontFamily="Consolas" FontSize="13" Margin="0,2">
                                <Run Text="{Binding Progress, Converter={StaticResource ProgressToStageStatusConverter}, ConverterParameter=35, Mode=OneWay}" />
                                <Run Text="  检测步态事件" />
                            </TextBlock>
                            <TextBlock FontFamily="Consolas" FontSize="13" Margin="0,2">
                                <Run Text="{Binding Progress, Converter={StaticResource ProgressToStageStatusConverter}, ConverterParameter=60, Mode=OneWay}" />
                                <Run Text="  计算步态参数" />
                            </TextBlock>
                            <TextBlock FontFamily="Consolas" FontSize="13" Margin="0,2">
                                <Run Text="{Binding Progress, Converter={StaticResource ProgressToStageStatusConverter}, ConverterParameter=80, Mode=OneWay}" />
                                <Run Text="  输出结果" />
                            </TextBlock>
                        </StackPanel>
                    </materialDesign:Card>
                </StackPanel>
            </ScrollViewer>

            <!-- ====== 状态 C：预览 (Previewing) ====== -->
            <Grid Visibility="{Binding AnalysisState, Converter={StaticResource AnalysisStateToVisibilityConverter}, ConverterParameter=Previewing}">

                <!-- C-1: 视频预览子视图（IsShowingParams=False） -->
                <Grid Visibility="{Binding IsShowingParams, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverse}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="280" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" MinWidth="320" />
                    </Grid.ColumnDefinitions>

                    <!-- 左列：标注视频 -->
                    <Grid Grid.Column="0">
                        <Border Background="#1E1E1E" CornerRadius="4">
                            <MediaElement x:Name="AnnotatedVideoPlayer"
                                           Source="{Binding AnnotatedVideoPath}"
                                           LoadedBehavior="Manual"
                                           UnloadedBehavior="Stop"
                                           Stretch="Uniform"
                                           MediaOpened="AnnotatedVideoPlayer_MediaOpened"
                                           MediaEnded="AnnotatedVideoPlayer_MediaEnded"
                                           MediaFailed="AnnotatedVideoPlayer_MediaFailed" />
                        </Border>
                        <!-- 视频错误降级覆盖层 -->
                        <Border Background="#1E1E1E" CornerRadius="4"
                                Visibility="{Binding HasVideoError, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="VideoOffOutline" Width="48" Height="48"
                                                         HorizontalAlignment="Center" Foreground="#757575" Margin="0,0,0,12" />
                                <TextBlock Text="{Binding VideoErrorMessage}" Foreground="#BDBDBD"
                                           TextAlignment="Center" TextWrapping="Wrap" FontSize="13" MaxWidth="240" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- 右列：控制 + 进度条 + 曲线图 -->
                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- 播放控制区 -->
                        <StackPanel Grid.Row="0" Margin="0,0,0,8">
                            <!-- 按钮行 -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                                <Button Command="{Binding StepBackwardCommand}"
                                        Style="{StaticResource MaterialDesignIconButton}"
                                        ToolTip="-1s" Margin="0,0,4,0">
                                    <materialDesign:PackIcon Kind="Rewind" />
                                </Button>
                                <Button Command="{Binding PlayPauseCommand}"
                                        Style="{StaticResource MaterialDesignIconButton}" Margin="0,0,4,0">
                                    <materialDesign:PackIcon>
                                        <materialDesign:PackIcon.Style>
                                            <Style TargetType="materialDesign:PackIcon">
                                                <Setter Property="Kind" Value="Play" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                                        <Setter Property="Kind" Value="Pause" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </materialDesign:PackIcon.Style>
                                    </materialDesign:PackIcon>
                                </Button>
                                <Button Command="{Binding StepForwardCommand}"
                                        Style="{StaticResource MaterialDesignIconButton}"
                                        ToolTip="+1s">
                                    <materialDesign:PackIcon Kind="FastForward" />
                                </Button>
                            </StackPanel>

                            <!-- 播放速度 -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,4">
                                <TextBlock Text="{DynamicResource MA.Step4.Video.PlaybackSpeed}"
                                           VerticalAlignment="Center" Foreground="Gray" FontSize="12" Margin="0,0,8,0" />
                                <RadioButton Content="0.25x" GroupName="Speed" Margin="2,0"
                                             IsChecked="{Binding IsSpeed025x, Mode=OneWay}"
                                             Command="{Binding SetPlaybackSpeedCommand}" CommandParameter="0.25" />
                                <RadioButton Content="0.5x" GroupName="Speed" Margin="2,0"
                                             IsChecked="{Binding IsSpeed05x, Mode=OneWay}"
                                             Command="{Binding SetPlaybackSpeedCommand}" CommandParameter="0.5" />
                                <RadioButton Content="1x" GroupName="Speed" Margin="2,0"
                                             IsChecked="{Binding IsSpeed1x, Mode=OneWay}"
                                             Command="{Binding SetPlaybackSpeedCommand}" CommandParameter="1.0" />
                                <RadioButton Content="1.5x" GroupName="Speed" Margin="2,0"
                                             IsChecked="{Binding IsSpeed15x, Mode=OneWay}"
                                             Command="{Binding SetPlaybackSpeedCommand}" CommandParameter="1.5" />
                                <RadioButton Content="2x" GroupName="Speed" Margin="2,0"
                                             IsChecked="{Binding IsSpeed2x, Mode=OneWay}"
                                             Command="{Binding SetPlaybackSpeedCommand}" CommandParameter="2.0" />
                            </StackPanel>
                        </StackPanel>

                        <!-- 时间 + 进度条 -->
                        <StackPanel Grid.Row="1" Margin="0,0,0,8">
                            <TextBlock Text="{Binding CurrentTimeDisplay}" HorizontalAlignment="Center"
                                       FontSize="12" Foreground="Gray" Margin="0,0,0,4" />
                            <Slider x:Name="VideoSlider"
                                    Minimum="0"
                                    Maximum="{Binding VideoDurationSeconds}"
                                    Value="{Binding VideoCurrentTimeSeconds}"
                                    Thumb.DragStarted="VideoSlider_DragStarted"
                                    Thumb.DragCompleted="VideoSlider_DragCompleted"
                                    IsMoveToPointEnabled="True"
                                    SmallChange="0.1" LargeChange="1" />
                        </StackPanel>

                        <!-- 曲线图标题 -->
                        <TextBlock Grid.Row="2" Text="{DynamicResource MA.Step4.Chart.Title}" FontSize="12" Foreground="Gray" Margin="0,0,0,4" />

                        <!-- 曲线图区域 -->
                        <Grid Grid.Row="3">
                            <!-- 有数据时：曲线图纵向堆叠 -->
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          Visibility="{Binding HasChartData, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel>
                                    <oxy:PlotView Model="{Binding HipAnglePlotModel}" Height="100" Margin="0,0,0,4"
                                                  Visibility="{Binding HipAnglePlotModel, Converter={StaticResource NullableToVisibilityConverter}}"
                                                  MouseDown="PlotView_MouseDown" />
                                    <oxy:PlotView Model="{Binding KneeAnglePlotModel}" Height="100" Margin="0,0,0,4"
                                                  Visibility="{Binding KneeAnglePlotModel, Converter={StaticResource NullableToVisibilityConverter}}"
                                                  MouseDown="PlotView_MouseDown" />
                                    <oxy:PlotView Model="{Binding AnkleAnglePlotModel}" Height="100" Margin="0,0,0,4"
                                                  Visibility="{Binding AnkleAnglePlotModel, Converter={StaticResource NullableToVisibilityConverter}}"
                                                  MouseDown="PlotView_MouseDown" />
                                    <oxy:PlotView Model="{Binding PelvisAnglePlotModel}" Height="100"
                                                  Visibility="{Binding PelvisAnglePlotModel, Converter={StaticResource NullableToVisibilityConverter}}"
                                                  MouseDown="PlotView_MouseDown" />
                                </StackPanel>
                            </ScrollViewer>
                            <!-- 无数据时：降级提示 -->
                            <Border Background="#F5F5F5" CornerRadius="4"
                                    Visibility="{Binding HasChartData, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverse}">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,32">
                                    <materialDesign:PackIcon Kind="ChartLineVariant" Width="36" Height="36"
                                                             HorizontalAlignment="Center" Foreground="#BDBDBD" Margin="0,0,0,8" />
                                    <TextBlock Text="{DynamicResource MA.Step4.Chart.Unavailable}" Foreground="#9E9E9E"
                                               TextAlignment="Center" FontSize="13" />
                                    <TextBlock Text="{DynamicResource MA.Step4.Chart.UnavailableHint}" Foreground="#BDBDBD"
                                               TextAlignment="Center" FontSize="11" Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>

                <!-- C-2: 参数概览子视图（IsShowingParams=True） -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Visibility="{Binding IsShowingParams, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel Margin="0,0,0,16">

                        <!-- 步态事件参数 -->
                        <materialDesign:Card Padding="16" Margin="0,0,0,12"
                                             Visibility="{Binding GaitEventResult, Converter={StaticResource NullableToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource MA.Step4.Param.GaitEvents}"
                                           Style="{StaticResource MaterialDesignSubtitle1TextBlock}" Margin="0,0,0,12" />
                                <UniformGrid Columns="4" Rows="2">
                                    <StackPanel Margin="4">
                                        <TextBlock Text="{DynamicResource MA.Step4.Param.GaitCycleDuration}" Foreground="Gray" FontSize="12" />
                                        <TextBlock Text="{Binding GaitEventResult.GaitCycleDuration}" FontSize="16" FontWeight="Medium" />
                                    </StackPanel>
                                    <StackPanel Margin="4">
                                        <TextBlock Text="{DynamicResource MA.Step4.Param.StanceTime}" Foreground="Gray" FontSize="12" />
                                        <TextBlock Text="{Binding GaitEventResult.StanceTime}" FontSize="16" FontWeight="Medium" />
                                    </StackPanel>
                                    <StackPanel Margin="4">
                                        <TextBlock Text="{DynamicResource MA.Step4.Param.SwingTime}" Foreground="Gray" FontSize="12" />
                                        <TextBlock Text="{Binding GaitEventResult.SwingTime}" FontSize="16" FontWeight="Medium" />
                                    </StackPanel>
                                    <StackPanel Margin="4">
                                        <TextBlock Text="{DynamicResource MA.Step4.Param.DoubleSupportTime}" Foreground="Gray" FontSize="12" />
                                        <TextBlock Text="{Binding GaitEventResult.DoubleSupportTime}" FontSize="16" FontWeight="Medium" />
                                    </StackPanel>
                                    <StackPanel Margin="4">
                                        <TextBlock Text="{DynamicResource MA.Step4.Param.SingleSupportTime}" Foreground="Gray" FontSize="12" />
                                        <TextBlock Text="{Binding GaitEventResult.SingleSupportTime}" FontSize="16" FontWeight="Medium" />
                                    </StackPanel>
                                    <StackPanel Margin="4">
                                        <TextBlock Text="{DynamicResource MA.Step4.Param.StepLength}" Foreground="Gray" FontSize="12" />
                                        <TextBlock Text="{Binding GaitEventResult.StepLength}" FontSize="16" FontWeight="Medium" />
                                    </StackPanel>
                                    <StackPanel Margin="4">
                                        <TextBlock Text="{DynamicResource MA.Step4.Param.StrideLength}" Foreground="Gray" FontSize="12" />
                                        <TextBlock Text="{Binding GaitEventResult.StrideLength}" FontSize="16" FontWeight="Medium" />
                                    </StackPanel>
                                    <StackPanel Margin="4">
                                        <TextBlock Text="{DynamicResource MA.Step4.Param.GaitSpeed}" Foreground="Gray" FontSize="12" />
                                        <TextBlock Text="{Binding GaitEventResult.GaitSpeed}" FontSize="16" FontWeight="Medium" />
                                    </StackPanel>
                                </UniformGrid>
                            </StackPanel>
                        </materialDesign:Card>

                        <!-- 运动学参数 -->
                        <materialDesign:Card Padding="16" Margin="0,0,0,12"
                                             Visibility="{Binding KinematicResult, Converter={StaticResource NullableToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource MA.Step4.Param.Kinematics}"
                                           Style="{StaticResource MaterialDesignSubtitle1TextBlock}" Margin="0,0,0,12" />
                                <UniformGrid Columns="4">
                                    <StackPanel Margin="4">
                                        <TextBlock Text="{DynamicResource MA.Step4.Param.HipRom}" Foreground="Gray" FontSize="12" />
                                        <TextBlock Text="{Binding KinematicResult.HipRom}" FontSize="16" FontWeight="Medium" />
                                    </StackPanel>
                                    <StackPanel Margin="4">
                                        <TextBlock Text="{DynamicResource MA.Step4.Param.KneeRom}" Foreground="Gray" FontSize="12" />
                                        <TextBlock Text="{Binding KinematicResult.KneeRom}" FontSize="16" FontWeight="Medium" />
                                    </StackPanel>
                                    <StackPanel Margin="4">
                                        <TextBlock Text="{DynamicResource MA.Step4.Param.AnkleRom}" Foreground="Gray" FontSize="12" />
                                        <TextBlock Text="{Binding KinematicResult.AnkleRom}" FontSize="16" FontWeight="Medium" />
                                    </StackPanel>
                                    <StackPanel Margin="4">
                                        <TextBlock Text="{DynamicResource MA.Step4.Param.PelvisRom}" Foreground="Gray" FontSize="12" />
                                        <TextBlock Text="{Binding KinematicResult.PelvisRom}" FontSize="16" FontWeight="Medium" />
                                    </StackPanel>
                                </UniformGrid>
                            </StackPanel>
                        </materialDesign:Card>

                        <!-- 质量评估 -->
                        <materialDesign:Card Padding="16"
                                             Visibility="{Binding QualityResult, Converter={StaticResource NullableToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource MA.Step4.Quality.Title}"
                                           Style="{StaticResource MaterialDesignSubtitle1TextBlock}" Margin="0,0,0,12" />

                                <!-- 综合等级 -->
                                <Border CornerRadius="4" Padding="12,8" Margin="0,0,0,12"
                                        Background="{Binding QualityResult.GradeColor, FallbackValue=#F5F5F5}">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock FontSize="20" FontWeight="Bold" Foreground="White"
                                                   VerticalAlignment="Center" Margin="0,0,12,0"
                                                   Text="{Binding QualityResult.GradeDisplay, FallbackValue=--}" />
                                        <TextBlock FontSize="13" Foreground="White"
                                                   VerticalAlignment="Center"
                                                   Text="{Binding QualityResult.GradeDescription}" />
                                    </StackPanel>
                                </Border>

                                <UniformGrid Columns="4">
                                    <StackPanel Margin="4">
                                        <TextBlock Text="{DynamicResource MA.Step4.Quality.Confidence}" Foreground="Gray" FontSize="12" />
                                        <TextBlock FontSize="16" FontWeight="Medium">
                                            <Run Text="{Binding QualityResult.ConfidenceDisplay, Mode=OneWay}" />
                                            <Run Text="{Binding QualityResult.ConfidenceOk, Converter={StaticResource QualityBoolToStatusConverter}, Mode=OneWay}" />
                                        </TextBlock>
                                    </StackPanel>
                                    <StackPanel Margin="4">
                                        <TextBlock Text="{DynamicResource MA.Step4.Quality.ValidFrameRatio}" Foreground="Gray" FontSize="12" />
                                        <TextBlock FontSize="16" FontWeight="Medium">
                                            <Run Text="{Binding QualityResult.ValidFrameRatioDisplay, Mode=OneWay}" />
                                            <Run Text="{Binding QualityResult.ValidFrameRatioOk, Converter={StaticResource QualityBoolToStatusConverter}, Mode=OneWay}" />
                                        </TextBlock>
                                    </StackPanel>
                                    <StackPanel Margin="4">
                                        <TextBlock Text="{DynamicResource MA.Step4.Quality.Occlusion}" Foreground="Gray" FontSize="12" />
                                        <TextBlock FontSize="16" FontWeight="Medium"
                                                   Text="{Binding QualityResult.HasOcclusion, Converter={StaticResource BooleanToValueConverter}, ConverterParameter=⚠️|✅}" />
                                    </StackPanel>
                                    <StackPanel Margin="4">
                                        <TextBlock Text="{DynamicResource MA.Step4.Quality.MissingPoints}" Foreground="Gray" FontSize="12" />
                                        <TextBlock FontSize="16" FontWeight="Medium"
                                                   Text="{Binding QualityResult.HasMissingPoints, Converter={StaticResource BooleanToValueConverter}, ConverterParameter=⚠️|✅}" />
                                    </StackPanel>
                                </UniformGrid>
                            </StackPanel>
                        </materialDesign:Card>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- ====== 状态 D：分析失败 (Failed) ====== -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding AnalysisState, Converter={StaticResource AnalysisStateToVisibilityConverter}, ConverterParameter=Failed}">
                <StackPanel MaxWidth="520" HorizontalAlignment="Center" Margin="0,48,0,24">

                    <materialDesign:PackIcon Kind="AlertCircleOutline" Width="64" Height="64"
                                             HorizontalAlignment="Center" Foreground="#F44336" Margin="0,0,0,16" />

                    <!-- 错误详情 -->
                    <materialDesign:Card Padding="16" Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource MA.Step4.Error.Code}" Foreground="Gray" />
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding ErrorCode}" FontWeight="Medium" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource MA.Step4.Error.Description}" Foreground="Gray" />
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding ErrorDescription}" TextWrapping="Wrap" />

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="{DynamicResource MA.Step4.Error.Suggestion}" Foreground="Gray" />
                            <TextBlock Grid.Row="4" Grid.Column="2" Text="{Binding ErrorSuggestion}" Foreground="#FF9800" TextWrapping="Wrap" />
                        </Grid>
                    </materialDesign:Card>

                    <!-- 日志面板（可展开） -->
                    <Expander IsExpanded="{Binding IsLogExpanded}"
                              Header="{DynamicResource MA.Step4.Log.Title}">
                        <ListBox ItemsSource="{Binding TaskLogs}" MaxHeight="200"
                                 FontFamily="Consolas" FontSize="11"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto" />
                    </Expander>
                </StackPanel>
            </ScrollViewer>

        </Grid>

        <!-- ==================== 底部质量评估栏（仅 Previewing 状态显示） ==================== -->
        <Border Grid.Row="2" Padding="8,8,8,4">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsPreviewing}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <!-- 综合等级标识 -->
                <Border CornerRadius="3" Padding="6,2" Margin="0,0,12,0" VerticalAlignment="Center"
                        Background="{Binding QualityResult.GradeColor, FallbackValue=#9E9E9E}">
                    <TextBlock FontSize="12" FontWeight="Bold" Foreground="White"
                               Text="{Binding QualityResult.GradeDisplay, FallbackValue=--}" />
                </Border>
                <TextBlock VerticalAlignment="Center" Foreground="Gray" FontSize="12" Margin="0,0,4,0">
                    <Run Text="📊" />
                    <Run Text="{DynamicResource MA.Step4.Quality.Title}" /><Run Text=":" />
                </TextBlock>
                <TextBlock VerticalAlignment="Center" FontSize="12" Margin="8,0">
                    <Run Text="{DynamicResource MA.Step4.Quality.Confidence}" />
                    <Run Text=" " />
                    <Run Text="{Binding QualityResult.ConfidenceDisplay, Mode=OneWay}" />
                    <Run Text="{Binding QualityResult.ConfidenceOk, Converter={StaticResource QualityBoolToStatusConverter}, Mode=OneWay}" />
                </TextBlock>
                <TextBlock VerticalAlignment="Center" FontSize="12" Margin="8,0">
                    <Run Text="{DynamicResource MA.Step4.Quality.ValidFrameRatio}" />
                    <Run Text=" " />
                    <Run Text="{Binding QualityResult.ValidFrameRatioDisplay, Mode=OneWay}" />
                    <Run Text="{Binding QualityResult.ValidFrameRatioOk, Converter={StaticResource QualityBoolToStatusConverter}, Mode=OneWay}" />
                </TextBlock>
                <TextBlock VerticalAlignment="Center" FontSize="12" Margin="8,0">
                    <Run Text="{DynamicResource MA.Step4.Quality.Occlusion}" /><Run Text=":" />
                    <Run Text="{Binding QualityResult.HasOcclusion, Converter={StaticResource BooleanToValueConverter}, ConverterParameter=⚠️|✅, Mode=OneWay}" />
                </TextBlock>
                <TextBlock VerticalAlignment="Center" FontSize="12" Margin="8,0">
                    <Run Text="{DynamicResource MA.Step4.Quality.MissingPoints}" /><Run Text=":" />
                    <Run Text="{Binding QualityResult.HasMissingPoints, Converter={StaticResource BooleanToValueConverter}, ConverterParameter=⚠️|✅, Mode=OneWay}" />
                </TextBlock>
            </StackPanel>
        </Border>

    </Grid>
</UserControl>
