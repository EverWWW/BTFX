<UserControl
    x:Class="BTFX.Views.Measurement.Step4AnalyzeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:BTFX.ViewModels.Measurement"
    d:DataContext="{d:DesignInstance Type=vm:Step4AnalyzeViewModel}"
    d:DesignHeight="700"
    d:DesignWidth="1200"
    FontFamily="{StaticResource AppFont}"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Style x:Key="AnalyzeResultCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FAFAFA" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="28" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="SectionTitleTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#2F2A4A" />
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="SummaryTileStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="18,14" />
            <Setter Property="Margin" Value="0,0,16,0" />
        </Style>

        <Style x:Key="MetricTileStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="16,12" />
            <Setter Property="Margin" Value="0,0,14,14" />
        </Style>

        <Style x:Key="MetricLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#8A8798" />
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="MetricValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#403B5B" />
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,8,0,0" />
        </Style>

        <Style x:Key="ResultSecondaryButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="118" />
            <Setter Property="Height" Value="42" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#D7D4E6" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#403B5B" />
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F4F2FA" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45" />
                    <Setter Property="Cursor" Value="Arrow" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style
            x:Key="ResultPrimaryButtonStyle"
            BasedOn="{StaticResource ResultSecondaryButtonStyle}"
            TargetType="Button">
            <Setter Property="Background" Value="#403B5B" />
            <Setter Property="BorderBrush" Value="#403B5B" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#342F4C" />
                    <Setter Property="BorderBrush" Value="#342F4C" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45" />
                    <Setter Property="Cursor" Value="Arrow" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ResultContentVisibilityStyle" TargetType="Grid">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ResultButtonRowVisibilityStyle" TargetType="Grid">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AnalysisProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="Width" Value="520" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Background" Value="#E8E6F0" />
            <Setter Property="Foreground" Value="#403B5B" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid
                            Width="{TemplateBinding Width}"
                            Height="{TemplateBinding Height}"
                            ClipToBounds="True">
                            <Border Background="{TemplateBinding Background}" CornerRadius="15" />
                            <Grid ClipToBounds="True">
                                <Border x:Name="PART_Track" />
                                <Decorator x:Name="PART_Indicator" HorizontalAlignment="Left">
                                    <Border Background="{TemplateBinding Foreground}" CornerRadius="15" />
                                </Decorator>
                            </Grid>
                            <Border
                                Width="96"
                                HorizontalAlignment="Left"
                                CornerRadius="15"
                                Opacity="0.26">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Offset="0" Color="#00FFFFFF" />
                                        <GradientStop Offset="0.5" Color="#FFFFFFFF" />
                                        <GradientStop Offset="1" Color="#00FFFFFF" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.RenderTransform>
                                    <TranslateTransform x:Name="ProgressGlowTransform" X="-120" />
                                </Border.RenderTransform>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation
                                            Storyboard.TargetName="ProgressGlowTransform"
                                            Storyboard.TargetProperty="X"
                                            From="-120"
                                            To="540"
                                            Duration="0:0:1.35" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="24" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource AnalyzeResultCardStyle}">
            <Grid>
                <Grid Visibility="{Binding IsRunning, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Border
                        Width="620"
                        Padding="42,38"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="#FFFFFF"
                        CornerRadius="8">
                        <StackPanel>
                            <StackPanel
                                Margin="0,0,0,28"
                                HorizontalAlignment="Center"
                                Orientation="Horizontal">
                                <Border
                                    Width="3"
                                    Height="18"
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center"
                                    Background="#F2306A"
                                    CornerRadius="2" />
                                <TextBlock
                                    FontSize="18"
                                    Style="{StaticResource SectionTitleTextStyle}"
                                    Text="正在分析" />
                            </StackPanel>

                            <TextBlock
                                Margin="0,0,0,18"
                                HorizontalAlignment="Center"
                                FontFamily="{StaticResource AppFont}"
                                FontSize="40"
                                FontWeight="SemiBold"
                                Foreground="#403B5B"
                                Text="{Binding Progress, StringFormat={}{0}%}" />

                            <ProgressBar
                                Margin="0,0,0,24"
                                HorizontalAlignment="Center"
                                Style="{StaticResource AnalysisProgressBarStyle}"
                                Value="{Binding Progress, Mode=OneWay}" />

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="96" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    FontFamily="{StaticResource AppFont}"
                                    FontSize="14"
                                    Foreground="#8A8798"
                                    Text="当前阶段" />
                                <TextBlock
                                    Grid.Column="1"
                                    FontFamily="{StaticResource AppFont}"
                                    FontSize="15"
                                    FontWeight="SemiBold"
                                    Foreground="#403B5B"
                                    Text="{Binding CurrentStage, Mode=OneWay}" />
                            </Grid>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="96" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    FontFamily="{StaticResource AppFont}"
                                    FontSize="14"
                                    Foreground="#8A8798"
                                    Text="分析状态" />
                                <TextBlock
                                    Grid.Column="1"
                                    FontFamily="{StaticResource AppFont}"
                                    FontSize="15"
                                    Foreground="#666666"
                                    Text="{Binding StatusMessage, Mode=OneWay}"
                                    TextWrapping="Wrap" />
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="96" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    FontFamily="{StaticResource AppFont}"
                                    FontSize="14"
                                    Foreground="#8A8798"
                                    Text="已用时间" />
                                <TextBlock
                                    Grid.Column="1"
                                    FontFamily="{StaticResource AppFont}"
                                    FontSize="15"
                                    Foreground="#666666"
                                    Text="{Binding ElapsedTimeDisplay, Mode=OneWay}" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Style="{StaticResource ResultContentVisibilityStyle}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <Border
                            Width="3"
                            Height="16"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            Background="#F2306A"
                            CornerRadius="2" />
                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="分析结果" />
                    </StackPanel>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource SummaryTileStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource MetricLabelStyle}" Text="结果状态" />
                                <TextBlock Text="{Binding ResultStatusDisplay, Mode=OneWay}">
                                    <TextBlock.Style>
                                        <Style BasedOn="{StaticResource MetricValueStyle}" TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#403B5B" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsPreviewing}" Value="True">
                                                    <Setter Property="Foreground" Value="#2E9D57" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsFailed}" Value="True">
                                                    <Setter Property="Foreground" Value="#D92D4B" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource SummaryTileStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource MetricLabelStyle}" Text="分析时长" />
                                <TextBlock Style="{StaticResource MetricValueStyle}" Text="{Binding ResultAnalysisDurationDisplay, Mode=OneWay, FallbackValue=--, TargetNullValue=--}" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource SummaryTileStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource MetricLabelStyle}" Text="任务编号" />
                                <TextBlock
                                    FontSize="17"
                                    Style="{StaticResource MetricValueStyle}"
                                    Text="{Binding ResultTaskIdDisplay, Mode=OneWay, FallbackValue=--, TargetNullValue=--}"
                                    TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Border>

                        <Border
                            Grid.Column="3"
                            Margin="0"
                            Style="{StaticResource SummaryTileStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource MetricLabelStyle}" Text="数据质量" />
                                <TextBlock Style="{StaticResource MetricValueStyle}" Text="{Binding QualityResult.GradeDisplay, Mode=OneWay, FallbackValue=--, TargetNullValue=--}" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border
                            Grid.Column="0"
                            Margin="0,0,16,0"
                            Padding="20"
                            Background="#FFFFFF"
                            CornerRadius="8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="14" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="16" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock
                                    Grid.Row="0"
                                    FontFamily="{StaticResource AppFont}"
                                    FontSize="15"
                                    FontWeight="SemiBold"
                                    Foreground="#403B5B"
                                    Text="本次分析信息" />

                                <UniformGrid Grid.Row="2" Columns="2">
                                    <Border Style="{StaticResource MetricTileStyle}">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource MetricLabelStyle}" Text="身高" />
                                            <TextBlock
                                                FontSize="18"
                                                Style="{StaticResource MetricValueStyle}"
                                                Text="{Binding PatientHeightDisplay, FallbackValue=--, TargetNullValue=--}" />
                                        </StackPanel>
                                    </Border>
                                    <Border Margin="0,0,0,14" Style="{StaticResource MetricTileStyle}">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource MetricLabelStyle}" Text="体重" />
                                            <TextBlock
                                                FontSize="18"
                                                Style="{StaticResource MetricValueStyle}"
                                                Text="{Binding PatientWeightDisplay, FallbackValue=--, TargetNullValue=--}" />
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource MetricTileStyle}">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource MetricLabelStyle}" Text="膝关节 ROM" />
                                            <TextBlock
                                                FontSize="18"
                                                Style="{StaticResource MetricValueStyle}"
                                                Text="{Binding KinematicResult.KneeRom, FallbackValue=--, TargetNullValue=--}" />
                                        </StackPanel>
                                    </Border>
                                    <Border Margin="0,0,0,14" Style="{StaticResource MetricTileStyle}">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource MetricLabelStyle}" Text="髋关节 ROM" />
                                            <TextBlock
                                                FontSize="18"
                                                Style="{StaticResource MetricValueStyle}"
                                                Text="{Binding KinematicResult.HipRom, FallbackValue=--, TargetNullValue=--}" />
                                        </StackPanel>
                                    </Border>
                                </UniformGrid>

                                <Border
                                    Grid.Row="4"
                                    Padding="14"
                                    Background="#F7F6FB"
                                    CornerRadius="8">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource MetricLabelStyle}" Text="质量提示" />
                                        <TextBlock
                                            Margin="0,8,0,0"
                                            FontFamily="{StaticResource AppFont}"
                                            FontSize="14"
                                            Foreground="#666666"
                                            Text="{Binding QualityResult.GradeDescription, FallbackValue=暂无质量提示, TargetNullValue=暂无质量提示}"
                                            TextWrapping="Wrap" />
                                        <TextBlock
                                            Margin="0,8,0,0"
                                            FontFamily="{StaticResource AppFont}"
                                            FontSize="13"
                                            Foreground="#8A8798">
                                            <Run Text="关键点置信度 " />
                                            <Run Text="{Binding QualityResult.ConfidenceDisplay, FallbackValue=--, TargetNullValue=--}" />
                                            <Run Text="，有效帧比例 " />
                                            <Run Text="{Binding QualityResult.ValidFrameRatioDisplay, FallbackValue=--, TargetNullValue=--}" />
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <Border
                            Grid.Column="1"
                            Grid.ColumnSpan="3"
                            Padding="20"
                            Background="#FFFFFF"
                            CornerRadius="8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="14" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="16" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock
                                    Grid.Row="0"
                                    FontFamily="{StaticResource AppFont}"
                                    FontSize="15"
                                    FontWeight="SemiBold"
                                    Foreground="#403B5B"
                                    Text="关键步态参数" />

                                <UniformGrid Grid.Row="2" Columns="4">
                                    <Border Style="{StaticResource MetricTileStyle}">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource MetricLabelStyle}" Text="步速" />
                                            <TextBlock Style="{StaticResource MetricValueStyle}" Text="{Binding GaitEventResult.GaitSpeed, FallbackValue=--, TargetNullValue=--}" />
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource MetricTileStyle}">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource MetricLabelStyle}" Text="步长" />
                                            <TextBlock Style="{StaticResource MetricValueStyle}" Text="{Binding GaitEventResult.StepLength, FallbackValue=--, TargetNullValue=--}" />
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource MetricTileStyle}">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource MetricLabelStyle}" Text="步幅" />
                                            <TextBlock Style="{StaticResource MetricValueStyle}" Text="{Binding GaitEventResult.StrideLength, FallbackValue=--, TargetNullValue=--}" />
                                        </StackPanel>
                                    </Border>
                                    <Border Margin="0,0,0,14" Style="{StaticResource MetricTileStyle}">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource MetricLabelStyle}" Text="步频" />
                                            <TextBlock Style="{StaticResource MetricValueStyle}" Text="{Binding ResultCadenceDisplay, FallbackValue=--, TargetNullValue=--}" />
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource MetricTileStyle}">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource MetricLabelStyle}" Text="步态周期" />
                                            <TextBlock Style="{StaticResource MetricValueStyle}" Text="{Binding GaitEventResult.GaitCycleDuration, FallbackValue=--, TargetNullValue=--}" />
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource MetricTileStyle}">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource MetricLabelStyle}" Text="站立相" />
                                            <TextBlock Style="{StaticResource MetricValueStyle}" Text="{Binding GaitEventResult.StanceTime, FallbackValue=--, TargetNullValue=--}" />
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource MetricTileStyle}">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource MetricLabelStyle}" Text="摆动相" />
                                            <TextBlock Style="{StaticResource MetricValueStyle}" Text="{Binding GaitEventResult.SwingTime, FallbackValue=--, TargetNullValue=--}" />
                                        </StackPanel>
                                    </Border>
                                    <Border Margin="0,0,0,14" Style="{StaticResource MetricTileStyle}">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource MetricLabelStyle}" Text="双支撑" />
                                            <TextBlock Style="{StaticResource MetricValueStyle}" Text="{Binding GaitEventResult.DoubleSupportTime, FallbackValue=--, TargetNullValue=--}" />
                                        </StackPanel>
                                    </Border>
                                </UniformGrid>
                            </Grid>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="5" Margin="0,18,0,0">
                        <Border
                            Padding="18"
                            VerticalAlignment="Top"
                            Background="#FFFFFF"
                            CornerRadius="8"
                            Visibility="{Binding IsRunning, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock
                                    FontFamily="{StaticResource AppFont}"
                                    FontSize="15"
                                    FontWeight="SemiBold"
                                    Foreground="#403B5B"
                                    Text="{Binding CurrentStage, Mode=OneWay}" />
                                <ProgressBar
                                    Height="8"
                                    Margin="0,12,0,8"
                                    Foreground="#403B5B"
                                    Value="{Binding Progress, Mode=OneWay}" />
                                <TextBlock
                                    FontFamily="{StaticResource AppFont}"
                                    FontSize="13"
                                    Foreground="#666666"
                                    Text="{Binding StatusMessage, Mode=OneWay}" />
                            </StackPanel>
                        </Border>

                        <Border
                            Padding="18"
                            VerticalAlignment="Top"
                            Background="#FFF4F6"
                            CornerRadius="8"
                            Visibility="{Binding IsFailed, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock
                                    FontFamily="{StaticResource AppFont}"
                                    FontSize="15"
                                    FontWeight="SemiBold"
                                    Foreground="#D92D4B"
                                    Text="{Binding ErrorDescription, FallbackValue=分析失败, TargetNullValue=分析失败}" />
                                <TextBlock
                                    Margin="0,8,0,0"
                                    FontFamily="{StaticResource AppFont}"
                                    FontSize="13"
                                    Foreground="#666666"
                                    Text="{Binding ErrorSuggestion, FallbackValue=请检查视频和配置后重新分析, TargetNullValue=请检查视频和配置后重新分析}"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Style="{StaticResource ResultButtonRowVisibilityStyle}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button
                Grid.Column="0"
                HorizontalAlignment="Left"
                Command="{Binding ReturnCoverCommand}"
                Content="返回封面"
                Style="{StaticResource ResultSecondaryButtonStyle}" />

            <StackPanel
                Grid.Column="1"
                HorizontalAlignment="Center"
                Orientation="Horizontal">
                <Button
                    Margin="0,0,12,0"
                    Command="{Binding RerunTemporaryAnalysisCommand}"
                    Content="重新分析"
                    Style="{StaticResource ResultSecondaryButtonStyle}" />
                <Button
                    Width="132"
                    Margin="0,0,12,0"
                    Command="{Binding ViewReportCommand}"
                    Content="查看分析详情"
                    Style="{StaticResource ResultPrimaryButtonStyle}" />
                <Button
                    Command="{Binding GenerateReportCommand}"
                    Content="生成报告"
                    Style="{StaticResource ResultPrimaryButtonStyle}" />
            </StackPanel>
        </Grid>

        <MediaElement
            x:Name="AnnotatedVideoPlayer"
            LoadedBehavior="Manual"
            MediaEnded="AnnotatedVideoPlayer_MediaEnded"
            MediaFailed="AnnotatedVideoPlayer_MediaFailed"
            MediaOpened="AnnotatedVideoPlayer_MediaOpened"
            Source="{Binding AnnotatedVideoPath}"
            Stretch="Uniform"
            UnloadedBehavior="Stop"
            Visibility="Collapsed" />
    </Grid>
</UserControl>
