<UserControl x:Class="BTFX.Views.Measurement.Step4AnalyzeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:BTFX.ViewModels.Measurement"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:Step4AnalyzeViewModel}"
             d:DesignHeight="700" d:DesignWidth="1200"
             FontFamily="{StaticResource AppFont}">

    <UserControl.Resources>
        <Style x:Key="AnalyzeResultCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FAFAFA" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="28" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="SectionTitleTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#2F2A4A" />
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="SummaryTileStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="18,14" />
            <Setter Property="Margin" Value="0,0,16,0" />
        </Style>

        <Style x:Key="MetricTileStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="16,12" />
            <Setter Property="Margin" Value="0,0,14,14" />
        </Style>

        <Style x:Key="MetricLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#8A8798" />
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="MetricValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#403B5B" />
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,8,0,0" />
        </Style>

        <Style x:Key="ResultSecondaryButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="118" />
            <Setter Property="Height" Value="42" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#D7D4E6" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#403B5B" />
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F4F2FA" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45" />
                    <Setter Property="Cursor" Value="Arrow" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ResultPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ResultSecondaryButtonStyle}">
            <Setter Property="Background" Value="#403B5B" />
            <Setter Property="BorderBrush" Value="#403B5B" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#342F4C" />
                    <Setter Property="BorderBrush" Value="#342F4C" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45" />
                    <Setter Property="Cursor" Value="Arrow" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ResultContentVisibilityStyle" TargetType="Grid">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ResultButtonRowVisibilityStyle" TargetType="Grid">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="24" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource AnalyzeResultCardStyle}">
            <Grid>
                <Grid Visibility="{Binding IsRunning, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Border Width="620"
                            Padding="42,38"
                            Background="#FFFFFF"
                            CornerRadius="8"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,28">
                                <Border Width="3"
                                        Height="18"
                                        Background="#F2306A"
                                        CornerRadius="2"
                                        VerticalAlignment="Center"
                                        Margin="0,0,8,0" />
                                <TextBlock Text="正在分析"
                                           Style="{StaticResource SectionTitleTextStyle}"
                                           FontSize="18" />
                            </StackPanel>

                            <TextBlock Text="{Binding Progress, StringFormat={}{0}%}"
                                       HorizontalAlignment="Center"
                                       Foreground="#403B5B"
                                       FontFamily="{StaticResource AppFont}"
                                       FontSize="40"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,18" />

                            <ProgressBar Value="{Binding Progress, Mode=OneWay}"
                                         Height="10"
                                         Foreground="#403B5B"
                                         Background="#E8E6F0"
                                         Margin="0,0,0,24" />

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="96" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="当前阶段"
                                           Foreground="#8A8798"
                                           FontFamily="{StaticResource AppFont}"
                                           FontSize="14" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding CurrentStage, Mode=OneWay}"
                                           Foreground="#403B5B"
                                           FontFamily="{StaticResource AppFont}"
                                           FontSize="15"
                                           FontWeight="SemiBold" />
                            </Grid>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="96" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="分析状态"
                                           Foreground="#8A8798"
                                           FontFamily="{StaticResource AppFont}"
                                           FontSize="14" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding StatusMessage, Mode=OneWay}"
                                           Foreground="#666666"
                                           FontFamily="{StaticResource AppFont}"
                                           FontSize="15"
                                           TextWrapping="Wrap" />
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="96" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="已用时间"
                                           Foreground="#8A8798"
                                           FontFamily="{StaticResource AppFont}"
                                           FontSize="14" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding ElapsedTimeDisplay, Mode=OneWay}"
                                           Foreground="#666666"
                                           FontFamily="{StaticResource AppFont}"
                                           FontSize="15" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Style="{StaticResource ResultContentVisibilityStyle}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="18" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="18" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal">
                    <Border Width="3"
                            Height="16"
                            Background="#F2306A"
                            CornerRadius="2"
                            VerticalAlignment="Center"
                            Margin="0,0,8,0" />
                    <TextBlock Text="分析结果" Style="{StaticResource SectionTitleTextStyle}" />
                </StackPanel>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource SummaryTileStyle}">
                        <StackPanel>
                            <TextBlock Text="结果状态" Style="{StaticResource MetricLabelStyle}" />
                            <TextBlock Text="{Binding ResultStatusDisplay, Mode=OneWay}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource MetricValueStyle}">
                                        <Setter Property="Foreground" Value="#403B5B" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPreviewing}" Value="True">
                                                <Setter Property="Foreground" Value="#2E9D57" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsFailed}" Value="True">
                                                <Setter Property="Foreground" Value="#D92D4B" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource SummaryTileStyle}">
                        <StackPanel>
                            <TextBlock Text="分析时长" Style="{StaticResource MetricLabelStyle}" />
                            <TextBlock Text="{Binding ResultAnalysisDurationDisplay, Mode=OneWay, FallbackValue=--, TargetNullValue=--}"
                                       Style="{StaticResource MetricValueStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource SummaryTileStyle}">
                        <StackPanel>
                            <TextBlock Text="任务编号" Style="{StaticResource MetricLabelStyle}" />
                            <TextBlock Text="{Binding ResultTaskIdDisplay, Mode=OneWay, FallbackValue=--, TargetNullValue=--}"
                                       Style="{StaticResource MetricValueStyle}"
                                       FontSize="17"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="3" Style="{StaticResource SummaryTileStyle}" Margin="0">
                        <StackPanel>
                            <TextBlock Text="数据质量" Style="{StaticResource MetricLabelStyle}" />
                            <TextBlock Text="{Binding QualityResult.GradeDisplay, Mode=OneWay, FallbackValue=--, TargetNullValue=--}"
                                       Style="{StaticResource MetricValueStyle}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="18" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#FFFFFF" CornerRadius="8" Padding="20">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="14" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="关键步态参数"
                                       Foreground="#403B5B"
                                       FontFamily="{StaticResource AppFont}"
                                       FontSize="15"
                                       FontWeight="SemiBold" />

                            <UniformGrid Grid.Row="2" Columns="4">
                                <Border Style="{StaticResource MetricTileStyle}">
                                    <StackPanel>
                                        <TextBlock Text="步速" Style="{StaticResource MetricLabelStyle}" />
                                        <TextBlock Text="{Binding GaitEventResult.GaitSpeed, FallbackValue=--, TargetNullValue=--}" Style="{StaticResource MetricValueStyle}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MetricTileStyle}">
                                    <StackPanel>
                                        <TextBlock Text="步长" Style="{StaticResource MetricLabelStyle}" />
                                        <TextBlock Text="{Binding GaitEventResult.StepLength, FallbackValue=--, TargetNullValue=--}" Style="{StaticResource MetricValueStyle}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MetricTileStyle}">
                                    <StackPanel>
                                        <TextBlock Text="步幅" Style="{StaticResource MetricLabelStyle}" />
                                        <TextBlock Text="{Binding GaitEventResult.StrideLength, FallbackValue=--, TargetNullValue=--}" Style="{StaticResource MetricValueStyle}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MetricTileStyle}" Margin="0,0,0,14">
                                    <StackPanel>
                                        <TextBlock Text="步频" Style="{StaticResource MetricLabelStyle}" />
                                        <TextBlock Text="{Binding ResultCadenceDisplay, FallbackValue=--, TargetNullValue=--}" Style="{StaticResource MetricValueStyle}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MetricTileStyle}">
                                    <StackPanel>
                                        <TextBlock Text="步态周期" Style="{StaticResource MetricLabelStyle}" />
                                        <TextBlock Text="{Binding GaitEventResult.GaitCycleDuration, FallbackValue=--, TargetNullValue=--}" Style="{StaticResource MetricValueStyle}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MetricTileStyle}">
                                    <StackPanel>
                                        <TextBlock Text="站立相" Style="{StaticResource MetricLabelStyle}" />
                                        <TextBlock Text="{Binding GaitEventResult.StanceTime, FallbackValue=--, TargetNullValue=--}" Style="{StaticResource MetricValueStyle}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MetricTileStyle}">
                                    <StackPanel>
                                        <TextBlock Text="摆动相" Style="{StaticResource MetricLabelStyle}" />
                                        <TextBlock Text="{Binding GaitEventResult.SwingTime, FallbackValue=--, TargetNullValue=--}" Style="{StaticResource MetricValueStyle}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MetricTileStyle}" Margin="0,0,0,14">
                                    <StackPanel>
                                        <TextBlock Text="双支撑" Style="{StaticResource MetricLabelStyle}" />
                                        <TextBlock Text="{Binding GaitEventResult.DoubleSupportTime, FallbackValue=--, TargetNullValue=--}" Style="{StaticResource MetricValueStyle}" />
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2" Background="#FFFFFF" CornerRadius="8" Padding="20">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="14" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="16" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="本次分析信息"
                                       Foreground="#403B5B"
                                       FontFamily="{StaticResource AppFont}"
                                       FontSize="15"
                                       FontWeight="SemiBold" />

                            <UniformGrid Grid.Row="2" Columns="2">
                                <Border Style="{StaticResource MetricTileStyle}">
                                    <StackPanel>
                                        <TextBlock Text="身高" Style="{StaticResource MetricLabelStyle}" />
                                        <TextBlock Text="{Binding PatientHeightDisplay, FallbackValue=--, TargetNullValue=--}" Style="{StaticResource MetricValueStyle}" FontSize="18" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MetricTileStyle}" Margin="0,0,0,14">
                                    <StackPanel>
                                        <TextBlock Text="体重" Style="{StaticResource MetricLabelStyle}" />
                                        <TextBlock Text="{Binding PatientWeightDisplay, FallbackValue=--, TargetNullValue=--}" Style="{StaticResource MetricValueStyle}" FontSize="18" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MetricTileStyle}">
                                    <StackPanel>
                                        <TextBlock Text="膝关节 ROM" Style="{StaticResource MetricLabelStyle}" />
                                        <TextBlock Text="{Binding KinematicResult.KneeRom, FallbackValue=--, TargetNullValue=--}" Style="{StaticResource MetricValueStyle}" FontSize="18" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MetricTileStyle}" Margin="0,0,0,14">
                                    <StackPanel>
                                        <TextBlock Text="髋关节 ROM" Style="{StaticResource MetricLabelStyle}" />
                                        <TextBlock Text="{Binding KinematicResult.HipRom, FallbackValue=--, TargetNullValue=--}" Style="{StaticResource MetricValueStyle}" FontSize="18" />
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <Border Grid.Row="4" Background="#F7F6FB" CornerRadius="8" Padding="14">
                                <StackPanel>
                                    <TextBlock Text="质量提示" Style="{StaticResource MetricLabelStyle}" />
                                    <TextBlock Text="{Binding QualityResult.GradeDescription, FallbackValue=暂无质量提示, TargetNullValue=暂无质量提示}"
                                               Margin="0,8,0,0"
                                               Foreground="#666666"
                                               FontFamily="{StaticResource AppFont}"
                                               FontSize="14"
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,8,0,0"
                                               Foreground="#8A8798"
                                               FontFamily="{StaticResource AppFont}"
                                               FontSize="13">
                                        <Run Text="关键点置信度 " />
                                        <Run Text="{Binding QualityResult.ConfidenceDisplay, FallbackValue=--, TargetNullValue=--}" />
                                        <Run Text="，有效帧比例 " />
                                        <Run Text="{Binding QualityResult.ValidFrameRatioDisplay, FallbackValue=--, TargetNullValue=--}" />
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>

                <Grid Grid.Row="5" Margin="0,18,0,0">
                    <Border Background="#FFFFFF"
                            CornerRadius="8"
                            Padding="18"
                            VerticalAlignment="Top"
                            Visibility="{Binding IsRunning, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="{Binding CurrentStage, Mode=OneWay}"
                                       Foreground="#403B5B"
                                       FontFamily="{StaticResource AppFont}"
                                       FontSize="15"
                                       FontWeight="SemiBold" />
                            <ProgressBar Value="{Binding Progress, Mode=OneWay}"
                                         Height="8"
                                         Margin="0,12,0,8"
                                         Foreground="#403B5B" />
                            <TextBlock Text="{Binding StatusMessage, Mode=OneWay}"
                                       Foreground="#666666"
                                       FontFamily="{StaticResource AppFont}"
                                       FontSize="13" />
                        </StackPanel>
                    </Border>

                    <Border Background="#FFF4F6"
                            CornerRadius="8"
                            Padding="18"
                            VerticalAlignment="Top"
                            Visibility="{Binding IsFailed, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="{Binding ErrorDescription, FallbackValue=分析失败, TargetNullValue=分析失败}"
                                       Foreground="#D92D4B"
                                       FontFamily="{StaticResource AppFont}"
                                       FontSize="15"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{Binding ErrorSuggestion, FallbackValue=请检查视频和配置后重新分析, TargetNullValue=请检查视频和配置后重新分析}"
                                       Margin="0,8,0,0"
                                       Foreground="#666666"
                                       FontFamily="{StaticResource AppFont}"
                                       FontSize="13"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Style="{StaticResource ResultButtonRowVisibilityStyle}">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center">
                <Button Content="重新分析"
                        Command="{Binding RerunTemporaryAnalysisCommand}"
                        Style="{StaticResource ResultSecondaryButtonStyle}"
                        Margin="0,0,12,0" />
                <Button Content="查看分析详情"
                        Command="{Binding ViewReportCommand}"
                        Style="{StaticResource ResultPrimaryButtonStyle}"
                        Width="132"
                        Margin="0,0,12,0" />
                <Button Content="生成报告"
                        Command="{Binding GenerateReportCommand}"
                        Style="{StaticResource ResultPrimaryButtonStyle}" />
            </StackPanel>
        </Grid>

        <MediaElement x:Name="AnnotatedVideoPlayer"
                      Visibility="Collapsed"
                      Source="{Binding AnnotatedVideoPath}"
                      LoadedBehavior="Manual"
                      UnloadedBehavior="Stop"
                      Stretch="Uniform"
                      MediaOpened="AnnotatedVideoPlayer_MediaOpened"
                      MediaEnded="AnnotatedVideoPlayer_MediaEnded"
                      MediaFailed="AnnotatedVideoPlayer_MediaFailed" />
    </Grid>
</UserControl>
