<UserControl
    x:Class="BTFX.Views.DataManagementView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:vm="clr-namespace:BTFX.ViewModels"
    d:DataContext="{d:DesignInstance Type=vm:DataManagementViewModel}"
    d:DesignHeight="900"
    d:DesignWidth="1920"
    Background="#F5F5F5"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Styles/SelectionStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <ControlTemplate x:Key="RoundedButtonTemplate" TargetType="Button">
                <Border
                    x:Name="ButtonBorder"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="24"
                    SnapsToDevicePixels="True">
                    <ContentPresenter
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        RecognizesAccessKey="True" />
                </Border>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.9" />
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.75" />
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45" />
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>

            <ControlTemplate x:Key="FilterIconButtonTemplate" TargetType="Button">
                <Border Background="Transparent" CornerRadius="14">
                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
            </ControlTemplate>

            <Style x:Key="HeaderTextStyle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
                <Setter Property="FontSize" Value="22" />
                <Setter Property="FontWeight" Value="Normal" />
                <Setter Property="Foreground" Value="#666666" />
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>

            <Style x:Key="RowTextStyle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
                <Setter Property="FontSize" Value="22" />
                <Setter Property="FontWeight" Value="Normal" />
                <Setter Property="Foreground" Value="#555555" />
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            </Style>

            <Style x:Key="SelectCheckBoxStyle" TargetType="CheckBox">
                <Setter Property="Focusable" Value="False" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="CheckBox">
                            <Border Padding="4" Background="Transparent">
                                <Image
                                    Width="22"
                                    Height="22"
                                    RenderOptions.BitmapScalingMode="HighQuality"
                                    Source="/Resources/Images/PatientSelectionView/xuanzekuang.png" />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsChecked" Value="True">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="CheckBox">
                                    <Border Padding="4" Background="Transparent">
                                        <Image
                                            Width="22"
                                            Height="22"
                                            RenderOptions.BitmapScalingMode="HighQuality"
                                            Source="/Resources/Images/PatientSelectionView/xuanzhongkuang.png" />
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!--  日期范围框中单个日期的样式：使用 Button + Popup + Calendar，不使用 DatePicker  -->

            <!--  状态下拉框：外层 Border 画完整圆角框，内层 Grid 分左右两列（文字 + 箭头）  -->
            <Style x:Key="FilterComboBoxStyle" TargetType="ComboBox">
                <Setter Property="Foreground" Value="#555555" />
                <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
                <Setter Property="FontSize" Value="22" />
                <Setter Property="Background" Value="#FFFFFF" />
                <Setter Property="BorderBrush" Value="#D1D1D1" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Width" Value="220" />
                <Setter Property="Height" Value="68" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
                <Setter Property="OverridesDefaultStyle" Value="True" />
                <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
                <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
                <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                <Setter Property="ItemContainerStyle">
                    <Setter.Value>
                        <Style TargetType="ComboBoxItem">
                            <Setter Property="SnapsToDevicePixels" Value="True" />
                            <Setter Property="OverridesDefaultStyle" Value="True" />
                            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
                            <Setter Property="FontSize" Value="20" />
                            <Setter Property="Foreground" Value="#555555" />
                            <Setter Property="HorizontalContentAlignment" Value="Left" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ComboBoxItem">
                                        <Border
                                            x:Name="ItemBorder"
                                            Padding="18,12"
                                            Background="Transparent"
                                            CornerRadius="10">
                                            <ContentPresenter VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsHighlighted" Value="True">
                                                <Setter TargetName="ItemBorder" Property="Background" Value="#F0F4F9" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="ItemBorder" Property="Background" Value="#EEF2F7" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Setter.Value>
                </Setter>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBox">
                            <Grid
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}"
                                SnapsToDevicePixels="True">
                                <!--  ToggleButton 铺满整个控件，既是可视外框也是点击区域  -->
                                <ToggleButton
                                    x:Name="ToggleButton"
                                    Width="{TemplateBinding Width}"
                                    Height="{TemplateBinding Height}"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    VerticalContentAlignment="Stretch"
                                    ClickMode="Press"
                                    Cursor="Hand"
                                    Focusable="False"
                                    IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                    OverridesDefaultStyle="True">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border
                                                x:Name="OuterBorder"
                                                Background="{Binding Background, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderThickness="{Binding BorderThickness, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                CornerRadius="16"
                                                SnapsToDevicePixels="True">
                                                <!--  箭头放在右侧  -->
                                                <Path
                                                    Width="12"
                                                    Height="7"
                                                    Margin="0,0,18,0"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Center"
                                                    Data="M0,0 L6,6 L12,0"
                                                    Fill="Transparent"
                                                    Stroke="#999999"
                                                    StrokeThickness="1.5" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#B0B0B0" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>

                                <!--  选中项文字：叠加在 ToggleButton 之上，不接收点击  -->
                                <ContentPresenter
                                    x:Name="ContentSite"
                                    Margin="18,0,40,0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Content="{TemplateBinding SelectionBoxItem}"
                                    ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                    ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                    IsHitTestVisible="False" />

                                <!--  下拉弹出层  -->
                                <Popup
                                    x:Name="PART_Popup"
                                    AllowsTransparency="True"
                                    Focusable="False"
                                    IsOpen="{TemplateBinding IsDropDownOpen}"
                                    Placement="Bottom"
                                    PopupAnimation="Fade">
                                    <Border
                                        Width="220"
                                        Margin="0,6,0,0"
                                        Padding="8"
                                        Background="White"
                                        BorderBrush="#E2E2E2"
                                        BorderThickness="1"
                                        CornerRadius="16">
                                        <ScrollViewer MaxHeight="260" CanContentScroll="True">
                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.5" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="ActionIconButtonStyle" TargetType="Button">
                <Setter Property="Width" Value="38" />
                <Setter Property="Height" Value="38" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border
                                x:Name="ActionBorder"
                                Width="38"
                                Height="38"
                                Background="Transparent"
                                CornerRadius="19">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ActionBorder" Property="Background" Value="#EEF3F8" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.35" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="PageArrowButtonStyle" TargetType="Button">
                <Setter Property="Width" Value="40" />
                <Setter Property="Height" Value="40" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border
                                x:Name="ArrowBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ArrowBorder" Property="Background" Value="#F0F0F0" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.35" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="PageNumberButtonStyle" TargetType="Button">
                <Setter Property="Width" Value="44" />
                <Setter Property="Height" Value="40" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border
                                x:Name="PageBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="PageBorder" Property="Background" Value="#F0F0F0" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Border
            MinHeight="760"
            MaxWidth="1720"
            MaxHeight="840"
            Margin="0,0,0,0"
            Padding="40,30,40,28"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Background="#FFFFFF"
            CornerRadius="8">
            <Border.Effect>
                <DropShadowEffect
                    BlurRadius="16"
                    Opacity="0.05"
                    ShadowDepth="2"
                    Color="#000000" />
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="28" />
                    <RowDefinition Height="60" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="36" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="48" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="26" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!--  ==================== 日期范围控件（完全不使用 DatePicker） ====================  -->
                    <Border
                        Grid.Column="0"
                        Width="500"
                        Height="68"
                        Background="#FFFFFF"
                        BorderBrush="#D1D1D1"
                        BorderThickness="1"
                        CornerRadius="16">
                        <Grid Margin="18,0,12,0">
                            <Grid.ColumnDefinitions>
                                <!--  起始日期文本  -->
                                <ColumnDefinition Width="*" />
                                <!--  起始日期日历图标  -->
                                <ColumnDefinition Width="Auto" />
                                <!--  分隔符  -->
                                <ColumnDefinition Width="34" />
                                <!--  截止日期文本  -->
                                <ColumnDefinition Width="*" />
                                <!--  截止日期日历图标  -->
                                <ColumnDefinition Width="Auto" />
                                <!--  清空按钮（固定占位）  -->
                                <ColumnDefinition Width="32" />
                            </Grid.ColumnDefinitions>

                            <!--  起始日期文本  -->
                            <Button
                                x:Name="StartDateButton"
                                Grid.Column="0"
                                VerticalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Background="Transparent"
                                BorderThickness="0"
                                Click="StartDateButton_Click"
                                Cursor="Hand"
                                Focusable="False">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="Transparent">
                                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                                <TextBlock
                                    x:Name="StartDateText"
                                    VerticalAlignment="Center"
                                    FontFamily="{StaticResource AppFont}"
                                    FontSize="22"
                                    Foreground="#BBBBBB"
                                    Text="0000.00.00" />
                            </Button>
                            <Popup
                                x:Name="StartDatePopup"
                                AllowsTransparency="True"
                                Placement="Bottom"
                                PlacementTarget="{Binding ElementName=StartDateButton}"
                                PopupAnimation="Fade"
                                StaysOpen="False">
                                <Border
                                    Margin="0,6,0,0"
                                    Background="White"
                                    BorderBrush="#E5E5E5"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                    <Calendar
                                        x:Name="StartDateCalendar"
                                        DisplayDateEnd="{Binding MaxDate, Mode=OneWay}"
                                        SelectedDatesChanged="StartDateCalendar_SelectedDatesChanged" />
                                </Border>
                            </Popup>

                            <!--  起始日期日历图标（常驻）  -->
                            <Button
                                Grid.Column="1"
                                Width="28"
                                Height="28"
                                Margin="4,0,0,0"
                                Background="Transparent"
                                BorderThickness="0"
                                Click="StartDateButton_Click"
                                Cursor="Hand"
                                Focusable="False">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="Transparent">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                                <Image
                                    Width="22"
                                    Height="22"
                                    RenderOptions.BitmapScalingMode="HighQuality"
                                    Source="/Resources/Images/DataManagement/rili.png" />
                            </Button>

                            <!--  分隔符  -->
                            <TextBlock
                                Grid.Column="2"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontFamily="{StaticResource AppFont}"
                                FontSize="22"
                                Foreground="#D1D1D1"
                                Text=" — " />

                            <!--  截止日期文本  -->
                            <Button
                                x:Name="EndDateButton"
                                Grid.Column="3"
                                VerticalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Background="Transparent"
                                BorderThickness="0"
                                Click="EndDateButton_Click"
                                Cursor="Hand"
                                Focusable="False">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="Transparent">
                                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                                <TextBlock
                                    x:Name="EndDateText"
                                    VerticalAlignment="Center"
                                    FontFamily="{StaticResource AppFont}"
                                    FontSize="22"
                                    Foreground="#BBBBBB"
                                    Text="0000.00.00" />
                            </Button>
                            <Popup
                                x:Name="EndDatePopup"
                                AllowsTransparency="True"
                                Placement="Bottom"
                                PlacementTarget="{Binding ElementName=EndDateButton}"
                                PopupAnimation="Fade"
                                StaysOpen="False">
                                <Border
                                    Margin="0,6,0,0"
                                    Background="White"
                                    BorderBrush="#E5E5E5"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                    <Calendar
                                        x:Name="EndDateCalendar"
                                        DisplayDateEnd="{Binding MaxDate, Mode=OneWay}"
                                        SelectedDatesChanged="EndDateCalendar_SelectedDatesChanged" />
                                </Border>
                            </Popup>

                            <!--  截止日期日历图标（常驻）  -->
                            <Button
                                Grid.Column="4"
                                Width="28"
                                Height="28"
                                Margin="4,0,0,0"
                                Background="Transparent"
                                BorderThickness="0"
                                Click="EndDateButton_Click"
                                Cursor="Hand"
                                Focusable="False">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="Transparent">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                                <Image
                                    Width="22"
                                    Height="22"
                                    RenderOptions.BitmapScalingMode="HighQuality"
                                    Source="/Resources/Images/DataManagement/rili.png" />
                            </Button>

                            <!--  清空按钮（固定列宽，不改变 Visibility，用 Opacity 控制显隐）  -->
                            <Button
                                x:Name="DateClearButton"
                                Grid.Column="5"
                                Width="24"
                                Height="24"
                                HorizontalAlignment="Center"
                                Background="Transparent"
                                BorderThickness="0"
                                Click="DateClearButton_Click"
                                Cursor="Hand"
                                Focusable="False"
                                IsHitTestVisible="False"
                                Opacity="0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border
                                            x:Name="ClearBorder"
                                            Background="Transparent"
                                            CornerRadius="12">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ClearBorder" Property="Background" Value="#F0F0F0" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <TextBlock
                                    FontFamily="Segoe UI"
                                    FontSize="14"
                                    Foreground="#999999"
                                    Text="✕" />
                            </Button>
                        </Grid>
                    </Border>

                    <!--  ==================== 状态下拉框 ====================  -->
                    <StackPanel
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <TextBlock
                            Width="44"
                            VerticalAlignment="Center"
                            FontFamily="{StaticResource AppFont}"
                            FontSize="22"
                            Foreground="#666666"
                            Text="状态" />
                        <ComboBox
                            Width="220"
                            Height="68"
                            Margin="18,0,0,0"
                            DisplayMemberPath="Display"
                            ItemsSource="{Binding StatusOptions}"
                            PreviewMouseLeftButtonDown="StatusComboBox_PreviewMouseLeftButtonDown"
                            SelectedItem="{Binding SelectedStatusOption, Mode=TwoWay}"
                            Style="{StaticResource FilterComboBoxStyle}" />
                    </StackPanel>

                    <Button
                        Grid.Column="4"
                        Width="180"
                        Height="68"
                        Background="#403B5B"
                        BorderThickness="0"
                        Command="{Binding SearchCommand}"
                        Cursor="Hand"
                        Foreground="White"
                        Tag="24"
                        Template="{StaticResource RoundedButtonTemplate}">
                        <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                            <Image
                                Width="24"
                                Height="24"
                                RenderOptions.BitmapScalingMode="HighQuality"
                                Source="/Resources/Images/DataManagement/sousuo.png" />
                            <TextBlock
                                Margin="10,0,0,0"
                                VerticalAlignment="Center"
                                FontFamily="{StaticResource AppFont}"
                                FontSize="22"
                                Foreground="White"
                                Text="搜索" />
                        </StackPanel>
                    </Button>
                </Grid>

                <Border
                    Grid.Row="2"
                    Background="#FAFAFA"
                    CornerRadius="8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="1.05*" />
                            <ColumnDefinition Width="1.05*" />
                            <ColumnDefinition Width="0.8*" />
                            <ColumnDefinition Width="0.8*" />
                            <ColumnDefinition Width="1.9*" />
                            <ColumnDefinition Width="1.25*" />
                            <ColumnDefinition Width="0.8*" />
                            <ColumnDefinition Width="0.8*" />
                            <ColumnDefinition Width="0.8*" />
                        </Grid.ColumnDefinitions>

                        <Button
                            Grid.Column="0"
                            Click="AllSelectCheckBox_Click"
                            Style="{StaticResource HeaderSelectIconButtonStyle}" />

                        <TextBlock
                            Grid.Column="1"
                            Style="{StaticResource HeaderTextStyle}"
                            Text="编号" />
                        <TextBlock
                            Grid.Column="2"
                            Style="{StaticResource HeaderTextStyle}"
                            Text="姓名" />
                        <TextBlock
                            Grid.Column="3"
                            Style="{StaticResource HeaderTextStyle}"
                            Text="性别" />
                        <TextBlock
                            Grid.Column="4"
                            Style="{StaticResource HeaderTextStyle}"
                            Text="年龄" />
                        <TextBlock
                            Grid.Column="5"
                            Style="{StaticResource HeaderTextStyle}"
                            Text="测量日期" />
                        <TextBlock
                            Grid.Column="6"
                            Style="{StaticResource HeaderTextStyle}"
                            Text="状态" />
                        <TextBlock
                            Grid.Column="7"
                            Style="{StaticResource HeaderTextStyle}"
                            Text="详情" />
                        <TextBlock
                            Grid.Column="8"
                            Style="{StaticResource HeaderTextStyle}"
                            Text="导出" />
                        <TextBlock
                            Grid.Column="9"
                            Style="{StaticResource HeaderTextStyle}"
                            Text="删除" />
                    </Grid>
                </Border>

                <Grid
                    x:Name="DataListViewport"
                    Grid.Row="3"
                    MaxHeight="468"
                    VerticalAlignment="Stretch"
                    SizeChanged="DataListViewport_SizeChanged">
                    <ItemsControl ItemsSource="{Binding MeasurementRecords}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border
                                    x:Name="RowBorder"
                                    Height="60"
                                    Margin="0,8,0,0"
                                    Background="#FAFAFA"
                                    CornerRadius="8"
                                    SnapsToDevicePixels="True">
                                    <Grid VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="1.05*" />
                                            <ColumnDefinition Width="1.05*" />
                                            <ColumnDefinition Width="0.8*" />
                                            <ColumnDefinition Width="0.8*" />
                                            <ColumnDefinition Width="1.9*" />
                                            <ColumnDefinition Width="1.25*" />
                                            <ColumnDefinition Width="0.8*" />
                                            <ColumnDefinition Width="0.8*" />
                                            <ColumnDefinition Width="0.8*" />
                                        </Grid.ColumnDefinitions>

                                        <CheckBox
                                            Grid.Column="0"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Checked="ItemCheckBox_CheckedChanged"
                                            IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            Style="{StaticResource SelectCheckBoxStyle}"
                                            Unchecked="ItemCheckBox_CheckedChanged" />

                                        <TextBlock
                                            Grid.Column="1"
                                            Style="{StaticResource RowTextStyle}"
                                            Text="{Binding RowNumber}" />
                                        <TextBlock
                                            Grid.Column="2"
                                            Style="{StaticResource RowTextStyle}"
                                            Text="{Binding PatientName}" />
                                        <TextBlock
                                            Grid.Column="3"
                                            Style="{StaticResource RowTextStyle}"
                                            Text="{Binding GenderDisplay}" />
                                        <TextBlock
                                            Grid.Column="4"
                                            Style="{StaticResource RowTextStyle}"
                                            Text="{Binding AgeDisplay}" />
                                        <TextBlock
                                            Grid.Column="5"
                                            Style="{StaticResource RowTextStyle}"
                                            Text="{Binding MeasurementDateDisplay}" />

                                        <Border
                                            Grid.Column="6"
                                            Width="120"
                                            Height="36"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Background="{Binding StatusBackground}"
                                            CornerRadius="20">
                                            <StackPanel
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Orientation="Horizontal">
                                                <Image
                                                    Width="18"
                                                    Height="18"
                                                    Margin="0,0,6,0"
                                                    RenderOptions.BitmapScalingMode="HighQuality"
                                                    Source="{Binding StatusIcon}" />
                                                <TextBlock
                                                    VerticalAlignment="Center"
                                                    FontFamily="{StaticResource AppFont}"
                                                    FontSize="18"
                                                    FontWeight="Medium"
                                                    Foreground="{Binding StatusForeground}"
                                                    Text="{Binding StatusDisplay}" />
                                            </StackPanel>
                                        </Border>

                                        <Button
                                            Grid.Column="7"
                                            Command="{Binding DataContext.ViewDetailCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource ActionIconButtonStyle}">
                                            <Image
                                                Width="28"
                                                Height="28"
                                                RenderOptions.BitmapScalingMode="HighQuality"
                                                Source="/Resources/Images/DataManagement/xiangqing.png" />
                                        </Button>

                                        <Button
                                            Grid.Column="8"
                                            Command="{Binding DataContext.ExportSingleCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource ActionIconButtonStyle}"
                                            Visibility="{Binding DataContext.CanExport, RelativeSource={RelativeSource AncestorType=ItemsControl}, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <Image
                                                Width="22"
                                                Height="22"
                                                RenderOptions.BitmapScalingMode="HighQuality"
                                                Source="/Resources/Images/DataManagement/piliangdaochu.png" />
                                        </Button>

                                        <Button
                                            Grid.Column="9"
                                            Command="{Binding DataContext.DeleteSingleCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource ActionIconButtonStyle}"
                                            Visibility="{Binding DataContext.CanDelete, RelativeSource={RelativeSource AncestorType=ItemsControl}, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <Image
                                                Width="28"
                                                Height="28"
                                                RenderOptions.BitmapScalingMode="HighQuality"
                                                Source="/Resources/Images/PatientSelectionView/shanchu.png" />
                                        </Button>
                                    </Grid>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                        <Setter TargetName="RowBorder" Property="Background" Value="#F0F4F9" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border
                        Background="#66FFFFFF"
                        CornerRadius="8"
                        Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Orientation="Vertical">
                            <ProgressBar
                                Width="120"
                                Height="4"
                                IsIndeterminate="True" />
                            <TextBlock
                                Margin="0,14,0,0"
                                HorizontalAlignment="Center"
                                FontFamily="{StaticResource AppFont}"
                                FontSize="18"
                                Foreground="#666666"
                                Text="正在加载数据..." />
                        </StackPanel>
                    </Border>

                    <Border HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock
                            FontFamily="{StaticResource AppFont}"
                            FontSize="18"
                            Foreground="#999999"
                            Text="暂无数据">
                            <TextBlock.Visibility>
                                <MultiBinding Converter="{StaticResource EmptyDataVisibilityConverter}">
                                    <Binding Path="MeasurementRecords.Count" />
                                    <Binding Path="IsLoading" />
                                </MultiBinding>
                            </TextBlock.Visibility>
                        </TextBlock>
                    </Border>
                </Grid>

                <Grid Grid.Row="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel
                        Grid.Column="0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Orientation="Horizontal"
                        Visibility="{Binding CanBatchOperation, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Button
                            Width="160"
                            Height="48"
                            Background="#FFFFFF"
                            BorderBrush="#403B5B"
                            BorderThickness="1"
                            Command="{Binding BatchExportCommand}"
                            Cursor="Hand"
                            Tag="24"
                            Template="{StaticResource RoundedButtonTemplate}"
                            Visibility="{Binding CanExport, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="IsEnabled" Value="True" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedCount}" Value="0">
                                            <Setter Property="IsEnabled" Value="False" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                <Image
                                    Width="22"
                                    Height="22"
                                    RenderOptions.BitmapScalingMode="HighQuality"
                                    Source="/Resources/Images/DataManagement/piliangdaochu.png" />
                                <TextBlock
                                    Margin="8,0,0,0"
                                    VerticalAlignment="Center"
                                    FontFamily="{StaticResource AppFont}"
                                    FontSize="18"
                                    FontWeight="Medium"
                                    Foreground="#403B5B"
                                    Text="批量导出" />
                            </StackPanel>
                        </Button>

                        <Button
                            Width="160"
                            Height="48"
                            Margin="22,0,0,0"
                            Background="#FFFFFF"
                            BorderBrush="#FF0000"
                            BorderThickness="1"
                            Command="{Binding BatchDeleteCommand}"
                            Cursor="Hand"
                            Tag="24"
                            Template="{StaticResource RoundedButtonTemplate}"
                            Visibility="{Binding CanDelete, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="IsEnabled" Value="True" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedCount}" Value="0">
                                            <Setter Property="IsEnabled" Value="False" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                <Image
                                    Width="22"
                                    Height="22"
                                    RenderOptions.BitmapScalingMode="HighQuality"
                                    Source="/Resources/Images/DataManagement/shanchu2.png" />
                                <TextBlock
                                    Margin="8,0,0,0"
                                    VerticalAlignment="Center"
                                    FontFamily="{StaticResource AppFont}"
                                    FontSize="18"
                                    FontWeight="Medium"
                                    Foreground="#FF0000"
                                    Text="删除" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <StackPanel
                        Grid.Column="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <Button
                            Margin="0,0,30,0"
                            Command="{Binding PreviousPageCommand}"
                            IsEnabled="{Binding CanPagePrevious}"
                            Style="{StaticResource PageArrowButtonStyle}">
                            <Image
                                Width="20"
                                Height="20"
                                RenderOptions.BitmapScalingMode="HighQuality"
                                Source="/Resources/Images/PatientSelectionView/zuo.png" />
                        </Button>

                        <ItemsControl ItemsSource="{Binding DataPageNumbers}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Width="65" Height="40">
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontFamily="Roboto"
                                            FontSize="22"
                                            FontWeight="Medium"
                                            Foreground="#999999"
                                            Text="...">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsEllipsis}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <Border
                                            Width="44"
                                            Height="40"
                                            HorizontalAlignment="Center"
                                            Background="#F0F4F9"
                                            CornerRadius="8">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding IsCurrent}" Value="True" />
                                                                <Condition Binding="{Binding IsEllipsis}" Value="False" />
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </MultiDataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                FontFamily="Roboto"
                                                FontSize="22"
                                                FontWeight="Medium"
                                                Foreground="#403B5B"
                                                Text="{Binding DisplayText}" />
                                        </Border>

                                        <Button
                                            HorizontalAlignment="Center"
                                            Command="{Binding DataContext.GoToPageNumberCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding PageNumber}">
                                            <Button.Style>
                                                <Style BasedOn="{StaticResource PageNumberButtonStyle}" TargetType="Button">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsEllipsis}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <TextBlock
                                                FontFamily="Roboto"
                                                FontSize="22"
                                                FontWeight="Medium"
                                                Foreground="#555555"
                                                Text="{Binding DisplayText}" />
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Button
                            Margin="30,0,0,0"
                            Command="{Binding NextPageCommand}"
                            IsEnabled="{Binding CanPageNext}"
                            Style="{StaticResource PageArrowButtonStyle}">
                            <Image
                                Width="20"
                                Height="20"
                                RenderOptions.BitmapScalingMode="HighQuality"
                                Source="/Resources/Images/PatientSelectionView/you.png" />
                        </Button>
                    </StackPanel>

                    <TextBlock
                        Grid.Column="2"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        FontFamily="{StaticResource AppFont}"
                        FontSize="16"
                        Foreground="#999999"
                        Text="{Binding SelectedCount, StringFormat=已选 {0} 项}" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
