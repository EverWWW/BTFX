<UserControl
    x:Class="BTFX.Views.DataManagementView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:BTFX.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:vm="clr-namespace:BTFX.ViewModels"
    d:DataContext="{d:DesignInstance Type=vm:DataManagementViewModel}"
    d:DesignHeight="700"
    d:DesignWidth="1200"
    mc:Ignorable="d">

    <UserControl.Resources>
        <!--  状态颜色转换器  -->
        <SolidColorBrush x:Key="PendingBrush" Color="#FF9800" />
        <SolidColorBrush x:Key="InProgressBrush" Color="#2196F3" />
        <SolidColorBrush x:Key="CompletedBrush" Color="#4CAF50" />
        <SolidColorBrush x:Key="CancelledBrush" Color="#9E9E9E" />
        <SolidColorBrush x:Key="FailedBrush" Color="#F44336" />
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <!--  顶部筛选区域  -->
            <RowDefinition Height="Auto" />
            <!--  中间数据列表  -->
            <RowDefinition Height="*" />
            <!--  底部分页和操作  -->
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  顶部筛选区域  -->
        <md:Card
            Grid.Row="0"
            Margin="0,0,0,16"
            Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--  筛选条件  -->
                <WrapPanel
                    Grid.Row="0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <!--  患者姓名  -->
                    <StackPanel Margin="0,0,24,8" Orientation="Horizontal">
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="14"
                            Text="{DynamicResource FilterPatientName}" />
                        <TextBox
                            Width="150"
                            md:HintAssist.Hint="{DynamicResource EnterNameSearch}"
                            MaxLength="50"
                            Style="{StaticResource MaterialDesignOutlinedTextBox}"
                            Text="{Binding FilterPatientName, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <!--  开始日期  -->
                    <StackPanel Margin="0,0,24,8" Orientation="Horizontal">
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="14"
                            Text="{DynamicResource StartDate}" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="14"
                            Text="：" />
                        <DatePicker
                            Width="140"
                            md:HintAssist.Hint="{DynamicResource SelectDateHint}"
                            DisplayDateEnd="{Binding MaxDate, Mode=OneWay}"
                            SelectedDate="{Binding FilterStartDate}"
                            Style="{StaticResource MaterialDesignOutlinedDatePicker}" />
                    </StackPanel>

                    <!--  结束日期  -->
                    <StackPanel Margin="0,0,24,8" Orientation="Horizontal">
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="14"
                            Text="{DynamicResource EndDate}" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="14"
                            Text="：" />
                        <DatePicker
                            Width="140"
                            md:HintAssist.Hint="{DynamicResource SelectDateHint}"
                            DisplayDateEnd="{Binding MaxDate, Mode=OneWay}"
                            SelectedDate="{Binding FilterEndDate}"
                            Style="{StaticResource MaterialDesignOutlinedDatePicker}" />
                    </StackPanel>

                    <!--  测量状态  -->
                    <StackPanel Margin="0,0,24,8" Orientation="Horizontal">
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="14"
                            Text="{DynamicResource MeasurementStatus}" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="14"
                            Text="：" />
                        <ComboBox
                            Width="120"
                            DisplayMemberPath="Display"
                            ItemsSource="{Binding StatusOptions}"
                            SelectedItem="{Binding SelectedStatusOption}"
                            Style="{StaticResource MaterialDesignOutlinedComboBox}" />
                    </StackPanel>

                    <!--  搜索和重置按钮  -->
                    <StackPanel Margin="0,0,0,8" Orientation="Horizontal">
                        <Button
                            Margin="0,0,8,0"
                            Command="{Binding SearchCommand}"
                            Content="{DynamicResource Search}"
                            Style="{StaticResource MaterialDesignRaisedButton}" />
                        <Button
                            Command="{Binding ResetFilterCommand}"
                            Content="{DynamicResource Reset}"
                            Style="{StaticResource MaterialDesignOutlinedButton}" />
                    </StackPanel>
                </WrapPanel>
            </Grid>
        </md:Card>

        <!--  中间数据列表  -->
        <md:Card
            Grid.Row="1"
            Margin="0,0,0,16"
            Padding="0">
            <Grid>
                <!--  数据列表  -->
                <DataGrid
                    AlternatingRowBackground="{DynamicResource MaterialDesignPaper}"
                    AutoGenerateColumns="False"
                    CanUserAddRows="False"
                    CanUserDeleteRows="False"
                    CanUserReorderColumns="False"
                    HeadersVisibility="Column"
                    IsReadOnly="True"
                    ItemsSource="{Binding MeasurementRecords}"
                    RowBackground="{DynamicResource MaterialDesignCardBackground}"
                    SelectedItem="{Binding SelectedRecord}"
                    SelectionMode="Single"
                    Style="{StaticResource MaterialDesignDataGrid}">

                    <DataGrid.Resources>
                        <!--  移除选中行的边框高亮  -->
                        <Style BasedOn="{StaticResource {x:Type DataGridRow}}" TargetType="DataGridRow">
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                            <EventSetter Event="MouseDoubleClick" Handler="DataGridRow_MouseDoubleClick" />
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="BorderThickness" Value="0" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>

                        <!--  移除单元格选中边框并确保文字垂直居中  -->
                        <Style BasedOn="{StaticResource {x:Type DataGridCell}}" TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <Border
                                            Padding="8,0"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}">
                                            <ContentPresenter VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Background" Value="Transparent" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <!--  选择列  -->
                        <DataGridTemplateColumn Width="50">
                            <DataGridTemplateColumn.Header>
                                <CheckBox
                                    Checked="AllSelectCheckBox_CheckedChanged"
                                    IsChecked="{Binding DataContext.IsAllSelected, RelativeSource={RelativeSource AncestorType=DataGrid}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    ToolTip="{DynamicResource ToggleSelectAll}"
                                    Unchecked="AllSelectCheckBox_CheckedChanged" />
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox
                                        HorizontalAlignment="Center"
                                        Checked="ItemCheckBox_CheckedChanged"
                                        IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        Unchecked="ItemCheckBox_CheckedChanged" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!--  序号列  -->
                        <DataGridTextColumn
                            Width="60"
                            Binding="{Binding RowNumber}"
                            Header="{DynamicResource Id}" />

                        <!--  患者姓名列  -->
                        <DataGridTextColumn
                            Width="120"
                            Binding="{Binding PatientName}"
                            Header="{DynamicResource PatientName}" />

                        <!--  性别列  -->
                        <DataGridTextColumn
                            Width="60"
                            Binding="{Binding GenderDisplay}"
                            Header="{DynamicResource Gender}" />

                        <!--  年龄列  -->
                        <DataGridTextColumn
                            Width="60"
                            Binding="{Binding AgeDisplay}"
                            Header="{DynamicResource Age}" />

                        <!--  测量日期列  -->
                        <DataGridTextColumn
                            Width="160"
                            Binding="{Binding MeasurementDateDisplay}"
                            Header="{DynamicResource MeasurementDate}" />

                        <!--  测量状态列  -->
                        <DataGridTemplateColumn Width="100" Header="{DynamicResource MeasurementStatus}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border
                                        Padding="8,4"
                                        HorizontalAlignment="Center"
                                        Background="{Binding StatusColor}"
                                        CornerRadius="4">
                                        <TextBlock
                                            FontSize="12"
                                            Foreground="White"
                                            Text="{Binding StatusDisplay}" />
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!--  操作列  -->
                        <DataGridTemplateColumn Width="200" Header="{DynamicResource Actions}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                        <Button
                                            Margin="0,0,4,0"
                                            Command="{Binding DataContext.ViewDetailCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Content="{DynamicResource ViewDetails}"
                                            Style="{StaticResource MaterialDesignFlatButton}" />
                                        <Button
                                            Margin="0,0,4,0"
                                            Command="{Binding DataContext.ExportSingleCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Content="{DynamicResource Export}"
                                            Style="{StaticResource MaterialDesignFlatButton}"
                                            Visibility="{Binding DataContext.CanExport, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <Button
                                            Command="{Binding DataContext.DeleteSingleCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Content="{DynamicResource Delete}"
                                            Foreground="{StaticResource FailedBrush}"
                                            Style="{StaticResource MaterialDesignFlatButton}"
                                            Visibility="{Binding DataContext.CanDelete, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!--  加载中遮罩  -->
                <Border
                    Background="#80000000"
                    CornerRadius="4"
                    Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <ProgressBar
                            Width="24"
                            Height="24"
                            Margin="0,0,8,0"
                            IsIndeterminate="True"
                            Style="{StaticResource MaterialDesignCircularProgressBar}" />
                        <TextBlock
                            VerticalAlignment="Center"
                            Foreground="White"
                            Text="{DynamicResource Loading}" />
                    </StackPanel>
                </Border>

                <!--  空数据提示  -->
                <Border
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Panel.ZIndex="-1">
                    <TextBlock
                        FontSize="16"
                        Foreground="{DynamicResource MaterialDesignBodyLight}"
                        Text="{DynamicResource NoData}">
                        <TextBlock.Visibility>
                            <MultiBinding Converter="{StaticResource EmptyDataVisibilityConverter}">
                                <Binding Path="MeasurementRecords.Count" />
                                <Binding Path="IsLoading" />
                            </MultiBinding>
                        </TextBlock.Visibility>
                    </TextBlock>
                </Border>
            </Grid>
        </md:Card>

        <!--  底部分页和操作区域  -->
        <md:Card Grid.Row="2" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <!--  分页控件  -->
                    <ColumnDefinition Width="Auto" />
                    <!--  统计信息  -->
                    <ColumnDefinition Width="*" />
                    <!--  批量操作  -->
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!--  分页控件  -->
                <StackPanel
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <Button
                        Margin="0,0,8,0"
                        Command="{Binding PreviousPageCommand}"
                        Content="{DynamicResource PreviousPage}"
                        IsEnabled="{Binding CurrentPage, Converter={StaticResource GreaterThanOneConverter}}"
                        Style="{StaticResource MaterialDesignOutlinedButton}" />

                    <TextBlock
                        Margin="8,0"
                        VerticalAlignment="Center"
                        FontSize="14">
                        <Run Text="{DynamicResource Page}" />
                        <Run FontWeight="Bold" Text="{Binding CurrentPage, Mode=OneWay}" />
                        <Run Text="/" />
                        <Run FontWeight="Bold" Text="{Binding TotalPages, Mode=OneWay}" />
                        <Run Text="{DynamicResource Page}" />
                    </TextBlock>

                    <Button
                        Margin="8,0"
                        Command="{Binding NextPageCommand}"
                        Content="{DynamicResource NextPage}"
                        Style="{StaticResource MaterialDesignOutlinedButton}" />

                    <TextBlock
                        Margin="16,0,8,0"
                        VerticalAlignment="Center"
                        Text="{DynamicResource GoToPage}" />
                    <TextBox
                        Width="50"
                        VerticalContentAlignment="Center"
                        Style="{StaticResource MaterialDesignOutlinedTextBox}"
                        Text="{Binding GoToPageInput, UpdateSourceTrigger=PropertyChanged}">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding GoToPageCommand}" />
                        </TextBox.InputBindings>
                    </TextBox>
                    <TextBlock
                        Margin="8,0"
                        VerticalAlignment="Center"
                        Text="{DynamicResource Pages}" />
                    <Button
                        Command="{Binding GoToPageCommand}"
                        Content="{DynamicResource Go}"
                        Style="{StaticResource MaterialDesignFlatButton}" />
                </StackPanel>

                <!--  统计信息  -->
                <TextBlock
                    Grid.Column="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="14"
                    Foreground="{DynamicResource MaterialDesignBodyLight}">
                    <Run Text="{DynamicResource Total}" />
                    <Run FontWeight="Bold" Text="{Binding TotalRecords, Mode=OneWay}" />
                    <Run Text="{DynamicResource RecordsSelected}" />
                    <Run FontWeight="Bold" Text="{Binding SelectedCount, Mode=OneWay}" />
                    <Run Text="{DynamicResource Items}" />
                </TextBlock>

                <!--  批量操作按钮  -->
                <StackPanel
                    Grid.Column="2"
                    VerticalAlignment="Center"
                    Orientation="Horizontal"
                    Visibility="{Binding CanBatchOperation, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Button
                        Margin="0,0,8,0"
                        Command="{Binding BatchExportCommand}"
                        Content="{DynamicResource BatchExport}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Visibility="{Binding CanExport, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <Button
                        Background="{StaticResource FailedBrush}"
                        Command="{Binding BatchDeleteCommand}"
                        Content="{DynamicResource BatchDelete}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Visibility="{Binding CanDelete, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </StackPanel>
            </Grid>
        </md:Card>
    </Grid>
</UserControl>
