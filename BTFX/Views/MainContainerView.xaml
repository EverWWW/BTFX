<UserControl
    x:Class="BTFX.Views.MainContainerView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:BTFX.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="clr-namespace:BTFX.ViewModels"
    d:DesignHeight="960"
    d:DesignWidth="1880"
    Background="#F4F4F4"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVisConverter" />

        <Style x:Key="ShellCardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="NavigationListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled" />
        </Style>

        <Style x:Key="NavigationListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Height" Value="Auto" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                    <Setter Property="Opacity" Value="0.35" />
                    <Setter Property="IsEnabled" Value="False" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Key}" Value="DevTest">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="NavigationCardStyle" TargetType="Border">
            <Setter Property="Width" Value="96" />
            <Setter Property="Height" Value="88" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Background" Value="#403B5B" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="NavigationIconStyle" TargetType="Image">
            <Setter Property="Width" Value="48" />
            <Setter Property="Height" Value="48" />
            <Setter Property="Stretch" Value="Uniform" />
            <Setter Property="RenderOptions.BitmapScalingMode" Value="HighQuality" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Key}" Value="Measurement">
                    <Setter Property="Source" Value="/Resources/Images/NavigationItem/celiangpinggu1.png" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Key}" Value="DataManagement">
                    <Setter Property="Source" Value="/Resources/Images/NavigationItem/shujuguanli1.png" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Key}" Value="Report">
                    <Setter Property="Source" Value="/Resources/Images/NavigationItem/baogao1.png" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Key}" Value="Settings">
                    <Setter Property="Source" Value="/Resources/Images/NavigationItem/shezhi1.png" />
                </DataTrigger>

                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Key}" Value="Measurement" />
                        <Condition Binding="{Binding IsSelected}" Value="True" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Source" Value="/Resources/Images/NavigationItem/celiangpinggu2.png" />
                </MultiDataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Key}" Value="DataManagement" />
                        <Condition Binding="{Binding IsSelected}" Value="True" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Source" Value="/Resources/Images/NavigationItem/shujuguanli2.png" />
                </MultiDataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Key}" Value="Report" />
                        <Condition Binding="{Binding IsSelected}" Value="True" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Source" Value="/Resources/Images/NavigationItem/baogao2.png" />
                </MultiDataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Key}" Value="Settings" />
                        <Condition Binding="{Binding IsSelected}" Value="True" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Source" Value="/Resources/Images/NavigationItem/shezhi2.png" />
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="NavigationTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Foreground" Value="#403B5B" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>

        <Style x:Key="HeaderLabelTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="Foreground" Value="#999999" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="HeaderValueTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="Foreground" Value="#555555" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <ControlTemplate x:Key="RoundActionButtonTemplate" TargetType="Button">
            <Border
                x:Name="ButtonBorder"
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="24"
                SnapsToDevicePixels="True">
                <ContentPresenter
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    RecognizesAccessKey="True" />
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.9" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.75" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style x:Key="ActionButtonBaseStyle" TargetType="Button">
            <Setter Property="Width" Value="160" />
            <Setter Property="Height" Value="48" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template" Value="{StaticResource RoundActionButtonTemplate}" />
        </Style>

        <Style
            x:Key="SwitchPatientButtonStyle"
            BasedOn="{StaticResource ActionButtonBaseStyle}"
            TargetType="Button">
            <Setter Property="Background" Value="#F0F4F9" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#403B5B" />
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsGuestMode}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style
            x:Key="CreateMeasurementButtonStyle"
            BasedOn="{StaticResource ActionButtonBaseStyle}"
            TargetType="Button">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#403B5B" />
            <Setter Property="Foreground" Value="#403B5B" />
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding SelectedNavigationItem.Key}" Value="Measurement">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style
            x:Key="ResetButtonStyle"
            BasedOn="{StaticResource ActionButtonBaseStyle}"
            TargetType="Button">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#FF932D" />
            <Setter Property="Foreground" Value="#FF932D" />
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding SelectedNavigationItem.Key}" Value="Measurement">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LogoutButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="96" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="LogoutBorder"
                            Padding="0,12"
                            Background="Transparent"
                            CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="LogoutBorder" Property="Background" Value="#F7F7F7" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="LogoutBorder" Property="Opacity" Value="0.75" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DeviceStatusImageStyle" TargetType="Image">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Stretch" Value="Uniform" />
            <Setter Property="Source" Value="/Resources/Images/NavigationItem/weilianjie.png" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding DeviceStatus}" Value="{x:Static viewModels:DeviceConnectionStatus.Connected}">
                    <Setter Property="Source" Value="/Resources/Images/NavigationItem/lianjie.png" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style
            x:Key="DeviceStatusTextStyle"
            BasedOn="{StaticResource HeaderValueTextStyle}"
            TargetType="TextBlock">
            <Setter Property="Foreground" Value="#666666" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding DeviceStatus}" Value="{x:Static viewModels:DeviceConnectionStatus.Connected}">
                    <Setter Property="Foreground" Value="#24BC3E" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <materialDesign:DialogHost CloseOnClickAway="False" Identifier="RootDialog">
        <Grid Background="#F4F4F4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border
                Grid.Column="0"
                Margin="16,16,0,16"
                Style="{StaticResource ShellCardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="32" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="24" />
                    </Grid.RowDefinitions>

                    <ListBox
                        Grid.Row="1"
                        Margin="0,18,0,0"
                        ItemContainerStyle="{StaticResource NavigationListBoxItemStyle}"
                        ItemsSource="{Binding NavigationItems}"
                        SelectedItem="{Binding SelectedNavigationItem}"
                        Style="{StaticResource NavigationListBoxStyle}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <StackPanel Margin="0,0,0,48" VerticalAlignment="Center">
                                        <Border Style="{StaticResource NavigationCardStyle}">
                                            <Grid>
                                                <Image Style="{StaticResource NavigationIconStyle}" />
                                            </Grid>
                                        </Border>
                                        <TextBlock
                                            Margin="0,12,0,0"
                                            Style="{StaticResource NavigationTextStyle}"
                                            Text="{Binding Title}" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Button
                        Grid.Row="2"
                        Command="{Binding LogoutCommand}"
                        Style="{StaticResource LogoutButtonStyle}">
                        <StackPanel HorizontalAlignment="Center">
                            <Image
                                Width="32"
                                Height="32"
                                Source="/Resources/Images/NavigationItem/tuichu.png"
                                Stretch="Uniform" />
                            <TextBlock
                                Margin="0,10,0,0"
                                HorizontalAlignment="Center"
                                FontFamily="{StaticResource AppFont}"
                                FontSize="22"
                                FontWeight="Medium"
                                Foreground="#403B5B"
                                Text="退出" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <Grid Grid.Column="2" Margin="0,16,16,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="80" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border
                    Grid.Row="0"
                    Padding="28,0"
                    Style="{StaticResource ShellCardBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="32" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                            <TextBlock Style="{StaticResource HeaderLabelTextStyle}" Text="姓名：" />
                            <TextBlock Style="{StaticResource HeaderValueTextStyle}" Text="{Binding CurrentPatientName, TargetNullValue=--}" />
                            <StackPanel
                                Margin="36,0,0,0"
                                VerticalAlignment="Center"
                                Orientation="Horizontal"
                                Visibility="{Binding IsCurrentPatientGenderVisible, Converter={StaticResource BoolToVisConverter}}">
                                <TextBlock Style="{StaticResource HeaderLabelTextStyle}" Text="性别：" />
                                <TextBlock Style="{StaticResource HeaderValueTextStyle}" Text="{Binding CurrentPatientGender, TargetNullValue=--}" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                            <Button Command="{Binding SwitchPatientCommand}" Style="{StaticResource SwitchPatientButtonStyle}">
                                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                    <Image
                                        Width="20"
                                        Height="20"
                                        Margin="0,0,8,0"
                                        Source="/Resources/Images/NavigationItem/genghuanhuanzhe.png"
                                        Stretch="Uniform" />
                                    <TextBlock
                                        FontFamily="{StaticResource AppFont}"
                                        FontSize="20"
                                        Foreground="#403B5B"
                                        Text="更换患者" />
                                </StackPanel>
                            </Button>

                            <Button
                                Margin="16,0,0,0"
                                Command="{Binding ElementName=ContentHost, Path=Content.DataContext.CreateMeasurementCommand}"
                                Style="{StaticResource CreateMeasurementButtonStyle}">
                                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                    <Image
                                        Width="20"
                                        Height="20"
                                        Margin="0,0,8,0"
                                        Source="/Resources/Images/NavigationItem/chuangjianceliang.png"
                                        Stretch="Uniform" />
                                    <TextBlock
                                        FontFamily="{StaticResource AppFont}"
                                        FontSize="20"
                                        Foreground="#403B5B"
                                        Text="创建测量" />
                                </StackPanel>
                            </Button>

                            <Button
                                Margin="16,0,0,0"
                                Command="{Binding ElementName=ContentHost, Path=Content.DataContext.ResetMeasurementCommand}"
                                Style="{StaticResource ResetButtonStyle}">
                                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                    <Image
                                        Width="20"
                                        Height="20"
                                        Margin="0,0,8,0"
                                        Source="/Resources/Images/NavigationItem/chongzhi.png"
                                        Stretch="Uniform" />
                                    <TextBlock
                                        FontFamily="{StaticResource AppFont}"
                                        FontSize="20"
                                        Foreground="#FF932D"
                                        Text="重置" />
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <StackPanel
                            Grid.Column="4"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                            <Image Margin="0,0,8,0" Style="{StaticResource DeviceStatusImageStyle}" />
                            <TextBlock Style="{StaticResource DeviceStatusTextStyle}" Text="{Binding DeviceStatusText}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border
                    Grid.Row="2"
                    Padding="0"
                    Style="{StaticResource ShellCardBorderStyle}">
                    <Grid>
                        <ContentControl x:Name="ContentHost" Content="{Binding CurrentContent}">
                            <ContentControl.Style>
                                <Style TargetType="ContentControl">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentContent}" Value="{x:Null}">
                                            <Setter Property="Content">
                                                <Setter.Value>
                                                    <Grid Background="#FFFFFF">
                                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                            <Image
                                                                Width="72"
                                                                Height="72"
                                                                Source="/Resources/Images/NavigationItem/celiangpinggu1.png"
                                                                Stretch="Uniform" />
                                                            <TextBlock
                                                                Margin="0,20,0,0"
                                                                HorizontalAlignment="Center"
                                                                FontFamily="{StaticResource AppFont}"
                                                                FontSize="24"
                                                                FontWeight="Medium"
                                                                Foreground="#403B5B"
                                                                Text="{DynamicResource NavMeasurement}" />
                                                            <TextBlock
                                                                Margin="0,10,0,0"
                                                                HorizontalAlignment="Center"
                                                                FontFamily="{StaticResource AppFont}"
                                                                FontSize="18"
                                                                Foreground="#999999"
                                                                Text="{DynamicResource SelectMenuToStart}" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ContentControl.Style>
                        </ContentControl>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </materialDesign:DialogHost>
</UserControl>
