<UserControl x:Class="BTFX.Views.MainContainerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BTFX.Views"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:BTFX.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="720" d:DesignWidth="1280"
             Background="{DynamicResource MaterialDesign.Brush.Background}">

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVisConverter" />
        <converters:InverseBooleanConverter x:Key="InverseBoolConverter" />
        <converters:StringToColorBrushConverter x:Key="StringToColorBrushConverter" />

        <!-- 导航项样式 -->
        <Style x:Key="NavigationItemStyle" TargetType="ListBoxItem" BasedOn="{StaticResource MaterialDesignListBoxItem}">
            <Setter Property="Height" Value="48" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                    <Setter Property="Opacity" Value="0.5" />
                    <Setter Property="IsEnabled" Value="False" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <materialDesign:DialogHost Identifier="RootDialog" CloseOnClickAway="False">
        <Grid>
            <Grid.ColumnDefinitions>
                <!-- 左侧导航栏 -->
                <ColumnDefinition Width="Auto" />
                <!-- 主内容区 -->
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- 左侧导航栏 -->
            <Border Grid.Column="0" 
                    Background="{DynamicResource MaterialDesign.Brush.Primary}"
                    Width="{Binding IsNavigationOpen, Converter={StaticResource BoolToVisConverter}, ConverterParameter=240|64}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Width" Value="240" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsNavigationOpen}" Value="False">
                                                <Setter Property="Width" Value="64" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <!-- Logo -->
                                        <RowDefinition Height="Auto" />
                                        <!-- 导航菜单 -->
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <!-- Logo区域 -->
                                    <Border Grid.Row="0" 
                                            Padding="16" 
                                            Background="{DynamicResource MaterialDesign.Brush.Primary.Dark}">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <!-- Logo图标 -->
                                            <materialDesign:PackIcon Kind="Walk" 
                                                                      Width="32" Height="32" 
                                                                      Foreground="White"
                                                                      VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Border>

                                    <!-- 导航菜单 -->
                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding NavigationItems}"
                             SelectedItem="{Binding SelectedNavigationItem}"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="0,8"
                             ItemContainerStyle="{StaticResource NavigationItemStyle}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.InputBindings>
                                        <MouseBinding MouseAction="LeftClick" 
                                                      Command="{Binding DataContext.NavigateToCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                      CommandParameter="{Binding}" />
                                    </Grid.InputBindings>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <materialDesign:PackIcon Kind="{Binding IconKind}"
                                                                  Width="24" Height="24"
                                                                  Foreground="White"
                                                                  VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding Title}"
                                                   Foreground="White"
                                                   FontSize="14"
                                                   VerticalAlignment="Center"
                                                   Margin="16,0,0,0"
                                                   Visibility="{Binding DataContext.IsNavigationOpen, RelativeSource={RelativeSource AncestorType=ListBox}, Converter={StaticResource BoolToVisConverter}}" />
                                    </StackPanel>

                                    <!-- 选中指示器 -->
                                    <Border HorizontalAlignment="Left"
                                            Width="4"
                                            Margin="-16,0,0,0"
                                            Background="White"
                                            CornerRadius="0,2,2,0"
                                            Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisConverter}}" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- 右侧主内容区 -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <!-- 顶部状态栏 -->
                    <RowDefinition Height="56" />
                    <!-- 内容区域 -->
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- 顶部状态栏 -->
                <Border Grid.Row="0"
                        Background="{DynamicResource MaterialDesign.Brush.Background}"
                        BorderBrush="{DynamicResource MaterialDesign.Brush.TextBox.HoverBackground}"
                        BorderThickness="0,0,0,1">
                    <Grid Margin="16,0">
                        <Grid.ColumnDefinitions>
                            <!-- 菜单折叠按钮 -->
                            <ColumnDefinition Width="Auto" />
                            <!-- 患者信息 -->
                            <ColumnDefinition Width="Auto" />
                            <!-- 当前时间（居中） -->
                            <ColumnDefinition Width="*" />
                            <!-- 设备状态 -->
                            <ColumnDefinition Width="Auto" />
                            <!-- 操作按钮 -->
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- 菜单折叠按钮 -->
                        <Button Grid.Column="0"
                                Style="{StaticResource MaterialDesignIconButton}"
                                Command="{Binding ToggleNavigationCommand}"
                                ToolTip="展开/折叠菜单">
                            <materialDesign:PackIcon Kind="Menu" Width="24" Height="24" />
                        </Button>

                        <!-- 患者信息区域 -->
                        <StackPanel Grid.Column="1" 
                                    Orientation="Horizontal" 
                                    VerticalAlignment="Center"
                                    Margin="16,0">
                            <!-- 有患者时显示 -->
                            <StackPanel Orientation="Horizontal"
                                        Visibility="{Binding HasCurrentPatient, Converter={StaticResource BoolToVisConverter}}">
                                <materialDesign:PackIcon Kind="Account" 
                                                          Width="20" Height="20"
                                                          VerticalAlignment="Center"
                                                          Foreground="{DynamicResource MaterialDesign.Brush.Primary}" />
                                <TextBlock Text="{Binding CurrentPatientName}"
                                           FontSize="14"
                                           FontWeight="Medium"
                                           VerticalAlignment="Center"
                                           Margin="8,0,0,0" />
                                <TextBlock VerticalAlignment="Center"
                                           Margin="8,0,0,0"
                                           Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}">
                                    <Run Text="{Binding CurrentPatientGender}" />
                                    <Run Text=" / " />
                                    <Run Text="{Binding CurrentPatientAge, StringFormat={}{0}岁}" />
                                </TextBlock>
                            </StackPanel>

                            <!-- 游客模式提示 -->
                            <StackPanel Orientation="Horizontal"
                                        Visibility="{Binding IsGuestMode, Converter={StaticResource BoolToVisConverter}}">
                                <materialDesign:PackIcon Kind="AccountAlert"
                                                          Width="20" Height="20"
                                                          VerticalAlignment="Center"
                                                          Foreground="#F44336" />
                                <TextBlock Text="游客模式 - 功能受限"
                                           FontSize="14"
                                           Foreground="#F44336"
                                           VerticalAlignment="Center"
                                           Margin="8,0,0,0" />
                            </StackPanel>
                        </StackPanel>

                        <!-- 当前时间（居中） -->
                        <TextBlock Grid.Column="2"
                                   Text="{Binding CurrentTime}"
                                   FontSize="14"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}" />

                        <!-- 设备状态 -->
                        <StackPanel Grid.Column="3" 
                                                Orientation="Horizontal"
                                                VerticalAlignment="Center"
                                                Margin="16,0">
                                        <Ellipse Width="10" Height="10"
                                                 VerticalAlignment="Center"
                                                 Fill="{Binding DeviceStatusColor, Converter={StaticResource StringToColorBrushConverter}}" />
                                        <TextBlock Text="{Binding DeviceStatusText}"
                                                   FontSize="13"
                                                   VerticalAlignment="Center"
                                                   Margin="8,0,0,0"
                                                   Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}" />
                                    </StackPanel>

                                    <!-- 操作按钮 -->
                                    <StackPanel Grid.Column="4" 
                                                Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <!-- 切换患者按钮（非游客模式显示） -->
                            <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Content="切换患者"
                                    Command="{Binding SwitchPatientCommand}"
                                    Visibility="{Binding IsGuestMode, Converter={StaticResource BoolToVisConverter}, ConverterParameter=Inverse}"
                                    Margin="0,0,8,0"
                                    Height="32"
                                    Padding="16,0" />

                            <!-- 退出登录按钮 -->
                            <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Content="退出登录"
                                    Command="{Binding LogoutCommand}"
                                    Height="32"
                                    Padding="16,0"
                                    Foreground="#F44336"
                                    BorderBrush="#F44336" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 内容区域 -->
                <Border Grid.Row="1" 
                        Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                        Margin="16">
                    <Grid>
                        <!-- 内容占位 - 后续绑定到子视图 -->
                        <ContentControl Content="{Binding CurrentContent}">
                            <ContentControl.Style>
                                <Style TargetType="ContentControl">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentContent}" Value="{x:Null}">
                                            <Setter Property="Content">
                                                <Setter.Value>
                                                    <StackPanel HorizontalAlignment="Center" 
                                                                VerticalAlignment="Center">
                                                        <materialDesign:PackIcon Kind="ChartLine"
                                                                                  Width="64" Height="64"
                                                                                  HorizontalAlignment="Center"
                                                                                  Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}" />
                                                        <TextBlock Text="测量评估"
                                                                   FontSize="18"
                                                                   FontWeight="Medium"
                                                                   HorizontalAlignment="Center"
                                                                   Margin="0,16,0,0" />
                                                        <TextBlock Text="请选择左侧菜单开始操作"
                                                                   FontSize="14"
                                                                   Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}"
                                                                   HorizontalAlignment="Center"
                                                                   Margin="0,8,0,0" />
                                                    </StackPanel>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ContentControl.Style>
                        </ContentControl>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </materialDesign:DialogHost>
</UserControl>
