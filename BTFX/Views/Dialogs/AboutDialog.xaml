<UserControl x:Class="BTFX.Views.Dialogs.AboutDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BTFX.Views.Dialogs"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:common="clr-namespace:BTFX.Common"
             mc:Ignorable="d" 
             d:DesignWidth="400"
             MinWidth="350"
             MaxWidth="450">

    <materialDesign:Card Padding="32" 
                         UniformCornerRadius="8"
                         materialDesign:ElevationAssist.Elevation="Dp8">
        <Grid>
            <Grid.RowDefinitions>
                <!-- Logo -->
                <RowDefinition Height="Auto" />
                <!-- 应用名称 -->
                <RowDefinition Height="Auto" />
                <!-- 英文名称 -->
                <RowDefinition Height="Auto" />
                <!-- 版本号 -->
                <RowDefinition Height="Auto" />
                <!-- 分隔线 -->
                <RowDefinition Height="Auto" />
                <!-- 版权信息 -->
                <RowDefinition Height="Auto" />
                <!-- 关闭按钮 -->
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Logo -->
            <Border Grid.Row="0"
                    Width="80" Height="80"
                    CornerRadius="40"
                    Background="{DynamicResource MaterialDesign.Brush.Primary}"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,16">
                <materialDesign:PackIcon Kind="Walk"
                                          Width="48" Height="48"
                                          Foreground="White"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
            </Border>

            <!-- 应用名称（中文） -->
            <TextBlock Grid.Row="1"
                       Text="{x:Static common:Constants.APP_DISPLAY_NAME}"
                       FontSize="20"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,4" />

            <!-- 应用名称（英文） -->
            <TextBlock Grid.Row="2"
                       Text="{x:Static common:Constants.APP_DISPLAY_NAME_EN}"
                       FontSize="12"
                       Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,16" />

            <!-- 版本号 -->
            <StackPanel Grid.Row="3" 
                        HorizontalAlignment="Center"
                        Margin="0,0,0,16">
                <TextBlock FontSize="14"
                           HorizontalAlignment="Center">
                    <Run Text="版本: " Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}" />
                    <Run Text="{x:Static common:Constants.VERSION_FULL}" FontWeight="Medium" />
                </TextBlock>
                <TextBlock FontSize="12"
                           Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0">
                    <Run Text="内部版本: " />
                    <Run Text="{x:Static common:Constants.VERSION_INTERNAL}" />
                </TextBlock>
            </StackPanel>

            <!-- 分隔线 -->
            <Separator Grid.Row="4" Margin="0,0,0,16" />

            <!-- 版权信息 -->
            <StackPanel Grid.Row="5"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,24">
                <TextBlock Text="Copyright © 2024-2026"
                           FontSize="12"
                           Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="All Rights Reserved"
                           FontSize="12"
                           Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0" />
            </StackPanel>

            <!-- 关闭按钮 -->
            <Button Grid.Row="6"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Content="关闭"
                    Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                    HorizontalAlignment="Center"
                    MinWidth="120" />
        </Grid>
    </materialDesign:Card>
</UserControl>
