<UserControl
    x:Class="BTFX.Views.Dialogs.AboutDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:common="clr-namespace:BTFX.Common"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:BTFX.Views.Dialogs"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    MinWidth="350"
    MaxWidth="450"
    d:DesignWidth="400"
    mc:Ignorable="d">

    <materialDesign:Card
        Padding="32"
        materialDesign:ElevationAssist.Elevation="Dp8"
        UniformCornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <!--  Logo  -->
                <RowDefinition Height="Auto" />
                <!--  应用名称  -->
                <RowDefinition Height="Auto" />
                <!--  英文名称  -->
                <RowDefinition Height="Auto" />
                <!--  版本号  -->
                <RowDefinition Height="Auto" />
                <!--  分隔线  -->
                <RowDefinition Height="Auto" />
                <!--  版权信息  -->
                <RowDefinition Height="Auto" />
                <!--  关闭按钮  -->
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  Logo  -->
            <Border
                Grid.Row="0"
                Width="80"
                Height="80"
                Margin="0,0,0,16"
                HorizontalAlignment="Center"
                Background="{DynamicResource MaterialDesign.Brush.Primary}"
                CornerRadius="40">
                <materialDesign:PackIcon
                    Width="48"
                    Height="48"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Foreground="White"
                    Kind="Walk" />
            </Border>

            <!--  应用名称（中文）  -->
            <TextBlock
                Grid.Row="1"
                Margin="0,0,0,4"
                HorizontalAlignment="Center"
                FontSize="20"
                FontWeight="Bold"
                Text="{x:Static common:Constants.APP_DISPLAY_NAME}" />

            <!--  应用名称（英文）  -->
            <TextBlock
                Grid.Row="2"
                Margin="0,0,0,16"
                HorizontalAlignment="Center"
                FontSize="12"
                Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}"
                Text="{x:Static common:Constants.APP_DISPLAY_NAME_EN}" />

            <!--  版本号  -->
            <StackPanel
                Grid.Row="3"
                Margin="0,0,0,16"
                HorizontalAlignment="Center">
                <TextBlock HorizontalAlignment="Center" FontSize="14">
                    <Run Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}" Text="版本: " />
                    <Run FontWeight="Medium" Text="{x:Static common:Constants.VERSION_FULL}" />
                </TextBlock>
                <TextBlock
                    Margin="0,4,0,0"
                    HorizontalAlignment="Center"
                    FontSize="12"
                    Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}">
                    <Run Text="内部版本: " />
                    <Run Text="{x:Static common:Constants.VERSION_INTERNAL}" />
                </TextBlock>
            </StackPanel>

            <!--  分隔线  -->
            <Separator Grid.Row="4" Margin="0,0,0,16" />

            <!--  版权信息  -->
            <StackPanel
                Grid.Row="5"
                Margin="0,0,0,24"
                HorizontalAlignment="Center">
                <TextBlock
                    HorizontalAlignment="Center"
                    FontSize="12"
                    Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}"
                    Text="Copyright © 2024-2026" />
                <TextBlock
                    Margin="0,4,0,0"
                    HorizontalAlignment="Center"
                    FontSize="12"
                    Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}"
                    Text="All Rights Reserved" />
            </StackPanel>

            <!--  关闭按钮  -->
            <Button
                Grid.Row="6"
                MinWidth="120"
                HorizontalAlignment="Center"
                Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                Content="关闭"
                Style="{StaticResource MaterialDesignRaisedButton}" />
        </Grid>
    </materialDesign:Card>
</UserControl>
