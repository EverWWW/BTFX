<UserControl
    x:Class="BTFX.Views.Dialogs.ConfirmDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:BTFX.Views.Dialogs"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    MinWidth="300"
    MaxWidth="500"
    d:DesignWidth="400"
    mc:Ignorable="d">

    <materialDesign:Card
        Padding="24"
        materialDesign:ElevationAssist.Elevation="Dp8"
        UniformCornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <!--  标题  -->
                <RowDefinition Height="Auto" />
                <!--  消息内容  -->
                <RowDefinition Height="Auto" />
                <!--  按钮区域  -->
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  标题  -->
            <TextBlock
                Grid.Row="0"
                Margin="0,0,0,16"
                FontSize="18"
                FontWeight="Medium"
                Text="{Binding Title}" />

            <!--  消息内容  -->
            <TextBlock
                Grid.Row="1"
                Margin="0,0,0,24"
                FontSize="14"
                Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}"
                Text="{Binding Message}"
                TextWrapping="Wrap" />

            <!--  按钮区域  -->
            <StackPanel
                Grid.Row="2"
                HorizontalAlignment="Right"
                Orientation="Horizontal">
                <!--  取消按钮  -->
                <Button
                    MinWidth="80"
                    Margin="0,0,8,0"
                    Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                    CommandParameter="{x:Static local:ConfirmDialog.FalseValue}"
                    Content="否"
                    Style="{StaticResource MaterialDesignFlatButton}" />

                <!--  确认按钮  -->
                <Button
                    MinWidth="80"
                    Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                    CommandParameter="{x:Static local:ConfirmDialog.TrueValue}"
                    Content="是"
                    Style="{StaticResource MaterialDesignRaisedButton}" />
            </StackPanel>
        </Grid>
    </materialDesign:Card>
</UserControl>
