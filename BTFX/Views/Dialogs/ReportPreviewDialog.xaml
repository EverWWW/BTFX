<UserControl
    x:Class="BTFX.Views.Dialogs.ReportPreviewDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:BTFX.ViewModels"
    d:DataContext="{d:DesignInstance Type=vm:ReportPreviewDialogViewModel}"
    Background="Transparent"
    mc:Ignorable="d">

    <UserControl.Resources>
        <SolidColorBrush x:Key="PreviewMaskBrush" Color="#8C0D1B2A" />
        <SolidColorBrush x:Key="PreviewPanelBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="PreviewHeaderBrush" Color="#F8FAFD" />
        <SolidColorBrush x:Key="PreviewBorderBrush" Color="#D9E3EE" />
        <SolidColorBrush x:Key="PreviewCardBorderBrush" Color="#E5EBF3" />
        <SolidColorBrush x:Key="PreviewCardBackgroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="PreviewMutedBrush" Color="#7B8794" />
        <SolidColorBrush x:Key="PreviewTextBrush" Color="#223045" />
        <SolidColorBrush x:Key="PreviewAccentBrush" Color="#403B5B" />
        <SolidColorBrush x:Key="PreviewHighlightBrush" Color="#EEF3F9" />
        <SolidColorBrush x:Key="PreviewSoftBrush" Color="#F8FAFD" />
        <SolidColorBrush x:Key="PreviewPrimaryButtonBrush" Color="#403B5B" />
        <SolidColorBrush x:Key="PreviewSecondaryButtonBorderBrush" Color="#B8C4D3" />

        <Style x:Key="PreviewTitleTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="FontSize" Value="30" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource PreviewTextBrush}" />
        </Style>

        <Style x:Key="PreviewSectionTitleTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource PreviewTextBrush}" />
        </Style>

        <Style x:Key="PreviewHintTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="{StaticResource PreviewMutedBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="PreviewCardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PreviewCardBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PreviewCardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="18,16" />
        </Style>

        <Style x:Key="PreviewChipTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Foreground" Value="{StaticResource PreviewAccentBrush}" />
        </Style>

        <Style x:Key="PreviewMetricLabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{StaticResource PreviewMutedBrush}" />
        </Style>

        <Style x:Key="PreviewMetricValueStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource PreviewTextBrush}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="PreviewCloseButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="44" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="ButtonBorder"
                            Background="{TemplateBinding Background}"
                            CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#FFEFF3F8" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#FFDDE5EF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style
            x:Key="PreviewSecondaryButtonStyle"
            BasedOn="{StaticResource SecondaryButton}"
            TargetType="Button">
            <Setter Property="Width" Value="176" />
            <Setter Property="Height" Value="46" />
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="BorderBrush" Value="{StaticResource PreviewSecondaryButtonBorderBrush}" />
            <Setter Property="Foreground" Value="{StaticResource PreviewAccentBrush}" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="12" />
        </Style>

        <Style
            x:Key="PreviewPrimaryButtonStyle"
            BasedOn="{StaticResource PrimaryButton}"
            TargetType="Button">
            <Setter Property="Width" Value="176" />
            <Setter Property="Height" Value="46" />
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Background" Value="{StaticResource PreviewPrimaryButtonBrush}" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="12" />
        </Style>

        <Style
            x:Key="PreviewSurfaceBorderStyle"
            BasedOn="{StaticResource DialogSurfaceBorderStyle}"
            TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PreviewPanelBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect
                        BlurRadius="30"
                        Direction="270"
                        Opacity="0.10"
                        ShadowDepth="0"
                        Color="#1F2A37" />
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="Transparent">
        <Border Background="{StaticResource PreviewMaskBrush}" />

        <Border
            Width="1440"
            MaxWidth="1520"
            MaxHeight="960"
            Margin="48"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="{StaticResource PreviewPanelBrush}"
            CornerRadius="24"
            Style="{StaticResource PreviewSurfaceBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border
                    Grid.Row="0"
                    Padding="28,10,28,10"
                    Background="{StaticResource PreviewHeaderBrush}"
                    BorderBrush="{StaticResource PreviewBorderBrush}"
                    BorderThickness="0,0,0,1"
                    CornerRadius="24,24,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                            <TextBlock Style="{StaticResource PreviewTitleTextStyle}" Text="报告预览" />
                            <TextBlock
                                Margin="14,0,0,0"
                                VerticalAlignment="Center"
                                Foreground="{StaticResource PreviewTextBrush}"
                                Style="{StaticResource PreviewHintTextStyle}">
                                <Run Text="标题 " />
                                <Run Text="{Binding ReportTitle, Mode=OneWay, TargetNullValue=步态分析报告}" />
                                <Run Text="  ·  编号 " />
                                <Run Text="{Binding ReportNumber, Mode=OneWay, TargetNullValue=RPT-20250218-001}" />
                                <Run Text="  ·  " />
                                <Run Text="{Binding PreviewSource, Mode=OneWay, TargetNullValue=AnalysisResult #1024}" />
                            </TextBlock>
                        </StackPanel>

                        <Button
                            Grid.Column="1"
                            Command="{Binding CloseCommand}"
                            Style="{StaticResource PreviewCloseButtonStyle}">
                            <materialDesign:PackIcon
                                Width="22"
                                Height="22"
                                Foreground="{StaticResource PreviewTextBrush}"
                                Kind="Close" />
                        </Button>
                    </Grid>
                </Border>

                <Grid Grid.Row="1" Margin="28,24,28,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="20" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Padding="16,12" Style="{StaticResource PreviewCardBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                <Border
                                    Padding="12,6"
                                    Background="#FFF7FAFD"
                                    BorderBrush="#FFDDE7F0"
                                    BorderThickness="1"
                                    CornerRadius="999">
                                    <TextBlock Style="{StaticResource PreviewChipTextStyle}" Text="{Binding IncludedSectionsSummary, TargetNullValue=时空参数、运动学摘要、质量控制}" />
                                </Border>
                                <Border
                                    Margin="10,0,0,0"
                                    Padding="12,6"
                                    Background="#FFF2F6FB"
                                    BorderBrush="#FFD7E3F2"
                                    BorderThickness="1"
                                    CornerRadius="999">
                                    <TextBlock Style="{StaticResource PreviewChipTextStyle}" Text="{Binding UpdatedAtDisplayWithLabel, TargetNullValue=最近更新时间：2025-02-18 14:35}" />
                                </Border>
                                <Border
                                    Margin="10,0,0,0"
                                    Padding="12,6"
                                    Background="#FFF7FAFD"
                                    BorderBrush="#FFDDE7F0"
                                    BorderThickness="1"
                                    CornerRadius="999">
                                    <TextBlock Style="{StaticResource PreviewChipTextStyle}" Text="{Binding PreviewStatus, TargetNullValue=已生成当前草稿的报告预览，可在返回配置后继续调整。}" />
                                </Border>
                            </StackPanel>

                            <TextBlock
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                Style="{StaticResource PreviewHintTextStyle}"
                                Text="覆盖式承载壳体，后续可与分析详情页在同一层级容器内平滑切换。" />
                        </Grid>
                    </Border>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="320" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource PreviewCardBorderStyle}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource PreviewSectionTitleTextStyle}" Text="预览摘要" />
                                    <TextBlock
                                        Margin="0,8,0,0"
                                        Style="{StaticResource PreviewHintTextStyle}"
                                        Text="当前摘要区压缩为轻量侧栏，用于承载报告基础信息、包含项和状态，不再占用过大的横向空间。" />

                                    <Border Margin="0,16,0,0" Style="{StaticResource PreviewCardBorderStyle}">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource PreviewMetricLabelStyle}" Text="报告标题" />
                                            <TextBlock
                                                Margin="0,6,0,0"
                                                Style="{StaticResource PreviewMetricValueStyle}"
                                                Text="{Binding ReportTitle}" />
                                        </StackPanel>
                                    </Border>

                                    <Border Margin="0,12,0,0" Style="{StaticResource PreviewCardBorderStyle}">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource PreviewMetricLabelStyle}" Text="报告编号" />
                                            <TextBlock
                                                Margin="0,6,0,0"
                                                Style="{StaticResource PreviewMetricValueStyle}"
                                                Text="{Binding ReportNumber}" />
                                        </StackPanel>
                                    </Border>

                                    <Border Margin="0,12,0,0" Style="{StaticResource PreviewCardBorderStyle}">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource PreviewMetricLabelStyle}" Text="预览来源" />
                                            <TextBlock
                                                Margin="0,6,0,0"
                                                Style="{StaticResource PreviewMetricValueStyle}"
                                                Text="{Binding PreviewSource}"
                                                TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>

                                    <Border Margin="0,12,0,0" Style="{StaticResource PreviewCardBorderStyle}">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource PreviewMetricLabelStyle}" Text="包含项" />
                                            <TextBlock
                                                Margin="0,6,0,0"
                                                FontSize="15"
                                                Style="{StaticResource PreviewMetricValueStyle}"
                                                Text="{Binding IncludedSectionsSummary}"
                                                TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>

                                    <Border
                                        Margin="0,12,0,0"
                                        Padding="16,14"
                                        Background="{StaticResource PreviewHighlightBrush}"
                                        BorderBrush="#FFD8E2EE"
                                        BorderThickness="1"
                                        CornerRadius="16">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource PreviewMetricLabelStyle}" Text="状态说明" />
                                            <TextBlock
                                                Margin="0,8,0,0"
                                                Foreground="{StaticResource PreviewTextBrush}"
                                                Style="{StaticResource PreviewHintTextStyle}"
                                                Text="{Binding PreviewStatus}"
                                                TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource PreviewCardBorderStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="16" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <TextBlock Style="{StaticResource PreviewSectionTitleTextStyle}" Text="文档预览" />
                                        <TextBlock
                                            Margin="0,8,0,0"
                                            Style="{StaticResource PreviewHintTextStyle}"
                                            Text="保留正式文档预览区作为主内容焦点，后续可继续扩展打印、页码跳转与模板切换能力。" />
                                    </StackPanel>

                                    <Border
                                        Grid.Column="1"
                                        Padding="12,8"
                                        Background="{StaticResource PreviewSoftBrush}"
                                        BorderBrush="#FFDDE7F0"
                                        BorderThickness="1"
                                        CornerRadius="12">
                                        <TextBlock Style="{StaticResource PreviewChipTextStyle}" Text="FlowDocument 预览区域" />
                                    </Border>
                                </Grid>

                                <Border
                                    Grid.Row="2"
                                    Background="#FFFFFF"
                                    BorderBrush="#FFD8E2EE"
                                    BorderThickness="1"
                                    CornerRadius="18">
                                    <FlowDocumentScrollViewer
                                        Margin="8"
                                        Document="{Binding PreviewDocument}"
                                        IsToolBarVisible="True"
                                        VerticalScrollBarVisibility="Auto" />
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

                <Border
                    Grid.Row="2"
                    Padding="0,20,0,24"
                    Background="#F8FAFD"
                    BorderBrush="{StaticResource PreviewBorderBrush}"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,24,24">
                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                        <Button
                            Margin="0,0,16,0"
                            Command="{Binding BackToConfigCommand}"
                            Content="{DynamicResource AnalysisDetail.ReportPreview.BackToConfig}"
                            Style="{StaticResource PreviewSecondaryButtonStyle}" />
                        <Button
                            Command="{Binding CloseCommand}"
                            Content="{DynamicResource AnalysisDetail.ReportPreview.Close}"
                            Style="{StaticResource PreviewPrimaryButtonStyle}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
