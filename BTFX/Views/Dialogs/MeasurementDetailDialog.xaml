<Window
    x:Class="BTFX.Views.Dialogs.MeasurementDetailDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:BTFX.Views.Dialogs"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:vm="clr-namespace:BTFX.ViewModels"
    Title="测量详情"
    Width="700"
    Height="600"
    d:DataContext="{d:DesignInstance Type=vm:MeasurementDetailViewModel}"
    ResizeMode="NoResize"
    Style="{StaticResource MaterialDesignWindow}"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  标题  -->
        <TextBlock
            Grid.Row="0"
            Margin="0,0,0,16"
            FontSize="20"
            FontWeight="Bold"
            Text="测量详情" />

        <!--  内容区域  -->
        <ScrollViewer
            Grid.Row="1"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!--  患者信息  -->
                <md:Card Margin="0,0,0,16" Padding="16">
                    <StackPanel>
                        <TextBlock
                            Margin="0,0,0,12"
                            FontSize="16"
                            FontWeight="Medium"
                            Text="患者信息" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel
                                Grid.Row="0"
                                Grid.Column="0"
                                Margin="0,0,0,8"
                                Orientation="Horizontal">
                                <TextBlock
                                    Width="60"
                                    Foreground="{DynamicResource MaterialDesignBodyLight}"
                                    Text="姓名：" />
                                <TextBlock FontWeight="Medium" Text="{Binding PatientName}" />
                            </StackPanel>

                            <StackPanel
                                Grid.Row="0"
                                Grid.Column="1"
                                Margin="0,0,0,8"
                                Orientation="Horizontal">
                                <TextBlock
                                    Width="60"
                                    Foreground="{DynamicResource MaterialDesignBodyLight}"
                                    Text="性别：" />
                                <TextBlock Text="{Binding Gender}" />
                            </StackPanel>

                            <StackPanel
                                Grid.Row="1"
                                Grid.Column="0"
                                Margin="0,0,0,8"
                                Orientation="Horizontal">
                                <TextBlock
                                    Width="60"
                                    Foreground="{DynamicResource MaterialDesignBodyLight}"
                                    Text="年龄：" />
                                <TextBlock Text="{Binding Age}" />
                            </StackPanel>

                            <StackPanel
                                Grid.Row="1"
                                Grid.Column="1"
                                Margin="0,0,0,8"
                                Orientation="Horizontal">
                                <TextBlock
                                    Width="60"
                                    Foreground="{DynamicResource MaterialDesignBodyLight}"
                                    Text="电话：" />
                                <TextBlock Text="{Binding Phone}" />
                            </StackPanel>

                            <StackPanel
                                Grid.Row="2"
                                Grid.Column="0"
                                Grid.ColumnSpan="2"
                                Orientation="Horizontal">
                                <TextBlock
                                    Width="60"
                                    Foreground="{DynamicResource MaterialDesignBodyLight}"
                                    Text="证件号：" />
                                <TextBlock Text="{Binding IdNumber}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </md:Card>

                <!--  测量信息  -->
                <md:Card Margin="0,0,0,16" Padding="16">
                    <StackPanel>
                        <TextBlock
                            Margin="0,0,0,12"
                            FontSize="16"
                            FontWeight="Medium"
                            Text="测量信息" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel
                                Grid.Row="0"
                                Grid.Column="0"
                                Margin="0,0,0,8"
                                Orientation="Horizontal">
                                <TextBlock
                                    Width="70"
                                    Foreground="{DynamicResource MaterialDesignBodyLight}"
                                    Text="测量日期：" />
                                <TextBlock Text="{Binding MeasurementDate}" />
                            </StackPanel>

                            <StackPanel
                                Grid.Row="0"
                                Grid.Column="1"
                                Margin="0,0,0,8"
                                Orientation="Horizontal">
                                <TextBlock
                                    Width="70"
                                    Foreground="{DynamicResource MaterialDesignBodyLight}"
                                    Text="操作员：" />
                                <TextBlock Text="{Binding OperatorName}" />
                            </StackPanel>

                            <StackPanel
                                Grid.Row="1"
                                Grid.Column="0"
                                Margin="0,0,0,8"
                                Orientation="Horizontal">
                                <TextBlock
                                    Width="70"
                                    Foreground="{DynamicResource MaterialDesignBodyLight}"
                                    Text="测量状态：" />
                                <Border
                                    Padding="8,2"
                                    Background="{Binding StatusColor}"
                                    CornerRadius="4">
                                    <TextBlock Foreground="White" Text="{Binding Status}" />
                                </Border>
                            </StackPanel>

                            <StackPanel
                                Grid.Row="1"
                                Grid.Column="1"
                                Orientation="Horizontal">
                                <TextBlock
                                    Width="70"
                                    Foreground="{DynamicResource MaterialDesignBodyLight}"
                                    Text="测量时长：" />
                                <TextBlock Text="{Binding Duration}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </md:Card>

                <!--  步态参数  -->
                <md:Card Margin="0,0,0,16" Padding="16">
                    <StackPanel>
                        <TextBlock
                            Margin="0,0,0,12"
                            FontSize="16"
                            FontWeight="Medium"
                            Text="步态参数" />

                        <!--  有数据时显示  -->
                        <Grid Visibility="{Binding HasGaitParameters, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel
                                Grid.Row="0"
                                Grid.Column="0"
                                Margin="0,0,0,8"
                                Orientation="Horizontal">
                                <TextBlock
                                    Width="100"
                                    Foreground="{DynamicResource MaterialDesignBodyLight}"
                                    Text="左脚步幅(cm)：" />
                                <TextBlock FontWeight="Medium" Text="{Binding StrideLengthLeft}" />
                            </StackPanel>

                            <StackPanel
                                Grid.Row="0"
                                Grid.Column="1"
                                Margin="0,0,0,8"
                                Orientation="Horizontal">
                                <TextBlock
                                    Width="100"
                                    Foreground="{DynamicResource MaterialDesignBodyLight}"
                                    Text="右脚步幅(cm)：" />
                                <TextBlock FontWeight="Medium" Text="{Binding StrideLengthRight}" />
                            </StackPanel>

                            <StackPanel
                                Grid.Row="1"
                                Grid.Column="0"
                                Margin="0,0,0,8"
                                Orientation="Horizontal">
                                <TextBlock
                                    Width="100"
                                    Foreground="{DynamicResource MaterialDesignBodyLight}"
                                    Text="步频(步/分)：" />
                                <TextBlock FontWeight="Medium" Text="{Binding Cadence}" />
                            </StackPanel>

                            <StackPanel
                                Grid.Row="1"
                                Grid.Column="1"
                                Margin="0,0,0,8"
                                Orientation="Horizontal">
                                <TextBlock
                                    Width="100"
                                    Foreground="{DynamicResource MaterialDesignBodyLight}"
                                    Text="步速(m/s)：" />
                                <TextBlock FontWeight="Medium" Text="{Binding Velocity}" />
                            </StackPanel>

                            <StackPanel
                                Grid.Row="2"
                                Grid.Column="0"
                                Margin="0,0,0,8"
                                Orientation="Horizontal">
                                <TextBlock
                                    Width="100"
                                    Foreground="{DynamicResource MaterialDesignBodyLight}"
                                    Text="左脚支撑相(%)：" />
                                <TextBlock FontWeight="Medium" Text="{Binding StancePhaseLeft}" />
                            </StackPanel>

                            <StackPanel
                                Grid.Row="2"
                                Grid.Column="1"
                                Margin="0,0,0,8"
                                Orientation="Horizontal">
                                <TextBlock
                                    Width="100"
                                    Foreground="{DynamicResource MaterialDesignBodyLight}"
                                    Text="右脚支撑相(%)：" />
                                <TextBlock FontWeight="Medium" Text="{Binding StancePhaseRight}" />
                            </StackPanel>

                            <StackPanel
                                Grid.Row="3"
                                Grid.Column="0"
                                Orientation="Horizontal">
                                <TextBlock
                                    Width="100"
                                    Foreground="{DynamicResource MaterialDesignBodyLight}"
                                    Text="双支撑时间(%)：" />
                                <TextBlock FontWeight="Medium" Text="{Binding DoubleSupport}" />
                            </StackPanel>

                            <StackPanel
                                Grid.Row="3"
                                Grid.Column="1"
                                Orientation="Horizontal">
                                <TextBlock
                                    Width="100"
                                    Foreground="{DynamicResource MaterialDesignBodyLight}"
                                    Text="步宽(cm)：" />
                                <TextBlock FontWeight="Medium" Text="{Binding StepWidth}" />
                            </StackPanel>
                        </Grid>

                        <!--  无数据时显示  -->
                        <TextBlock
                            HorizontalAlignment="Center"
                            Foreground="{DynamicResource MaterialDesignBodyLight}"
                            Text="暂无步态参数数据"
                            Visibility="{Binding HasGaitParameters, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverse}" />
                    </StackPanel>
                </md:Card>

                <!--  视频回放区域（占位）  -->
                <md:Card Margin="0,0,0,16" Padding="16">
                    <StackPanel>
                        <TextBlock
                            Margin="0,0,0,12"
                            FontSize="16"
                            FontWeight="Medium"
                            Text="视频回放" />
                        <Border
                            Height="150"
                            Background="{DynamicResource MaterialDesignCardBackground}"
                            BorderBrush="{DynamicResource MaterialDesignDivider}"
                            BorderThickness="1"
                            CornerRadius="4">
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Foreground="{DynamicResource MaterialDesignBodyLight}"
                                Text="视频回放功能开发中..." />
                        </Border>
                    </StackPanel>
                </md:Card>

                <!--  关节点轨迹区域（占位）  -->
                <md:Card Padding="16">
                    <StackPanel>
                        <TextBlock
                            Margin="0,0,0,12"
                            FontSize="16"
                            FontWeight="Medium"
                            Text="关节点轨迹" />
                        <Border
                            Height="150"
                            Background="{DynamicResource MaterialDesignCardBackground}"
                            BorderBrush="{DynamicResource MaterialDesignDivider}"
                            BorderThickness="1"
                            CornerRadius="4">
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Foreground="{DynamicResource MaterialDesignBodyLight}"
                                Text="轨迹显示功能开发中..." />
                        </Border>
                    </StackPanel>
                </md:Card>
            </StackPanel>
        </ScrollViewer>

        <!--  底部按钮  -->
        <StackPanel
            Grid.Row="2"
            Margin="0,16,0,0"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                Margin="0,0,8,0"
                Command="{Binding ExportCommand}"
                Content="导出"
                Style="{StaticResource MaterialDesignOutlinedButton}"
                Visibility="{Binding CanExport, Converter={StaticResource BooleanToVisibilityConverter}}" />
            <Button
                Command="{Binding CloseCommand}"
                Content="关闭"
                IsDefault="True"
                Style="{StaticResource MaterialDesignRaisedButton}" />
        </StackPanel>
    </Grid>
</Window>
