<UserControl
    x:Class="BTFX.Views.Dialogs.MeasurementDetailDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:BTFX.ViewModels"
    Background="Transparent"
    d:DataContext="{d:DesignInstance Type=vm:GaitAnalysisDetailViewModel}"
    mc:Ignorable="d">

    <UserControl.Resources>
        <SolidColorBrush x:Key="OverlayMaskBrush" Color="#8C0D1B2A" />
        <SolidColorBrush x:Key="OverlayPanelBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="OverlayHeaderBrush" Color="#F8FAFD" />
        <SolidColorBrush x:Key="OverlayBorderBrush" Color="#D9E3EE" />
        <SolidColorBrush x:Key="OverlayCardBorderBrush" Color="#E5EBF3" />
        <SolidColorBrush x:Key="OverlayCardBackgroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="OverlayMutedBrush" Color="#7B8794" />
        <SolidColorBrush x:Key="OverlayTextBrush" Color="#223045" />
        <SolidColorBrush x:Key="OverlayAccentBrush" Color="#403B5B" />
        <SolidColorBrush x:Key="OverlayAssistBrush" Color="#E9EEF5" />
        <SolidColorBrush x:Key="OverlayHighlightBrush" Color="#EEF3F9" />
        <SolidColorBrush x:Key="OverlayPreviewBrush" Color="#EAF0F8" />
        <SolidColorBrush x:Key="OverlayPrimaryButtonBrush" Color="#403B5B" />
        <SolidColorBrush x:Key="OverlaySecondaryButtonBorderBrush" Color="#B8C4D3" />
        <Style BasedOn="{StaticResource DialogLightScrollBarStyle}" TargetType="ScrollBar" />

        <Style x:Key="OverlayTitleTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="FontSize" Value="30" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource OverlayTextBrush}" />
        </Style>

        <Style x:Key="OverlaySubtitleTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="{StaticResource OverlayMutedBrush}" />
        </Style>

        <Style x:Key="InfoLabelTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Foreground" Value="{StaticResource OverlayMutedBrush}" />
        </Style>

        <Style x:Key="InfoValueTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource OverlayTextBrush}" />
        </Style>

        <Style x:Key="SectionTitleTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource OverlayTextBrush}" />
        </Style>

        <Style x:Key="SectionHintTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="{StaticResource OverlayMutedBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource OverlayCardBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource OverlayCardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="20" />
        </Style>

        <Style x:Key="CompactInfoCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFF8FAFD" />
            <Setter Property="BorderBrush" Value="{StaticResource OverlayCardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="12,10" />
        </Style>

        <Style x:Key="CompactInfoLabelTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{StaticResource OverlayMutedBrush}" />
        </Style>

        <Style x:Key="CompactInfoValueTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource OverlayTextBrush}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="MetricCardBorderStyle" BasedOn="{StaticResource CardBorderStyle}" TargetType="Border">
            <Setter Property="MinHeight" Value="116" />
        </Style>

        <Style x:Key="MetricLabelTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{StaticResource OverlayMutedBrush}" />
        </Style>

        <Style x:Key="MetricValueTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="FontSize" Value="28" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource OverlayTextBrush}" />
        </Style>

        <Style x:Key="AnalysisTabHeaderTextStyle" TargetType="TextBlock">
            <Setter Property="Width" Value="172" />
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Foreground" Value="{StaticResource OverlayTextBrush}" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>

        <Style x:Key="AnalysisTabItemStyle" TargetType="TabItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Background="Transparent">
                            <Grid Width="172" SnapsToDevicePixels="True">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="44" />
                                    <RowDefinition Height="4" />
                                </Grid.RowDefinitions>
                                <Border
                                    x:Name="HeaderBackground"
                                    Grid.Row="0"
                                    Margin="0,0,0,8"
                                    Background="Transparent"
                                    CornerRadius="12">
                                    <ContentPresenter
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        ContentSource="Header" />
                                </Border>
                                <Border
                                    x:Name="HeaderUnderline"
                                    Grid.Row="1"
                                    Height="4"
                                    Background="#E4004A"
                                    CornerRadius="2"
                                    Opacity="0" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="HeaderBackground" Property="Background" Value="#FFF3F5F8" />
                                <Setter TargetName="HeaderUnderline" Property="Opacity" Value="1" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HeaderBackground" Property="Background" Value="#FFF7F9FC" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AnalysisTabControlStyle" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource AnalysisTabItemStyle}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid KeyboardNavigation.TabNavigation="Local">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0">
                                <Border
                                    Height="1"
                                    Margin="0,0,0,0"
                                    VerticalAlignment="Bottom"
                                    Background="#DCE4EE" />
                                <TabPanel
                                    x:Name="HeaderPanel"
                                    Margin="0,0,0,0"
                                    IsItemsHost="True"
                                    KeyboardNavigation.TabIndex="1" />
                            </Grid>
                            <Border
                                Grid.Row="1"
                                Margin="0,20,0,0"
                                Background="Transparent"
                                KeyboardNavigation.TabIndex="2">
                                <ContentPresenter
                                    x:Name="PART_SelectedContentHost"
                                    ContentSource="SelectedContent"
                                    SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OverlayCloseButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="44" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="ButtonBorder"
                            Background="{TemplateBinding Background}"
                            CornerRadius="14">
                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#FFEFF3F8" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#FFDDE5EF" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FooterSecondaryActionStyle" BasedOn="{StaticResource SecondaryButton}" TargetType="Button">
            <Setter Property="Width" Value="144" />
            <Setter Property="Height" Value="46" />
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="BorderBrush" Value="{StaticResource OverlaySecondaryButtonBorderBrush}" />
            <Setter Property="Foreground" Value="{StaticResource OverlayAccentBrush}" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="12" />
        </Style>

        <Style x:Key="FooterPrimaryActionStyle" BasedOn="{StaticResource PrimaryButton}" TargetType="Button">
            <Setter Property="Width" Value="144" />
            <Setter Property="Height" Value="46" />
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="Background" Value="{StaticResource OverlayPrimaryButtonBrush}" />
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="12" />
        </Style>

        <Style x:Key="OverlaySurfaceBorderStyle" BasedOn="{StaticResource DialogSurfaceBorderStyle}" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource OverlayPanelBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect
                        BlurRadius="42"
                        Direction="270"
                        Opacity="0.07"
                        ShadowDepth="0"
                        Color="#1F2A37" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HeaderMetaTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="{StaticResource OverlayMutedBrush}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="HeaderChipBorderStyle" TargetType="Border">
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#FFF7FAFD" />
            <Setter Property="BorderBrush" Value="{StaticResource OverlayCardBorderBrush}" />
        </Style>

        <Style x:Key="HeaderChipTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource OverlayAccentBrush}" />
        </Style>
    </UserControl.Resources>

    <Grid Background="Transparent">
        <Border Background="{StaticResource OverlayMaskBrush}" />

        <Border
            Width="1440"
            MaxWidth="1520"
            MaxHeight="960"
            Margin="2"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="{StaticResource OverlayPanelBrush}"
            CornerRadius="2"
            Style="{StaticResource OverlaySurfaceBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border
                    Grid.Row="0"
                    Padding="28,16,28,16"
                    Background="{StaticResource OverlayHeaderBrush}"
                    BorderBrush="{StaticResource OverlayBorderBrush}"
                    BorderThickness="0,0,0,1"
                    CornerRadius="24,24,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Style="{StaticResource OverlayTitleTextStyle}" Text="分析结果详情" />
                            <WrapPanel Margin="0,8,0,0">
                                <TextBlock Style="{StaticResource HeaderMetaTextStyle}">
                                    <Run Text="患者 " />
                                    <Run Text="{Binding PatientName, Mode=OneWay, TargetNullValue=张三}" />
                                </TextBlock>
                                <TextBlock Margin="16,0,0,0" Style="{StaticResource HeaderMetaTextStyle}">
                                    <Run Text="编号 " />
                                    <Run Text="{Binding PatientCode, Mode=OneWay, TargetNullValue=P-2025-0018}" />
                                </TextBlock>
                                <TextBlock Margin="16,0,0,0" Style="{StaticResource HeaderMetaTextStyle}">
                                    <Run Text="测量类型 " />
                                    <Run Text="{Binding MeasurementTypeDisplay, Mode=OneWay, TargetNullValue=步态评估}" />
                                </TextBlock>
                                <TextBlock Margin="16,0,0,0" Style="{StaticResource HeaderMetaTextStyle}">
                                    <Run Text="测量时间 " />
                                    <Run Text="{Binding MeasurementDate, Mode=OneWay, TargetNullValue=2025-02-18 14:26}" />
                                </TextBlock>
                            </WrapPanel>
                        </StackPanel>

                        <WrapPanel
                            Grid.Column="1"
                            Margin="24,0,16,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                            <Border
                                Padding="12,6"
                                Margin="0,0,10,0"
                                Background="{Binding AnalysisStatusColor, TargetNullValue=#4CAF50}"
                                CornerRadius="999">
                                <TextBlock
                                    Style="{StaticResource HeaderChipTextStyle}"
                                    Foreground="White"
                                    Text="{Binding AnalysisStatusText, TargetNullValue=分析成功}" />
                            </Border>
                            <Border Style="{StaticResource HeaderChipBorderStyle}">
                                <TextBlock
                                    Style="{StaticResource HeaderChipTextStyle}"
                                    Text="{Binding TaskStatusDisplay, TargetNullValue=已完成}" />
                            </Border>
                            <Border Style="{StaticResource HeaderChipBorderStyle}">
                                <TextBlock
                                    Style="{StaticResource HeaderChipTextStyle}"
                                    Text="{Binding QualityGradeDisplay, TargetNullValue=A级}" />
                            </Border>
                        </WrapPanel>

                        <Button
                            Grid.Column="2"
                            Command="{Binding CloseCommand}"
                            Style="{StaticResource OverlayCloseButtonStyle}">
                            <materialDesign:PackIcon
                                Width="22"
                                Height="22"
                                Foreground="{StaticResource OverlayTextBrush}"
                                Kind="Close" />
                        </Button>
                    </Grid>
                </Border>

                <Grid Grid.Row="1" Margin="28,20,28,0">
                    <Border Style="{StaticResource CardBorderStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="2" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                
                            </Grid>

                            <TabControl Grid.Row="2" Style="{StaticResource AnalysisTabControlStyle}">
                                <TabItem>
                                    <TabItem.Header>
                                        <TextBlock Style="{StaticResource AnalysisTabHeaderTextStyle}" Text="总体情况页" />
                                    </TabItem.Header>

                                    <ScrollViewer Style="{StaticResource DialogLightweightScrollViewerStyle}">
                                        <StackPanel>
                                            <UniformGrid Columns="6" Margin="0,0,0,20">
                                                <Border Margin="0,0,14,0" Style="{StaticResource MetricCardBorderStyle}">
                                                    <StackPanel>
                                                        <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="平均步速" />
                                                        <TextBlock
                                                            Margin="0,10,0,0"
                                                            Style="{StaticResource MetricValueTextStyle}"
                                                            Text="{Binding GaitSpeedDisplay, TargetNullValue=0.96 m/s}" />
                                                    </StackPanel>
                                                </Border>
                                                <Border Margin="0,0,14,0" Style="{StaticResource MetricCardBorderStyle}">
                                                    <StackPanel>
                                                        <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="平均步频" />
                                                        <TextBlock
                                                            Margin="0,10,0,0"
                                                            Style="{StaticResource MetricValueTextStyle}"
                                                            Text="{Binding CadenceDisplay, TargetNullValue=104 步/分}" />
                                                    </StackPanel>
                                                </Border>
                                                <Border Margin="0,0,14,0" Style="{StaticResource MetricCardBorderStyle}">
                                                    <StackPanel>
                                                        <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="平均步长" />
                                                        <TextBlock
                                                            Margin="0,10,0,0"
                                                            Style="{StaticResource MetricValueTextStyle}"
                                                            Text="{Binding StepLengthDisplay, TargetNullValue=0.58 m}" />
                                                    </StackPanel>
                                                </Border>
                                                <Border Margin="0,0,14,0" Style="{StaticResource MetricCardBorderStyle}">
                                                    <StackPanel>
                                                        <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="步态周期" />
                                                        <TextBlock
                                                            Margin="0,10,0,0"
                                                            Style="{StaticResource MetricValueTextStyle}"
                                                            Text="{Binding GaitCycleDisplay, TargetNullValue=1.13 s}" />
                                                    </StackPanel>
                                                </Border>
                                                <Border Margin="0,0,14,0" Style="{StaticResource MetricCardBorderStyle}">
                                                    <StackPanel>
                                                        <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="有效周期数" />
                                                        <TextBlock
                                                            Margin="0,10,0,0"
                                                            Style="{StaticResource MetricValueTextStyle}"
                                                            Text="18" />
                                                    </StackPanel>
                                                </Border>
                                                <Border Style="{StaticResource MetricCardBorderStyle}">
                                                    <StackPanel>
                                                        <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="质量提示" />
                                                        <TextBlock
                                                            Margin="0,10,0,0"
                                                            Style="{StaticResource MetricValueTextStyle}"
                                                            FontSize="22"
                                                            Text="{Binding QualityGradeDisplay, TargetNullValue=A级}" />
                                                    </StackPanel>
                                                </Border>
                                            </UniformGrid>

                                            <Grid Margin="0,0,0,20">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="1.2*" />
                                                    <ColumnDefinition Width="20" />
                                                    <ColumnDefinition Width="0.8*" />
                                                </Grid.ColumnDefinitions>

                                                <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}">
                                                    <StackPanel>
                                                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="结果摘要" />
                                                        <TextBlock
                                                            Margin="0,14,0,0"
                                                            Style="{StaticResource SectionHintTextStyle}"
                                                            Text="{Binding QualitySummary, TargetNullValue=当前步态节律稳定，左右差异控制在可接受范围内，建议结合临床主诉进一步观察站立相承重表现。}" />

                                                        <Grid Margin="0,18,0,0">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="128" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="Auto" />
                                                            </Grid.RowDefinitions>

                                                            <TextBlock Grid.Row="0" Style="{StaticResource InfoLabelTextStyle}" Text="质量提示" />
                                                            <TextBlock
                                                                Grid.Row="0"
                                                                Grid.Column="1"
                                                                Style="{StaticResource SectionHintTextStyle}"
                                                                Foreground="{StaticResource OverlayTextBrush}"
                                                                Text="{Binding QualitySummary, TargetNullValue=有效帧比例良好，可用于后续报告与趋势比对。}" />

                                                            <TextBlock Grid.Row="1" Margin="0,12,0,0" Style="{StaticResource InfoLabelTextStyle}" Text="结果来源" />
                                                            <TextBlock
                                                                Grid.Row="1"
                                                                Grid.Column="1"
                                                                Margin="0,12,0,0"
                                                                Style="{StaticResource SectionHintTextStyle}"
                                                                Foreground="{StaticResource OverlayTextBrush}"
                                                                Text="步态分析引擎 / 本地分析服务" />

                                                            <TextBlock Grid.Row="2" Margin="0,12,0,0" Style="{StaticResource InfoLabelTextStyle}" Text="文件摘要" />
                                                            <TextBlock
                                                                Grid.Row="2"
                                                                Grid.Column="1"
                                                                Margin="0,12,0,0"
                                                                Style="{StaticResource SectionHintTextStyle}"
                                                                Foreground="{StaticResource OverlayTextBrush}"
                                                                Text="{Binding FileCountDisplay, TargetNullValue=包含 1 个汇总文件、1 个标注视频、1 个曲线快照包。}" />

                                                            <TextBlock Grid.Row="3" Margin="0,12,0,0" Style="{StaticResource InfoLabelTextStyle}" Text="结果概览说明" />
                                                            <TextBlock
                                                                Grid.Row="3"
                                                                Grid.Column="1"
                                                                Margin="0,12,0,0"
                                                                Style="{StaticResource SectionHintTextStyle}"
                                                                Foreground="{StaticResource OverlayTextBrush}"
                                                                Text="覆盖式详情页适合作为统一结果浏览入口，后续报告预览可直接在同层承载容器中切换显示。" />
                                                        </Grid>
                                                    </StackPanel>
                                                </Border>

                                                <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                                                    <StackPanel>
                                                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="分析基础信息" />
                                                        <StackPanel Margin="0,18,0,0">
                                                            <DockPanel Margin="0,0,0,12">
                                                                <TextBlock Style="{StaticResource InfoLabelTextStyle}" Text="分析时间" />
                                                                <TextBlock
                                                                    DockPanel.Dock="Right"
                                                                    Style="{StaticResource SectionHintTextStyle}"
                                                                    Foreground="{StaticResource OverlayTextBrush}"
                                                                    Text="{Binding AnalysisCreatedAtDisplay, TargetNullValue=2025-02-18 14:29}" />
                                                            </DockPanel>
                                                            <DockPanel Margin="0,0,0,12">
                                                                <TextBlock Style="{StaticResource InfoLabelTextStyle}" Text="分析状态" />
                                                                <TextBlock
                                                                    DockPanel.Dock="Right"
                                                                    Style="{StaticResource SectionHintTextStyle}"
                                                                    Foreground="{StaticResource OverlayTextBrush}"
                                                                    Text="{Binding TaskStatusDisplay, TargetNullValue=已完成}" />
                                                            </DockPanel>
                                                            <DockPanel Margin="0,0,0,12">
                                                                <TextBlock Style="{StaticResource InfoLabelTextStyle}" Text="质量等级" />
                                                                <TextBlock
                                                                    DockPanel.Dock="Right"
                                                                    Style="{StaticResource SectionHintTextStyle}"
                                                                    Foreground="{StaticResource OverlayTextBrush}"
                                                                    Text="{Binding QualityGradeDisplay, TargetNullValue=A级}" />
                                                            </DockPanel>
                                                            <DockPanel Margin="0,0,0,12">
                                                                <TextBlock Style="{StaticResource InfoLabelTextStyle}" Text="测量名称" />
                                                                <TextBlock
                                                                    DockPanel.Dock="Right"
                                                                    Style="{StaticResource SectionHintTextStyle}"
                                                                    Foreground="{StaticResource OverlayTextBrush}"
                                                                    Text="{Binding MeasurementName, TargetNullValue=术后步态评估-左侧}" />
                                                            </DockPanel>
                                                            <DockPanel Margin="0,0,0,12">
                                                                <TextBlock Style="{StaticResource InfoLabelTextStyle}" Text="任务编号" />
                                                                <TextBlock
                                                                    DockPanel.Dock="Right"
                                                                    Style="{StaticResource SectionHintTextStyle}"
                                                                    Foreground="{StaticResource OverlayTextBrush}"
