<UserControl
    x:Class="BTFX.Views.Dialogs.MeasurementDetailDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:BTFX.Views.Dialogs"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:vm="clr-namespace:BTFX.ViewModels"
    Background="Transparent"
    d:DataContext="{d:DesignInstance Type=vm:MeasurementDetailViewModel}"
    mc:Ignorable="d">

    <Grid>
        <Border
            Style="{StaticResource DialogSurfaceBorderStyle}"
            Width="1080"
            MaxHeight="740"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">
        <Border.Resources>
            <SolidColorBrush x:Key="MeasurementSectionAccentBrush" Color="#E4004A" />
            <SolidColorBrush x:Key="MeasurementSectionTitleBrush" Color="#403B5B" />
            <SolidColorBrush x:Key="MeasurementSectionBackgroundBrush" Color="#FAFAFA" />
            <SolidColorBrush x:Key="MeasurementSectionBorderBrush" Color="#FFF1ECEF" />
            <SolidColorBrush x:Key="MeasurementLabelBrush" Color="#555555" />
            <SolidColorBrush x:Key="MeasurementValueBrush" Color="#403B5B" />
            <Style BasedOn="{StaticResource DialogLightScrollBarStyle}" TargetType="ScrollBar" />

            <Style x:Key="MeasurementSectionBorderStyle" TargetType="Border">
                <Setter Property="Margin" Value="0,0,0,20" />
                <Setter Property="Padding" Value="24" />
                <Setter Property="Background" Value="{StaticResource MeasurementSectionBackgroundBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource MeasurementSectionBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="8" />
            </Style>

            <Style x:Key="MeasurementSectionTitleTextStyle" TargetType="TextBlock">
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="FontFamily" Value="AlibabaPuHuiTi" />
                <Setter Property="FontSize" Value="24" />
                <Setter Property="FontWeight" Value="Normal" />
                <Setter Property="Foreground" Value="{StaticResource MeasurementSectionTitleBrush}" />
            </Style>

            <Style x:Key="MeasurementLabelTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource MeasurementLabelBrush}" />
                <Setter Property="FontFamily" Value="AlibabaPuHuiTi" />
                <Setter Property="FontSize" Value="20" />
                <Setter Property="FontWeight" Value="Normal" />
                <Setter Property="LineHeight" Value="30" />
                <Setter Property="TextWrapping" Value="Wrap" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>

            <Style x:Key="MeasurementValueTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource MeasurementValueBrush}" />
                <Setter Property="FontFamily" Value="AlibabaPuHuiTi" />
                <Setter Property="FontSize" Value="20" />
                <Setter Property="FontWeight" Value="Normal" />
                <Setter Property="LineHeight" Value="30" />
                <Setter Property="TextWrapping" Value="Wrap" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>
        </Border.Resources>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="68" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border
                Grid.Row="0"
                Background="#F0F6FA"
                CornerRadius="8,8,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="72" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="72" />
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        Grid.Column="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontFamily="AlibabaPuHuiTi"
                        FontSize="26"
                        FontWeight="Normal"
                        Foreground="#333333"
                        LineHeight="36"
                        Text="数据详情"
                        TextAlignment="Center" />

                    <Button
                        Grid.Column="2"
                        Width="40"
                        Height="40"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        BorderThickness="0"
                    Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                        Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderBrush" Value="Transparent" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="12">
                                                <ContentPresenter
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center" />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#DCE6ED" />
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="#CDD9E1" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="24"
                            Foreground="#333333"
                            Text="×" />
                    </Button>
                </Grid>
            </Border>

            <!--  内容区域  -->
            <Border
                Grid.Row="1"
                Margin="10,10,10,0"
                BorderBrush="#DBE2EF"
                BorderThickness="1"
                CornerRadius="8">
                <ScrollViewer
                    Style="{StaticResource DialogLightweightScrollViewerStyle}">
                    <StackPanel Margin="10">
                <!--  患者信息  -->
                <Border Style="{StaticResource MeasurementSectionBorderStyle}">
                    <StackPanel>
                        <StackPanel Margin="0,0,0,20" Orientation="Horizontal">
                            <Border
                                Width="4"
                                Height="16"
                                Margin="0,0,12,0"
                                VerticalAlignment="Center"
                                Background="{StaticResource MeasurementSectionAccentBrush}"
                                CornerRadius="8" />
                            <TextBlock
                                Style="{StaticResource MeasurementSectionTitleTextStyle}"
                                Text="患者信息" />
                        </StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="48" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel
                                Grid.Row="0"
                                Grid.Column="0"
                                Margin="0,10,0,10"
                                Orientation="Horizontal">
                                <TextBlock
                                    Width="100"
                                    Style="{StaticResource MeasurementLabelTextStyle}"
                                    Text="姓名：" />
                                <TextBlock Style="{StaticResource MeasurementValueTextStyle}" Text="{Binding PatientName}" />
                            </StackPanel>

                            <StackPanel
                                Grid.Row="0"
                                Grid.Column="2"
                                Margin="0,10,0,10"
                                Orientation="Horizontal">
                                <TextBlock
                                    Width="100"
                                    Style="{StaticResource MeasurementLabelTextStyle}"
                                    Text="性别：" />
                                <TextBlock Style="{StaticResource MeasurementValueTextStyle}" Text="{Binding Gender}" />
                            </StackPanel>

                            <StackPanel
                                Grid.Row="1"
                                Grid.Column="0"
                                Margin="0,10,0,10"
                                Orientation="Horizontal">
                                <TextBlock
                                    Width="100"
                                    Style="{StaticResource MeasurementLabelTextStyle}"
                                    Text="年龄：" />
                                <TextBlock Style="{StaticResource MeasurementValueTextStyle}" Text="{Binding Age}" />
                            </StackPanel>

                            <StackPanel
                                Grid.Row="1"
                                Grid.Column="2"
                                Margin="0,10,0,10"
                                Orientation="Horizontal">
                                <TextBlock
                                    Width="100"
                                    Style="{StaticResource MeasurementLabelTextStyle}"
                                    Text="电话：" />
                                <TextBlock Style="{StaticResource MeasurementValueTextStyle}" Text="{Binding Phone}" />
                            </StackPanel>

                            <StackPanel
                                Grid.Row="2"
                                Grid.Column="0"
                                Grid.ColumnSpan="3"
                                 Margin="0,10,0,10"
                                Orientation="Horizontal">
                                <TextBlock
                                    Width="100"
                                    Style="{StaticResource MeasurementLabelTextStyle}"
                                    Text="证件号：" />
                                <TextBlock Style="{StaticResource MeasurementValueTextStyle}" Text="{Binding IdNumber}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!--  测量信息  -->
                <Border Style="{StaticResource MeasurementSectionBorderStyle}">
                    <StackPanel>
                        <StackPanel Margin="0,0,0,20" Orientation="Horizontal">
                            <Border
                                Width="4"
                                Height="16"
                                Margin="0,0,12,0"
                                VerticalAlignment="Center"
                                Background="{StaticResource MeasurementSectionAccentBrush}"
                                CornerRadius="8" />
                            <TextBlock
                                Style="{StaticResource MeasurementSectionTitleTextStyle}"
                                Text="测量信息" />
                        </StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="48" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel
                                Grid.Row="0"
                                Grid.Column="0"
                                Margin="0,10,0,10"
                                Orientation="Horizontal">
                                <TextBlock
                                    Width="100"
                                    Style="{StaticResource MeasurementLabelTextStyle}"
                                    Text="测量日期：" />
                                <TextBlock Style="{StaticResource MeasurementValueTextStyle}" Text="{Binding MeasurementDate}" />
                            </StackPanel>

                            <StackPanel
                                Grid.Row="0"
                                Grid.Column="2"
                                Margin="0,10,0,10"
                                Orientation="Horizontal">
                                <TextBlock
                                    Width="100"
                                    Style="{StaticResource MeasurementLabelTextStyle}"
                                    Text="操作员：" />
                                <TextBlock Style="{StaticResource MeasurementValueTextStyle}" Text="{Binding OperatorName}" />
                            </StackPanel>

                            <StackPanel
                                Grid.Row="1"
                                Grid.Column="0"
                                Margin="0,10,0,10"
                                Orientation="Horizontal">
                                <TextBlock
                                    Width="100"
                                    Style="{StaticResource MeasurementLabelTextStyle}"
                                    Text="测量状态：" />
                                <Border
                                    Padding="10,4"
                                    Background="{Binding StatusColor}"
                                    CornerRadius="6">
                                    <TextBlock
                                        FontFamily="AlibabaPuHuiTi"
                                        FontSize="18"
                                        Foreground="White"
                                        Text="{Binding Status}" />
                                </Border>
                            </StackPanel>

                            <StackPanel
                                Grid.Row="1"
                                Grid.Column="2"
                               Margin="0,10,0,10"
                                Orientation="Horizontal">
                                <TextBlock
                                    Width="100"
                                    Style="{StaticResource MeasurementLabelTextStyle}"
                                    Text="测量时长：" />
                                <TextBlock Style="{StaticResource MeasurementValueTextStyle}" Text="{Binding Duration}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!--  步态参数  -->
                <Border Style="{StaticResource MeasurementSectionBorderStyle}">
                    <StackPanel>
                        <StackPanel Margin="0,0,0,20" Orientation="Horizontal">
                            <Border
                                Width="4"
                                Height="16"
                                Margin="0,0,12,0"
                                VerticalAlignment="Center"
                                Background="{StaticResource MeasurementSectionAccentBrush}"
                                CornerRadius="8" />
                            <TextBlock
                                Style="{StaticResource MeasurementSectionTitleTextStyle}"
                                Text="步态参数" />
                        </StackPanel>

                        <!--  有数据时显示  -->
                        <Grid Visibility="{Binding HasGaitParameters, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="48" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel
                                Grid.Row="0"
                                Grid.Column="0"
                                Margin="0,10,0,10"
                                Orientation="Horizontal">
                                <TextBlock
                                    Width="100"
                                    Style="{StaticResource MeasurementLabelTextStyle}"
                                    Text="左脚步幅(cm)：" />
                                <TextBlock Style="{StaticResource MeasurementValueTextStyle}" Text="{Binding StrideLengthLeft}" />
                            </StackPanel>

                            <StackPanel
                                Grid.Row="0"
                                Grid.Column="2"
                                Margin="0,10,0,10"
                                Orientation="Horizontal">
                                <TextBlock
                                    Width="100"
                                    Style="{StaticResource MeasurementLabelTextStyle}"
                                    Text="右脚步幅(cm)：" />
                                <TextBlock Style="{StaticResource MeasurementValueTextStyle}" Text="{Binding StrideLengthRight}" />
                            </StackPanel>

                            <StackPanel
                                Grid.Row="1"
                                Grid.Column="0"
                                Margin="0,10,0,10"
                                Orientation="Horizontal">
                                <TextBlock
                                    Width="100"
                                    Style="{StaticResource MeasurementLabelTextStyle}"
                                    Text="步频(步/分)：" />
                                <TextBlock Style="{StaticResource MeasurementValueTextStyle}" Text="{Binding Cadence}" />
                            </StackPanel>

                            <StackPanel
                                Grid.Row="1"
                                Grid.Column="2"
                                Margin="0,10,0,10"
                                Orientation="Horizontal">
                                <TextBlock
                                    Width="100"
                                    Style="{StaticResource MeasurementLabelTextStyle}"
                                    Text="步速(m/s)：" />
                                <TextBlock Style="{StaticResource MeasurementValueTextStyle}" Text="{Binding Velocity}" />
                            </StackPanel>

                            <StackPanel
                                Grid.Row="2"
                                Grid.Column="0"
                                Margin="0,10,0,10"
                                Orientation="Horizontal">
                                <TextBlock
                                    Width="100"
                                    Style="{StaticResource MeasurementLabelTextStyle}"
                                    Text="左脚支撑相(%)：" />
                                <TextBlock Style="{StaticResource MeasurementValueTextStyle}" Text="{Binding StancePhaseLeft}" />
                            </StackPanel>

                            <StackPanel
                                Grid.Row="2"
                                Grid.Column="2"
                                Margin="0,10,0,10"
                                Orientation="Horizontal">
                                <TextBlock
                                    Width="100"
                                    Style="{StaticResource MeasurementLabelTextStyle}"
                                    Text="右脚支撑相(%)：" />
                                <TextBlock Style="{StaticResource MeasurementValueTextStyle}" Text="{Binding StancePhaseRight}" />
                            </StackPanel>

                            <StackPanel
                                Grid.Row="3"
                                Grid.Column="0"
                               Margin="0,10,0,10"
                                Orientation="Horizontal">
                                <TextBlock
                                    Width="100"
                                    Style="{StaticResource MeasurementLabelTextStyle}"
                                    Text="双支撑时间(%)：" />
                                <TextBlock Style="{StaticResource MeasurementValueTextStyle}" Text="{Binding DoubleSupport}" />
                            </StackPanel>

                            <StackPanel
                                Grid.Row="3"
                                Grid.Column="2"
                               Margin="0,10,0,10"
                                Orientation="Horizontal">
                                <TextBlock
                                    Width="100"
                                    Style="{StaticResource MeasurementLabelTextStyle}"
                                    Text="步宽(cm)：" />
                                <TextBlock Style="{StaticResource MeasurementValueTextStyle}" Text="{Binding StepWidth}" />
                            </StackPanel>
                        </Grid>

                        <!--  无数据时显示  -->
                        <TextBlock
                            HorizontalAlignment="Center"
                            Style="{StaticResource MeasurementLabelTextStyle}"
                            Text="暂无步态参数数据"
                            Visibility="{Binding HasGaitParameters, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverse}" />
                    </StackPanel>
                </Border>

                <!--  视频回放区域（占位）  -->
                <Border Style="{StaticResource MeasurementSectionBorderStyle}">
                    <StackPanel>
                        <StackPanel Margin="0,0,0,20" Orientation="Horizontal">
                            <Border
                                Width="4"
                                Height="16"
                                 Margin="0,0,12,0"
                                VerticalAlignment="Center"
                                Background="{StaticResource MeasurementSectionAccentBrush}"
                                CornerRadius="8" />
                            <TextBlock
                                Style="{StaticResource MeasurementSectionTitleTextStyle}"
                                Text="视频回放" />
                        </StackPanel>
                        <Border
                            Height="150"
                            Background="{DynamicResource MaterialDesignCardBackground}"
                            CornerRadius="4">
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Foreground="{DynamicResource MaterialDesignBodyLight}"
                                Text="视频回放功能开发中..." />
                        </Border>
                    </StackPanel>
                </Border>

                <!--  关节点轨迹区域（占位）  -->
                <Border
                    Margin="0"
                    Style="{StaticResource MeasurementSectionBorderStyle}">
                    <StackPanel>
                        <StackPanel Margin="0,0,0,20" Orientation="Horizontal">
                            <Border
                                Width="4"
                                Height="16"
                                 Margin="0,0,12,0"
                                VerticalAlignment="Center"
                                Background="{StaticResource MeasurementSectionAccentBrush}"
                                CornerRadius="8" />
                            <TextBlock
                                Style="{StaticResource MeasurementSectionTitleTextStyle}"
                                Text="关节点轨迹" />
                        </StackPanel>
                        <Border
                            Height="150"
                            Background="{DynamicResource MaterialDesignCardBackground}"
                            CornerRadius="4">
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Foreground="{DynamicResource MaterialDesignBodyLight}"
                                Text="轨迹显示功能开发中..." />
                        </Border>
                    </StackPanel>
                </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!--  底部按钮  -->
            <StackPanel
                Grid.Row="2"
                Margin="0,20,0,20"
                HorizontalAlignment="Center"
                Orientation="Horizontal">
                <Button
                    Width="150"
                    Height="50"
                    Margin="0,0,24,0"
                    Background="#FFFFFF"
                    BorderBrush="#403B5B"
                    BorderThickness="1"
                    Command="{Binding CloseCommand}"
                    Content="取消"
                    Cursor="Hand"
                    FontFamily="AlibabaPuHuiTi"
                    FontSize="22"
                    FontWeight="Medium"
                    Foreground="#403B5B"
                    IsDefault="True"
                    Visibility="Visible">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="16">
                                            <ContentPresenter
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="16" />
                        </Style>
                    </Button.Resources>
                </Button>
                <Button
                    Width="150"
                    Height="50"
                    Background="#403B5B"
                    BorderThickness="0"
                    Command="{Binding ExportCommand}"
                    Content="导出"
                    Cursor="Hand"
                    FontFamily="AlibabaPuHuiTi"
                    FontSize="22"
                    FontWeight="Medium"
                    Foreground="#FFFFFF"
                    Visibility="{Binding CanExport, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="16">
                                            <ContentPresenter
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="16" />
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Grid>
        </Border>
    </Grid>
</UserControl>
