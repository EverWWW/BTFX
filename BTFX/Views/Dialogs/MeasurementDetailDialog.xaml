<UserControl
    x:Class="BTFX.Views.Dialogs.MeasurementDetailDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:oxy="http://oxyplot.org/wpf"
    xmlns:vm="clr-namespace:BTFX.ViewModels"
    d:DataContext="{d:DesignInstance Type=vm:GaitAnalysisDetailViewModel}"
    Background="Transparent"
    mc:Ignorable="d">

    <UserControl.Resources>
        <SolidColorBrush x:Key="OverlayMaskBrush" Color="#8C0D1B2A" />
        <SolidColorBrush x:Key="DialogBgBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="CardBgBrush" Color="#FAFAFA" />
        <SolidColorBrush x:Key="CardBorderBrush" Color="#EEF1F5" />
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#222222" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#666666" />
        <SolidColorBrush x:Key="WeakTextBrush" Color="#999999" />
        <SolidColorBrush x:Key="PrimaryPurpleBrush" Color="#40385F" />
        <SolidColorBrush x:Key="AccentOrangeBrush" Color="#FF8A00" />
        <SolidColorBrush x:Key="ExportBlueBrush" Color="#409EFF" />
        <Style BasedOn="{StaticResource DialogLightScrollBarStyle}" TargetType="ScrollBar" />

        <Style x:Key="TitleTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="SectionHeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="InfoLabelTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>

        <Style x:Key="InfoValueTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="MetricLabelTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
        </Style>

        <Style x:Key="MetricValueTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="FontSize" Value="24" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="Margin" Value="0,12,0,0" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBgBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="18" />
        </Style>

        <Style
            x:Key="MetricCardStyle"
            BasedOn="{StaticResource SectionCardStyle}"
            TargetType="Border">
            <Setter Property="MinHeight" Value="90" />
            <Setter Property="Padding" Value="16,14" />
            <Setter Property="Margin" Value="0,0,16,0" />
        </Style>

        <Style x:Key="TopTextButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45" />
                    <Setter Property="Cursor" Value="Arrow" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FooterSecondaryActionStyle" TargetType="Button">
            <Setter Property="Width" Value="128" />
            <Setter Property="Height" Value="42" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#D9DEE8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryPurpleBrush}" />
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style
            x:Key="FooterPrimaryActionStyle"
            BasedOn="{StaticResource FooterSecondaryActionStyle}"
            TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryPurpleBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryPurpleBrush}" />
            <Setter Property="Foreground" Value="#FFFFFF" />
        </Style>

        <Style x:Key="TabHeaderTextStyle" TargetType="TextBlock">
            <Setter Property="Width" Value="196" />
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="LineHeight" Value="40" />
            <Setter Property="LineStackingStrategy" Value="BlockLineHeight" />
        </Style>

        <Style x:Key="AnalysisTabItemStyle" TargetType="TabItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
            <Setter Property="Height" Value="40" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border
                            x:Name="TabPill"
                            Width="196"
                            Height="40"
                            Background="Transparent"
                            CornerRadius="22">
                            <Label
                                Width="196"
                                Height="40"
                                Padding="0"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Content="{TemplateBinding Header}"
                                FontFamily="{StaticResource AppFont}"
                                FontSize="15"
                                FontWeight="Medium"
                                Foreground="{TemplateBinding Foreground}"
                                TextOptions.TextFormattingMode="Display" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabPill" Property="Background" Value="{StaticResource PrimaryPurpleBrush}" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabPill" Property="Background" Value="#E2E7F0" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" />
                                    <Condition Property="IsSelected" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="TabPill" Property="Background" Value="{StaticResource PrimaryPurpleBrush}" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AnalysisTabControlStyle" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource AnalysisTabItemStyle}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid KeyboardNavigation.TabNavigation="Local">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border
                                Width="600"
                                Height="48"
                                Padding="4"
                                HorizontalAlignment="Center"
                                Background="#EEF2F7"
                                CornerRadius="24">
                                <TabPanel
                                    x:Name="HeaderPanel"
                                    HorizontalAlignment="Center"
                                    IsItemsHost="True"
                                    KeyboardNavigation.TabIndex="1" />
                            </Border>
                            <ContentPresenter
                                x:Name="PART_SelectedContentHost"
                                Grid.Row="1"
                                Margin="0,28,0,0"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                ContentSource="SelectedContent"
                                SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style
            x:Key="DetailContentScrollViewerStyle"
            BasedOn="{StaticResource DialogLightweightScrollViewerStyle}"
            TargetType="ScrollViewer">
            <Setter Property="CanContentScroll" Value="False" />
            <Setter Property="PanningMode" Value="VerticalOnly" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="Focusable" Value="False" />
        </Style>
    </UserControl.Resources>

    <Grid Background="Transparent">
        <Border Background="{StaticResource OverlayMaskBrush}" />

        <Border
            Width="1380"
            Height="900"
            MaxWidth="1480"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="{StaticResource DialogBgBrush}"
            BorderBrush="#E8EDF3"
            BorderThickness="1"
            CornerRadius="8">
            <Border.Effect>
                <DropShadowEffect
                    BlurRadius="28"
                    Direction="270"
                    Opacity="0.10"
                    ShadowDepth="0"
                    Color="#1F2A37" />
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="34,24,34,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                        <Button
                            Command="{Binding ExportCommand}"
                            IsEnabled="{Binding CanExport}"
                            Style="{StaticResource TopTextButtonStyle}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon
                                    Width="18"
                                    Height="18"
                                    VerticalAlignment="Center"
                                    Foreground="{StaticResource ExportBlueBrush}"
                                    Kind="Export" />
                                <TextBlock
                                    Margin="6,0,0,0"
                                    VerticalAlignment="Center"
                                    FontFamily="{StaticResource AppFont}"
                                    FontSize="14"
                                    Foreground="{StaticResource ExportBlueBrush}"
                                    Text="导出" />
                            </StackPanel>
                        </Button>
                        <Button
                            Margin="26,0,0,0"
                            Command="{Binding OpenReportPreviewCommand}"
                            IsEnabled="{Binding CanConfigureReport}"
                            Style="{StaticResource TopTextButtonStyle}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon
                                    Width="18"
                                    Height="18"
                                    VerticalAlignment="Center"
                                    Foreground="{StaticResource ExportBlueBrush}"
                                    Kind="FileDocumentOutline" />
                                <TextBlock
                                    Margin="6,0,0,0"
                                    VerticalAlignment="Center"
                                    FontFamily="{StaticResource AppFont}"
                                    FontSize="14"
                                    Foreground="{StaticResource ExportBlueBrush}"
                                    Text="报告预览" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <TextBlock
                        Grid.Column="1"
                        Style="{StaticResource TitleTextStyle}"
                        Text="分析结果详情" />

                    <Button
                        Grid.Column="2"
                        HorizontalAlignment="Right"
                        Command="{Binding CloseCommand}"
                        Style="{StaticResource TopTextButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                VerticalAlignment="Center"
                                FontFamily="{StaticResource AppFont}"
                                FontSize="14"
                                Foreground="{StaticResource WeakTextBrush}"
                                Text="关闭" />
                            <materialDesign:PackIcon
                                Width="18"
                                Height="18"
                                Margin="6,0,0,0"
                                VerticalAlignment="Center"
                                Foreground="{StaticResource WeakTextBrush}"
                                Kind="Close" />
                        </StackPanel>
                    </Button>
                </Grid>

                <Grid Grid.Row="1" Margin="34,28,34,28">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="32" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Border
                                Width="4"
                                Height="18"
                                Margin="0,0,10,0"
                                VerticalAlignment="Center"
                                Background="{StaticResource AccentOrangeBrush}"
                                CornerRadius="2" />
                            <TextBlock Style="{StaticResource SectionHeaderTextStyle}" Text="基本信息" />
                        </StackPanel>
                        <WrapPanel Margin="0,18,0,0">
                            <TextBlock Style="{StaticResource InfoLabelTextStyle}" Text="患者" />
                            <TextBlock
                                Margin="8,0,52,0"
                                Style="{StaticResource InfoValueTextStyle}"
                                Text="{Binding PatientName, Mode=OneWay, TargetNullValue=--}" />
                            <TextBlock Style="{StaticResource InfoLabelTextStyle}" Text="身高" />
                            <TextBlock
                                Margin="8,0,52,0"
                                Style="{StaticResource InfoValueTextStyle}"
                                Text="{Binding PatientHeightDisplay, Mode=OneWay, TargetNullValue=--}" />
                            <TextBlock Style="{StaticResource InfoLabelTextStyle}" Text="测量类型" />
                            <TextBlock
                                Margin="8,0,52,0"
                                Style="{StaticResource InfoValueTextStyle}"
                                Text="{Binding MeasurementTypeDisplay, Mode=OneWay, TargetNullValue=--}" />
                            <TextBlock Style="{StaticResource InfoLabelTextStyle}" Text="测量模式" />
                            <TextBlock
                                Margin="8,0,52,0"
                                Style="{StaticResource InfoValueTextStyle}"
                                Text="{Binding MeasurementVideoModeDisplay, Mode=OneWay, TargetNullValue=--}" />
                            <TextBlock Style="{StaticResource InfoLabelTextStyle}" Text="测量时间" />
                            <TextBlock
                                Margin="8,0,0,0"
                                Style="{StaticResource InfoValueTextStyle}"
                                Text="{Binding MeasurementDate, Mode=OneWay, TargetNullValue=--}" />
                        </WrapPanel>
                    </StackPanel>

                    <TabControl Grid.Row="2" Style="{StaticResource AnalysisTabControlStyle}">
                        <TabItem Header="总体情况页">

                            <ScrollViewer Style="{StaticResource DetailContentScrollViewerStyle}" VerticalScrollBarVisibility="Disabled">
                                <DockPanel Width="1312" LastChildFill="False">
                                    <UniformGrid
                                        Margin="0,0,0,24"
                                        Columns="5"
                                        DockPanel.Dock="Top">
                                        <Border Style="{StaticResource MetricCardStyle}">
                                            <StackPanel>
                                                <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="步态周期" />
                                                <TextBlock Style="{StaticResource MetricValueTextStyle}" Text="{Binding GaitCycleDisplay, TargetNullValue=--}" />
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource MetricCardStyle}">
                                            <StackPanel>
                                                <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="平均步长" />
                                                <TextBlock Style="{StaticResource MetricValueTextStyle}" Text="{Binding StepLengthDisplay, TargetNullValue=--}" />
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource MetricCardStyle}">
                                            <StackPanel>
                                                <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="平均步幅" />
                                                <TextBlock Style="{StaticResource MetricValueTextStyle}" Text="{Binding StrideLengthDisplay, TargetNullValue=--}" />
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource MetricCardStyle}">
                                            <StackPanel>
                                                <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="平均步频" />
                                                <TextBlock Style="{StaticResource MetricValueTextStyle}" Text="{Binding CadenceDisplay, TargetNullValue=--}" />
                                            </StackPanel>
                                        </Border>
                                        <Border Margin="0" Style="{StaticResource MetricCardStyle}">
                                            <StackPanel>
                                                <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="平均步速" />
                                                <TextBlock Style="{StaticResource MetricValueTextStyle}" Text="{Binding GaitSpeedDisplay, TargetNullValue=--}" />
                                            </StackPanel>
                                        </Border>
                                    </UniformGrid>

                                    <Grid Margin="0,0,0,24" DockPanel.Dock="Top">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="54*" />
                                            <ColumnDefinition Width="36" />
                                            <ColumnDefinition Width="46*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <StackPanel Margin="0,0,0,14" Orientation="Horizontal">
                                                <Border
                                                    Width="4"
                                                    Height="18"
                                                    Margin="0,0,10,0"
                                                    Background="{StaticResource AccentOrangeBrush}"
                                                    CornerRadius="2" />
                                                <TextBlock Style="{StaticResource SectionHeaderTextStyle}" Text="结果摘要" />
                                            </StackPanel>
                                            <Border Height="220" Style="{StaticResource SectionCardStyle}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="124" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>

                                                    <TextBlock
                                                        Grid.Row="0"
                                                        Style="{StaticResource InfoLabelTextStyle}"
                                                        Text="质量提示" />
                                                    <TextBlock
                                                        Grid.Row="0"
                                                        Grid.Column="1"
                                                        Style="{StaticResource InfoValueTextStyle}"
                                                        Text="{Binding QualityHintDisplay, TargetNullValue=--}" />
                                                    <TextBlock
                                                        Grid.Row="1"
                                                        Margin="0,14,0,0"
                                                        Style="{StaticResource InfoLabelTextStyle}"
                                                        Text="有效帧比例" />
                                                    <TextBlock
                                                        Grid.Row="1"
                                                        Grid.Column="1"
                                                        Margin="0,14,0,0"
                                                        Style="{StaticResource InfoValueTextStyle}"
                                                        Text="{Binding ValidFrameRatioDisplay, TargetNullValue=--}" />
                                                    <TextBlock
                                                        Grid.Row="2"
                                                        Margin="0,14,0,0"
                                                        Style="{StaticResource InfoLabelTextStyle}"
                                                        Text="结果预览说明" />
                                                    <TextBlock
                                                        Grid.Row="2"
                                                        Grid.Column="1"
                                                        Margin="0,14,0,0"
                                                        Style="{StaticResource InfoValueTextStyle}"
                                                        Text="当前展示本次步态分析的概要数据，详细曲线与视频内容可通过页签切换查看。" />
                                                </Grid>
                                            </Border>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2">
                                            <StackPanel Margin="0,0,0,14" Orientation="Horizontal">
                                                <Border
                                                    Width="4"
                                                    Height="18"
                                                    Margin="0,0,10,0"
                                                    Background="{StaticResource AccentOrangeBrush}"
                                                    CornerRadius="2" />
                                                <TextBlock Style="{StaticResource SectionHeaderTextStyle}" Text="分析基础信息" />
                                            </StackPanel>
                                            <Border Height="220" Style="{StaticResource SectionCardStyle}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="124" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>

                                                    <TextBlock
                                                        Grid.Row="0"
                                                        Style="{StaticResource InfoLabelTextStyle}"
                                                        Text="分析时间" />
                                                    <TextBlock
                                                        Grid.Row="0"
                                                        Grid.Column="1"
                                                        Style="{StaticResource InfoValueTextStyle}"
                                                        Text="{Binding AnalysisCreatedAtDisplay, TargetNullValue=--}" />
                                                    <TextBlock
                                                        Grid.Row="1"
                                                        Margin="0,14,0,0"
                                                        Style="{StaticResource InfoLabelTextStyle}"
                                                        Text="分析状态" />
                                                    <TextBlock
                                                        Grid.Row="1"
                                                        Grid.Column="1"
                                                        Margin="0,14,0,0"
                                                        Style="{StaticResource InfoValueTextStyle}"
                                                        Text="{Binding TaskStatusDisplay, TargetNullValue=--}" />
                                                    <TextBlock
                                                        Grid.Row="2"
                                                        Margin="0,14,0,0"
                                                        Style="{StaticResource InfoLabelTextStyle}"
                                                        Text="质量等级" />
                                                    <TextBlock
                                                        Grid.Row="2"
                                                        Grid.Column="1"
                                                        Margin="0,14,0,0"
                                                        Style="{StaticResource InfoValueTextStyle}"
                                                        Text="{Binding QualityGradeDisplay, TargetNullValue=--}" />
                                                    <TextBlock
                                                        Grid.Row="3"
                                                        Margin="0,14,0,0"
                                                        Style="{StaticResource InfoLabelTextStyle}"
                                                        Text="测量名称" />
                                                    <TextBlock
                                                        Grid.Row="3"
                                                        Grid.Column="1"
                                                        Margin="0,14,0,0"
                                                        Style="{StaticResource InfoValueTextStyle}"
                                                        Text="{Binding MeasurementName, TargetNullValue=--}" />
                                                    <TextBlock
                                                        Grid.Row="4"
                                                        Margin="0,14,0,0"
                                                        Style="{StaticResource InfoLabelTextStyle}"
                                                        Text="任务编号" />
                                                    <TextBlock
                                                        Grid.Row="4"
                                                        Grid.Column="1"
                                                        Margin="0,14,0,0"
                                                        Style="{StaticResource InfoValueTextStyle}"
                                                        Text="{Binding RequestIdDisplay, TargetNullValue=--}" />
                                                    <TextBlock
                                                        Grid.Row="5"
                                                        Margin="0,14,0,0"
                                                        Style="{StaticResource InfoLabelTextStyle}"
                                                        Text="分析耗时" />
                                                    <TextBlock
                                                        Grid.Row="5"
                                                        Grid.Column="1"
                                                        Margin="0,14,0,0"
                                                        Style="{StaticResource InfoValueTextStyle}"
                                                        Text="{Binding AnalysisDurationDisplay, TargetNullValue=--}" />
                                                </Grid>
                                            </Border>
                                        </StackPanel>
                                    </Grid>

                                    <StackPanel DockPanel.Dock="Top">
                                        <StackPanel Margin="0,0,0,14" Orientation="Horizontal">
                                            <Border
                                                Width="4"
                                                Height="18"
                                                Margin="0,0,10,0"
                                                Background="{StaticResource AccentOrangeBrush}"
                                                CornerRadius="2" />
                                            <TextBlock Style="{StaticResource SectionHeaderTextStyle}" Text="文件与输出摘要" />
                                        </StackPanel>
                                        <Border MinHeight="106" Style="{StaticResource SectionCardStyle}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="124" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="124" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <TextBlock
                                                    Grid.Row="0"
                                                    Style="{StaticResource InfoLabelTextStyle}"
                                                    Text="结果文件数量" />
                                                <TextBlock
                                                    Grid.Row="0"
                                                    Grid.Column="1"
                                                    Style="{StaticResource InfoValueTextStyle}"
                                                    Text="{Binding FileCountDisplay, TargetNullValue=暂无结果文件}" />
                                                <TextBlock
                                                    Grid.Row="0"
                                                    Grid.Column="2"
                                                    Style="{StaticResource InfoLabelTextStyle}"
                                                    Text="标注视频" />
                                                <TextBlock
                                                    Grid.Row="0"
                                                    Grid.Column="3"
                                                    Style="{StaticResource InfoValueTextStyle}"
                                                    Text="{Binding AnnotatedVideoDisplay, TargetNullValue=未生成标注视频}" />
                                                <TextBlock
                                                    Grid.Row="1"
                                                    Margin="0,14,0,0"
                                                    Style="{StaticResource InfoLabelTextStyle}"
                                                    Text="摘要文件" />
