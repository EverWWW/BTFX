<UserControl
    x:Class="BTFX.Views.Dialogs.DepartmentEditDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:common="clr-namespace:BTFX.Common"
    xmlns:converters="clr-namespace:BTFX.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:vm="clr-namespace:BTFX.ViewModels"
    d:DataContext="{d:DesignInstance Type=vm:DepartmentEditViewModel}"
    d:DesignHeight="400"
    d:DesignWidth="400"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <Grid Margin="8" MinWidth="350">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  标题  -->
        <TextBlock
            Grid.Row="0"
            Margin="0,0,0,16"
            FontSize="18"
            FontWeight="Medium"
            Text="{Binding Title}" />

        <!--  表单  -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!--  科室名称  -->
                <TextBox
                    Margin="0,0,0,16"
                    md:HintAssist.Hint="科室名称 *"
                    md:HintAssist.IsFloating="True"
                    MaxLength="{x:Static common:Constants.DEPARTMENT_NAME_MAX_LENGTH}"
                    Style="{StaticResource MaterialDesignOutlinedTextBox}"
                    Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />

                <!--  科室代码  -->
                <TextBox
                    Margin="0,0,0,16"
                    md:HintAssist.Hint="科室代码"
                    md:HintAssist.IsFloating="True"
                    MaxLength="20"
                    Style="{StaticResource MaterialDesignOutlinedTextBox}"
                    Text="{Binding Code, UpdateSourceTrigger=PropertyChanged}" />

                <!--  科室描述  -->
                <TextBox
                    Height="80"
                    Margin="0,0,0,16"
                    md:HintAssist.Hint="描述"
                    md:HintAssist.IsFloating="True"
                    AcceptsReturn="True"
                    MaxLength="200"
                    Style="{StaticResource MaterialDesignOutlinedTextBox}"
                    Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                    TextWrapping="Wrap"
                    VerticalContentAlignment="Top"
                    VerticalScrollBarVisibility="Auto" />

                <!--  排序顺序  -->
                <TextBox
                    Margin="0,0,0,16"
                    md:HintAssist.Hint="排序顺序"
                    md:HintAssist.IsFloating="True"
                    Style="{StaticResource MaterialDesignOutlinedTextBox}"
                    Text="{Binding SortOrder, UpdateSourceTrigger=PropertyChanged}" />

                <!--  是否启用  -->
                <StackPanel Margin="0,0,0,16" Orientation="Horizontal">
                    <ToggleButton IsChecked="{Binding IsEnabled}" Style="{StaticResource MaterialDesignSwitchToggleButton}" />
                    <TextBlock
                        Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        Text="启用科室" />
                </StackPanel>

                <!--  验证错误提示  -->
                <TextBlock
                    Margin="0,0,0,8"
                    Foreground="{DynamicResource MaterialDesign.Brush.ValidationError}"
                    Text="{Binding ValidationError}"
                    TextWrapping="Wrap"
                    Visibility="{Binding HasValidationError, Converter={StaticResource BooleanToVisibilityConverter}}" />
            </StackPanel>
        </ScrollViewer>

        <!--  按钮区域  -->
        <StackPanel
            Grid.Row="2"
            Margin="0,16,0,0"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                Margin="0,0,8,0"
                Command="{Binding CancelCommand}"
                Content="取消"
                IsEnabled="{Binding IsSaving, Converter={StaticResource InverseBooleanConverter}}"
                Style="{StaticResource MaterialDesignOutlinedButton}" />
            <Button
                Command="{Binding SaveCommand}"
                Content="保存"
                IsEnabled="{Binding IsSaving, Converter={StaticResource InverseBooleanConverter}}"
                Style="{StaticResource MaterialDesignRaisedButton}" />
        </StackPanel>
    </Grid>
</UserControl>
