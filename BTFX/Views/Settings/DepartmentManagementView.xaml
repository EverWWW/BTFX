<UserControl
    x:Class="BTFX.Views.Settings.DepartmentManagementView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:BTFX.Views.Settings"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:vm="clr-namespace:BTFX.ViewModels"
    d:DataContext="{d:DesignInstance Type=vm:SettingsViewModel}"
    d:DesignHeight="500"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  工具栏  -->
        <StackPanel
            Grid.Row="0"
            Margin="0,0,0,16"
            Orientation="Horizontal">
            <Button
                Margin="0,0,8,0"
                Command="{Binding AddDepartmentCommand}"
                Content="{DynamicResource AddDepartment}"
                Style="{StaticResource MaterialDesignRaisedButton}" />
            <Button
                Command="{Binding LoadDepartmentsCommand}"
                Content="{DynamicResource Refresh}"
                Style="{StaticResource MaterialDesignOutlinedButton}" />
        </StackPanel>

        <!--  科室列表  -->
        <DataGrid
            Grid.Row="1"
            AutoGenerateColumns="False"
            CanUserAddRows="False"
            CanUserDeleteRows="False"
            HeadersVisibility="Column"
            IsReadOnly="True"
            ItemsSource="{Binding Departments}"
            RowHeight="44"
            SelectedItem="{Binding SelectedDepartment}"
            SelectionMode="Single"
            Style="{StaticResource MaterialDesignDataGrid}">
            <DataGrid.Columns>
                <DataGridTextColumn
                    Width="50"
                    Binding="{Binding RowNumber}"
                    ElementStyle="{StaticResource CenteredTextColumnStyle}"
                    Header="{DynamicResource RowNumber}" />
                <DataGridTextColumn
                    Width="150"
                    Binding="{Binding Name}"
                    ElementStyle="{StaticResource CenteredTextColumnStyle}"
                    Header="{DynamicResource DepartmentName}" />
                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding Description}"
                    ElementStyle="{StaticResource CenteredTextColumnStyle}"
                    Header="{DynamicResource Description}" />
                <DataGridTextColumn
                    Width="150"
                    Binding="{Binding CreatedAtDisplay}"
                    ElementStyle="{StaticResource CenteredTextColumnStyle}"
                    Header="{DynamicResource CreatedAt}" />
                <DataGridTemplateColumn Width="150" Header="{DynamicResource Operations}">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">
                                <Button
                                    Command="{Binding DataContext.EditDepartmentCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}"
                                    Content="{DynamicResource Edit}"
                                    Style="{StaticResource MaterialDesignFlatButton}" />
                                <Button
                                    Command="{Binding DataContext.DeleteDepartmentCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}"
                                    Content="{DynamicResource Delete}"
                                    Foreground="{DynamicResource MaterialDesign.Brush.ValidationError}"
                                    Style="{StaticResource MaterialDesignFlatButton}" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
