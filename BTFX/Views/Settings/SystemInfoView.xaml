<UserControl
    x:Class="BTFX.Views.Settings.SystemInfoView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:BTFX.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:local="clr-namespace:BTFX.Views.Settings"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:vm="clr-namespace:BTFX.ViewModels"
    d:DataContext="{d:DesignInstance Type=vm:SettingsViewModel}"
    d:DesignHeight="700"
    d:DesignWidth="700"
    mc:Ignorable="d">

  <UserControl.Resources>
    <converters:InverseBooleanConverter x:Key="InverseBooleanConverter" />

    <SolidColorBrush x:Key="SystemInfoAccentBrush" Color="#E4004A" />
    <SolidColorBrush x:Key="SystemInfoTitleBrush" Color="#403B5B" />
    <SolidColorBrush x:Key="SystemInfoContentBrush" Color="#555555" />
    <SolidColorBrush x:Key="SystemInfoCardBackgroundBrush" Color="#FAFAFA" />
    <SolidColorBrush x:Key="SystemInfoCardBorderBrush" Color="#FFF1ECEF" />
    <SolidColorBrush x:Key="SystemInfoInputBorderBrush" Color="#FFD9D5DE" />

    <Style x:Key="SectionCardStyle" TargetType="Border">
      <Setter Property="Margin" Value="0,0,0,20" />
      <Setter Property="Padding" Value="28" />
      <Setter Property="Background" Value="{StaticResource SystemInfoCardBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource SystemInfoCardBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style x:Key="SectionTitleTextStyle" TargetType="TextBlock">
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
      <Setter Property="FontSize" Value="24" />
      <Setter Property="FontWeight" Value="Medium" />
      <Setter Property="Foreground" Value="{StaticResource SystemInfoTitleBrush}" />
    </Style>

    <Style x:Key="InfoLineTextStyle" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource SystemInfoContentBrush}" />
      <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
      <Setter Property="FontSize" Value="20" />
      <Setter Property="FontWeight" Value="Normal" />
      <Setter Property="LineHeight" Value="30" />
      <Setter Property="TextWrapping" Value="Wrap" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="HeaderActionButtonStyle" BasedOn="{StaticResource MaterialDesignFlatButton}" TargetType="Button">
      <Setter Property="Padding" Value="8,4" />
      <Setter Property="MinHeight" Value="36" />
      <Setter Property="Margin" Value="16,0,0,0" />
      <Setter Property="Foreground" Value="{StaticResource SystemInfoAccentBrush}" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="HorizontalAlignment" Value="Right" />
    </Style>

    <Style x:Key="InlineActionButtonStyle" BasedOn="{StaticResource MaterialDesignFlatButton}" TargetType="Button">
      <Setter Property="Padding" Value="8,4" />
      <Setter Property="MinHeight" Value="36" />
      <Setter Property="Margin" Value="12,0,0,0" />
      <Setter Property="Foreground" Value="{StaticResource SystemInfoAccentBrush}" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
    </Style>

    <Style x:Key="AboutButtonStyle" BasedOn="{StaticResource MaterialDesignOutlinedButton}" TargetType="Button">
      <Setter Property="Padding" Value="14,6" />
      <Setter Property="Margin" Value="16,0,0,0" />
      <Setter Property="MinHeight" Value="36" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
    </Style>

    <Style x:Key="ActionButtonTextStyle" TargetType="TextBlock">
      <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
      <Setter Property="FontSize" Value="22" />
      <Setter Property="FontWeight" Value="Normal" />
      <Setter Property="Foreground" Value="{StaticResource SystemInfoAccentBrush}" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="ActionButtonContentGridStyle" TargetType="Grid">
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="CleanupInputStyle" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}" TargetType="TextBox">
      <Setter Property="Width" Value="56" />
      <Setter Property="MinHeight" Value="36" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="Margin" Value="12,0,12,0" />
      <Setter Property="Padding" Value="8,4" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="BorderBrush" Value="{StaticResource SystemInfoInputBorderBrush}" />
    </Style>
  </UserControl.Resources>

  <Grid Margin="40,20,40,20">
    <StackPanel HorizontalAlignment="Stretch">
      <Border Style="{StaticResource SectionCardStyle}">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal">
              <Border
                                Width="4"
                                Height="16"
                                Margin="0,0,12,0"
                                VerticalAlignment="Center"
                                Background="{StaticResource SystemInfoAccentBrush}"
                                CornerRadius="8" />
              <TextBlock
                                Style="{StaticResource SectionTitleTextStyle}"
                                Text="{DynamicResource AppInfo}" />
            </StackPanel>

            <Button
                            Grid.Column="1"
                            Command="{Binding ShowAboutDialogCommand}"
                            Content="{DynamicResource AboutUs}"
                            Style="{StaticResource AboutButtonStyle}" />
          </Grid>

          <Grid Grid.Row="1" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="48" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
              <TextBlock Margin="0,0,0,18" Style="{StaticResource InfoLineTextStyle}">
                                <Run Text="{DynamicResource AppNameLabel}" />
                                <Run Text="： " />
                                <Run Text="{Binding AppName, Mode=OneWay}" />
              </TextBlock>
              <TextBlock Style="{StaticResource InfoLineTextStyle}">
                                <Run Text="{DynamicResource CurrentUserLabel}" />
                                <Run Text="： " />
                                <Run Text="{Binding CurrentUsername}" />
              </TextBlock>
            </StackPanel>

            <StackPanel Grid.Column="2">
              <TextBlock Margin="0,0,0,18" Style="{StaticResource InfoLineTextStyle}">
                                <Run Text="{DynamicResource VersionLabel}" />
                                <Run Text="： " />
                                <Run Text="{Binding AppVersion, Mode=OneWay}" />
              </TextBlock>
              <TextBlock Style="{StaticResource InfoLineTextStyle}">
                                <Run Text="{DynamicResource UserRoleLabel}" />
                                <Run Text="： " />
                                <Run Text="{Binding CurrentUserRole}" />
              </TextBlock>
            </StackPanel>
          </Grid>
        </Grid>
      </Border>

      <Border Style="{StaticResource SectionCardStyle}">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <StackPanel Orientation="Horizontal">
            <Border
                            Width="4"
                            Height="16"
                            Margin="0,0,12,0"
                            VerticalAlignment="Center"
                            Background="{StaticResource SystemInfoAccentBrush}"
                            CornerRadius="8" />
            <TextBlock
                            Style="{StaticResource SectionTitleTextStyle}"
                            Text="{DynamicResource DataInfo}" />
          </StackPanel>

          <StackPanel Grid.Row="1" Margin="0,20,0,0">
            <TextBlock Margin="0,0,0,18" Style="{StaticResource InfoLineTextStyle}">
                            <Run Text="{DynamicResource DatabaseSizeLabel}" />
                            <Run Text="： " />
                            <Run Text="{Binding DatabaseSize}" />
            </TextBlock>

            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>

              <TextBlock
                                Grid.Column="0"
                                Margin="0,0,16,0"
                                Style="{StaticResource InfoLineTextStyle}"
                                TextTrimming="CharacterEllipsis"
                                ToolTip="{Binding LogDirectory}">
                                <Run Text="{DynamicResource LogDirectoryLabel}" />
                                <Run Text="： " />
                                <Run Text="{Binding LogDirectory}" />
              </TextBlock>

              <Button
                                Grid.Column="1"
                                Command="{Binding OpenLogDirectoryCommand}"
                                Style="{StaticResource InlineActionButtonStyle}">
                <Grid Style="{StaticResource ActionButtonContentGridStyle}">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>

                  <Image
                                        Width="20"
                                        Height="20"
                                        Margin="0,0,8,0"
                                        VerticalAlignment="Center"
                                        Source="/Resources/Images/Settings/dakaiwenjian.png" />
                  <TextBlock
                                        Grid.Column="1"
                                        Style="{StaticResource ActionButtonTextStyle}"
                                        Text="打开文件" />
                </Grid>
              </Button>
            </Grid>
          </StackPanel>
        </Grid>
      </Border>

      <Border Margin="0" Style="{StaticResource SectionCardStyle}">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal">
              <Border
                                Width="4"
                                Height="16"
                                Margin="0,0,12,0"
                                VerticalAlignment="Center"
                                Background="{StaticResource SystemInfoAccentBrush}"
                                CornerRadius="8" />
              <TextBlock
                                Style="{StaticResource SectionTitleTextStyle}"
                                Text="{DynamicResource LogManagement}" />
              <Button
     Command="{Binding LoadLogStatisticsCommand}"
     Style="{StaticResource HeaderActionButtonStyle}">
                <Grid Style="{StaticResource ActionButtonContentGridStyle}">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>

                  <Image
             Width="20"
             Height="20"
             Margin="0,0,8,0"
             VerticalAlignment="Center"
             Source="/Resources/Images/Settings/shuaxinhong.png" />
                  <TextBlock
             Grid.Column="1"
             Style="{StaticResource ActionButtonTextStyle}"
             Text="刷新" />
                </Grid>
              </Button>
              <Button
     Command="{Binding ExportLogsCommand}"
     IsEnabled="{Binding IsSaving, Converter={StaticResource InverseBooleanConverter}}"
     Style="{StaticResource HeaderActionButtonStyle}">
                <Grid Style="{StaticResource ActionButtonContentGridStyle}">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>

                  <Image
             Width="20"
             Height="20"
             Margin="0,0,8,0"
             VerticalAlignment="Center"
             Source="/Resources/Images/Settings/daochu.png" />
                  <TextBlock
             Grid.Column="1"
             Style="{StaticResource ActionButtonTextStyle}"
             Text="导出" />
                </Grid>
              </Button>
            </StackPanel>

            <StackPanel Grid.Column="1" VerticalAlignment="Center" Orientation="Horizontal">

            </StackPanel>
          </Grid>

          <StackPanel Grid.Row="1" Margin="0,15,0,0">
            <TextBlock
                            Margin="0,0,0,5"
                            Style="{StaticResource InfoLineTextStyle}"
                            Text="{Binding LogStatistics}" />

            <Grid VerticalAlignment="Center">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>

              <TextBlock
                                Grid.Column="0"
                                Style="{StaticResource InfoLineTextStyle}"
                                Text="{DynamicResource Cleanup}" />
              <TextBox
                                Grid.Column="1"
                                Style="{StaticResource CleanupInputStyle}"
                                Text="{Binding LogCleanupDays}" />
              <TextBlock
                                Grid.Column="2"
                                Style="{StaticResource InfoLineTextStyle}"
                                Text="{DynamicResource DaysAgoLogs}" />
              <Button
                                Grid.Column="3"
                                Command="{Binding CleanupLogsCommand}"
                                IsEnabled="{Binding IsSaving, Converter={StaticResource InverseBooleanConverter}}"
                                Style="{StaticResource InlineActionButtonStyle}">
                <Grid Style="{StaticResource ActionButtonContentGridStyle}">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>

                  <Image
                                        Width="20"
                                        Height="20"
                                        Margin="0,0,8,0"
                                        VerticalAlignment="Center"
                                        Source="/Resources/Images/Settings/qingli.png" />
                  <TextBlock
                                        Grid.Column="1"
                                        Style="{StaticResource ActionButtonTextStyle}"
                                        Text="清理" />
                </Grid>
              </Button>
            </Grid>
          </StackPanel>
        </Grid>
      </Border>
    </StackPanel>
  </Grid>
</UserControl>
