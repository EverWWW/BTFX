<UserControl
    x:Class="BTFX.Views.Settings.SystemInfoView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:BTFX.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:BTFX.Views.Settings"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:vm="clr-namespace:BTFX.ViewModels"
    d:DataContext="{d:DesignInstance Type=vm:SettingsViewModel}"
    d:DesignHeight="700"
    d:DesignWidth="700"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter" />
    </UserControl.Resources>

    <ScrollViewer Padding="24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="600">
            <!--  应用信息  -->
            <Grid Margin="0,0,0,16">
                <TextBlock
                    FontSize="16"
                    FontWeight="Medium"
                    Text="{DynamicResource AppInfo}" />
                <Button
                    HorizontalAlignment="Right"
                    Command="{Binding ShowAboutDialogCommand}"
                    Content="{DynamicResource AboutUs}"
                    Style="{StaticResource MaterialDesignOutlinedButton}" />
            </Grid>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock
                    Grid.Row="0"
                    Grid.Column="0"
                    Margin="0,0,0,8"
                    Foreground="{DynamicResource MaterialDesignBodyLight}"
                    Text="{DynamicResource AppNameLabel}" />
                <TextBlock
                    Grid.Row="0"
                    Grid.Column="1"
                    Margin="0,0,0,8"
                    Text="{Binding AppName}" />

                <TextBlock
                    Grid.Row="1"
                    Grid.Column="0"
                    Margin="0,0,0,8"
                    Foreground="{DynamicResource MaterialDesignBodyLight}"
                    Text="{DynamicResource VersionLabel}" />
                <TextBlock
                    Grid.Row="1"
                    Grid.Column="1"
                    Margin="0,0,0,8"
                    Text="{Binding AppVersion}" />

                <TextBlock
                    Grid.Row="2"
                    Grid.Column="0"
                    Margin="0,0,0,8"
                    Foreground="{DynamicResource MaterialDesignBodyLight}"
                    Text="{DynamicResource CurrentUserLabel}" />
                <TextBlock
                    Grid.Row="2"
                    Grid.Column="1"
                    Margin="0,0,0,8"
                    Text="{Binding CurrentUsername}" />

                <TextBlock
                    Grid.Row="3"
                    Grid.Column="0"
                    Margin="0,0,0,8"
                    Foreground="{DynamicResource MaterialDesignBodyLight}"
                    Text="{DynamicResource UserRoleLabel}" />
                <TextBlock
                    Grid.Row="3"
                    Grid.Column="1"
                    Margin="0,0,0,8"
                    Text="{Binding CurrentUserRole}" />
            </Grid>

            <!--  数据信息  -->
            <TextBlock
                Margin="0,24,0,16"
                FontSize="16"
                FontWeight="Medium"
                Text="{DynamicResource DataInfo}" />
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock
                    Grid.Row="0"
                    Grid.Column="0"
                    Margin="0,0,0,8"
                    Foreground="{DynamicResource MaterialDesignBodyLight}"
                    Text="{DynamicResource DatabaseSizeLabel}" />
                <TextBlock
                    Grid.Row="0"
                    Grid.Column="1"
                    Margin="0,0,0,8"
                    Text="{Binding DatabaseSize}" />

                <TextBlock
                    Grid.Row="1"
                    Grid.Column="0"
                    Margin="0,0,0,8"
                    Foreground="{DynamicResource MaterialDesignBodyLight}"
                    Text="{DynamicResource LogDirectoryLabel}" />
                <StackPanel
                    Grid.Row="1"
                    Grid.Column="1"
                    Orientation="Horizontal">
                    <TextBlock
                        MaxWidth="250"
                        Margin="0,0,8,0"
                        Text="{Binding LogDirectory}"
                        TextTrimming="CharacterEllipsis"
                        ToolTip="{Binding LogDirectory}" />
                    <Button
                        Padding="4"
                        Command="{Binding OpenLogDirectoryCommand}"
                        Content="{DynamicResource Open}"
                        Style="{StaticResource MaterialDesignFlatButton}" />
                </StackPanel>
            </Grid>

            <!--  日志管理  -->
            <TextBlock
                Margin="0,24,0,16"
                FontSize="16"
                FontWeight="Medium"
                Text="{DynamicResource LogManagement}" />

            <!--  日志统计  -->
            <Border
                Padding="12"
                Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                BorderBrush="{DynamicResource MaterialDesign.Brush.TextBox.HoverBackground}"
                BorderThickness="1"
                CornerRadius="4">
                <StackPanel>
                    <TextBlock
                        Foreground="{DynamicResource MaterialDesignBodyLight}"
                        Text="{Binding LogStatistics}"
                        TextWrapping="Wrap" />
                    <Button
                        Margin="0,8,0,0"
                        Padding="8,4"
                        HorizontalAlignment="Left"
                        Command="{Binding LoadLogStatisticsCommand}"
                        Content="{DynamicResource RefreshStatistics}"
                        Style="{StaticResource MaterialDesignFlatButton}" />
                </StackPanel>
            </Border>

            <!--  日志操作  -->
            <StackPanel Margin="0,16,0,0" Orientation="Horizontal">
                <Button
                    Margin="0,0,8,0"
                    Command="{Binding ExportLogsCommand}"
                    Content="{DynamicResource ExportLogs}"
                    IsEnabled="{Binding IsSaving, Converter={StaticResource InverseBooleanConverter}}"
                    Style="{StaticResource MaterialDesignOutlinedButton}" />
                <StackPanel Orientation="Horizontal">
                    <TextBlock
                        Margin="16,0,8,0"
                        VerticalAlignment="Center"
                        Text="{DynamicResource Cleanup}" />
                    <TextBox
                        Width="50"
                        VerticalAlignment="Center"
                        Style="{StaticResource MaterialDesignOutlinedTextBox}"
                        Text="{Binding LogCleanupDays}" />
                    <TextBlock
                        Margin="8,0,8,0"
                        VerticalAlignment="Center"
                        Text="{DynamicResource DaysAgoLogs}" />
                    <Button
                        Command="{Binding CleanupLogsCommand}"
                        Content="{DynamicResource Cleanup}"
                        Foreground="{DynamicResource MaterialDesign.Brush.ValidationError}"
                        IsEnabled="{Binding IsSaving, Converter={StaticResource InverseBooleanConverter}}"
                        Style="{StaticResource MaterialDesignFlatButton}" />
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
