<UserControl
    x:Class="BTFX.Views.Settings.GeneralSettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:BTFX.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:BTFX.Views.Settings"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:vm="clr-namespace:BTFX.ViewModels"
    d:DataContext="{d:DesignInstance Type=vm:SettingsViewModel}"
    d:DesignHeight="600"
    d:DesignWidth="500"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter" />
        <converters:StringToColorBrushConverter x:Key="StringToColorBrushConverter" />
    </UserControl.Resources>

    <ScrollViewer Padding="24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="600">
            <!--  语言设置  -->
            <TextBlock
                Margin="0,0,0,16"
                FontSize="16"
                FontWeight="Medium"
                Text="{DynamicResource LanguageSettings}" />
            <ComboBox
                Width="200"
                HorizontalAlignment="Left"
                md:HintAssist.Hint="{DynamicResource SelectLanguage}"
                DisplayMemberPath="Display"
                ItemsSource="{Binding LanguageOptions}"
                SelectedItem="{Binding SelectedLanguage}"
                Style="{StaticResource MaterialDesignOutlinedComboBox}" />

            <!--  主题设置  -->
            <TextBlock
                Margin="0,32,0,16"
                FontSize="16"
                FontWeight="Medium"
                Text="{DynamicResource ThemeSettings}" />
            <StackPanel Orientation="Horizontal">
                <ItemsControl ItemsSource="{Binding ThemeOptions}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <RadioButton
                                Margin="0,0,16,0"
                                GroupName="ThemeGroup"
                                IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                Style="{StaticResource MaterialDesignChoiceChipOutlineRadioButton}">
                                <StackPanel Orientation="Horizontal">
                                    <md:PackIcon
                                        Margin="0,0,8,0"
                                        VerticalAlignment="Center"
                                        Kind="{Binding IconKind}" />
                                    <TextBlock VerticalAlignment="Center" Text="{Binding Display}" />
                                </StackPanel>
                            </RadioButton>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!--  主题色设置  -->
            <TextBlock
                Margin="0,32,0,16"
                FontSize="16"
                FontWeight="Medium"
                Text="{DynamicResource ThemeColorSettings}" />
            <ItemsControl ItemsSource="{Binding ThemeColorOptions}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button
                            Width="48"
                            Height="48"
                            Margin="0,0,12,12"
                            Padding="0"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            Command="{Binding DataContext.ApplyThemeColorCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                            CommandParameter="{Binding}"
                            Cursor="Hand"
                            ToolTip="{Binding DisplayName}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Grid>
                                        <!--  选中时的外圈  -->
                                        <Border
                                            Width="48"
                                            Height="48"
                                            BorderBrush="{Binding ColorHex, Converter={StaticResource StringToColorBrushConverter}}"
                                            BorderThickness="3"
                                            CornerRadius="24"
                                            Visibility="{Binding IsSelected, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <!--  色块圆形  -->
                                        <Border
                                            Width="36"
                                            Height="36"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Background="{Binding ColorHex, Converter={StaticResource StringToColorBrushConverter}}"
                                            CornerRadius="18" />
                                        <!--  选中勾号  -->
                                        <md:PackIcon
                                            Width="18"
                                            Height="18"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Foreground="White"
                                            Kind="Check"
                                            Visibility="{Binding IsSelected, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                    </Grid>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!--  设置导入导出  -->
            <TextBlock
                Margin="0,32,0,16"
                FontSize="16"
                FontWeight="Medium"
                Text="{DynamicResource SettingsExportImport}" />
            <StackPanel Orientation="Horizontal">
                <Button
                    Margin="0,0,8,0"
                    Command="{Binding ExportSettingsCommand}"
                    Content="{DynamicResource ExportSettings}"
                    IsEnabled="{Binding IsSaving, Converter={StaticResource InverseBooleanConverter}}"
                    Style="{StaticResource MaterialDesignOutlinedButton}" />
                <Button
                    Command="{Binding ImportSettingsCommand}"
                    Content="{DynamicResource ImportSettings}"
                    IsEnabled="{Binding IsSaving, Converter={StaticResource InverseBooleanConverter}}"
                    Style="{StaticResource MaterialDesignOutlinedButton}" />
            </StackPanel>
            <TextBlock
                Margin="0,8,0,0"
                FontSize="12"
                Foreground="{DynamicResource MaterialDesignBodyLight}"
                Text="{DynamicResource SettingsExportImportHint}" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
