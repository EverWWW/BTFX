<UserControl
    x:Class="BTFX.Views.Settings.UnitSettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:common="clr-namespace:BTFX.Common"
    xmlns:converters="clr-namespace:BTFX.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:BTFX.Views.Settings"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:vm="clr-namespace:BTFX.ViewModels"
    d:DataContext="{d:DesignInstance Type=vm:SettingsViewModel}"
    d:DesignHeight="500"
    d:DesignWidth="600"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <ScrollViewer Padding="24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="500">
            <!--  单位名称  -->
            <TextBlock
                Margin="0,0,0,8"
                FontSize="16"
                FontWeight="Medium"
                Text="{DynamicResource UnitName}" />
            <TextBox
                md:HintAssist.Hint="{DynamicResource EnterUnitName}"
                MaxLength="{x:Static common:Constants.UNIT_NAME_MAX_LENGTH}"
                Style="{StaticResource MaterialDesignOutlinedTextBox}"
                Text="{Binding UnitName, UpdateSourceTrigger=PropertyChanged}" />

            <!--  Logo设置  -->
            <TextBlock
                Margin="0,24,0,8"
                FontSize="16"
                FontWeight="Medium"
                Text="{DynamicResource UnitLogo}" />
            <StackPanel Orientation="Horizontal">
                <Border
                    Width="100"
                    Height="100"
                    Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                    BorderBrush="{DynamicResource MaterialDesign.Brush.TextBox.HoverBackground}"
                    BorderThickness="1"
                    CornerRadius="4">
                    <Grid>
                        <Image
                            Source="{Binding LogoPath}"
                            Stretch="Uniform"
                            Visibility="{Binding HasLogo, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="{DynamicResource MaterialDesignBodyLight}"
                            Text="{DynamicResource NoLogo}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasLogo}" Value="False">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>
                <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                    <Button
                        Margin="0,0,0,8"
                        Command="{Binding SelectLogoCommand}"
                        Content="{DynamicResource SelectImage}"
                        Style="{StaticResource MaterialDesignOutlinedButton}" />
                    <Button
                        Command="{Binding ClearLogoCommand}"
                        Content="{DynamicResource ClearLogo}"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Visibility="{Binding HasLogo, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <TextBlock
                        Margin="0,8,0,0"
                        FontSize="12"
                        Foreground="{DynamicResource MaterialDesignBodyLight}"
                        Text="{DynamicResource LogoSizeHint}" />
                </StackPanel>
            </StackPanel>

            <!--  保存按钮  -->
            <Button
                Margin="0,32,0,0"
                HorizontalAlignment="Left"
                Command="{Binding SaveUnitSettingsCommand}"
                Content="{DynamicResource SaveSettings}"
                Style="{StaticResource MaterialDesignRaisedButton}" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
