<UserControl
    x:Class="BTFX.Views.Settings.UserManagementView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:BTFX.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:BTFX.Views.Settings"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:vm="clr-namespace:BTFX.ViewModels"
    d:DataContext="{d:DesignInstance Type=vm:SettingsViewModel}"
    d:DesignHeight="500"
    d:DesignWidth="900"
    mc:Ignorable="d">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  工具栏  -->
        <StackPanel
            Grid.Row="0"
            Margin="0,0,0,16"
            Orientation="Horizontal">
            <Button
                Margin="0,0,8,0"
                Command="{Binding AddUserCommand}"
                Content="{DynamicResource AddUser}"
                Style="{StaticResource MaterialDesignRaisedButton}" />
            <Button
                Command="{Binding LoadUsersCommand}"
                Content="{DynamicResource Refresh}"
                Style="{StaticResource MaterialDesignOutlinedButton}" />
        </StackPanel>

        <!--  用户列表  -->
        <DataGrid
            Grid.Row="1"
            AutoGenerateColumns="False"
            CanUserAddRows="False"
            CanUserDeleteRows="False"
            HeadersVisibility="Column"
            IsReadOnly="True"
            ItemsSource="{Binding Users}"
            RowHeight="44"
            SelectedItem="{Binding SelectedUser}"
            SelectionMode="Single"
            Style="{StaticResource MaterialDesignDataGrid}">

            <DataGrid.Columns>
                <DataGridTextColumn
                    Width="50"
                    Binding="{Binding RowNumber}"
                    ElementStyle="{StaticResource CenteredTextColumnStyle}"
                    Header="{DynamicResource RowNumber}" />
                <DataGridTextColumn
                    Width="100"
                    Binding="{Binding Username}"
                    ElementStyle="{StaticResource CenteredTextColumnStyle}"
                    Header="{DynamicResource Account}" />
                <DataGridTextColumn
                    Width="100"
                    Binding="{Binding Name}"
                    ElementStyle="{StaticResource CenteredTextColumnStyle}"
                    Header="{DynamicResource RealName}" />
                <DataGridTextColumn
                    Width="80"
                    Binding="{Binding RoleDisplay}"
                    ElementStyle="{StaticResource CenteredTextColumnStyle}"
                    Header="{DynamicResource Role}" />
                <DataGridTextColumn
                    Width="100"
                    Binding="{Binding DepartmentName}"
                    ElementStyle="{StaticResource CenteredTextColumnStyle}"
                    Header="{DynamicResource Department}" />
                <DataGridTemplateColumn Width="70" Header="{DynamicResource Status}">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border
                                Padding="8,4"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Background="{Binding StatusColor}"
                                CornerRadius="4">
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="12"
                                    Foreground="White"
                                    Text="{Binding StatusDisplay}" />
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn
                    Width="130"
                    Binding="{Binding LastLoginDisplay}"
                    ElementStyle="{StaticResource CenteredTextColumnStyle}"
                    Header="{DynamicResource LastLogin}" />
                <DataGridTemplateColumn Width="*" Header="{DynamicResource Operations}">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">
                                <Button
                                    Command="{Binding DataContext.EditUserCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}"
                                    Content="{DynamicResource Edit}"
                                    Style="{StaticResource MaterialDesignFlatButton}" />
                                <Button
                                    Command="{Binding DataContext.ResetPasswordCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}"
                                    Content="{DynamicResource ResetPassword}"
                                    Style="{StaticResource MaterialDesignFlatButton}" />
                                <Button
                                    Command="{Binding DataContext.ToggleUserStatusCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource MaterialDesignFlatButton}">
                                    <Button.Content>
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="{DynamicResource DisableUser}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding User.IsEnabled}" Value="False">
                                                            <Setter Property="Text" Value="{DynamicResource EnableUser}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Button.Content>
                                </Button>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
