<UserControl
    x:Class="BTFX.Views.LoginView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:BTFX.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="1080"
    d:DesignWidth="1920"
    Background="#F4F4F4"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />

        <!-- 输入框内左侧图标样式 -->
        <Style x:Key="InputIconStyle" TargetType="materialDesign:PackIcon">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="Margin" Value="20,0,0,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="Foreground" Value="#999999" />
        </Style>

        <!-- 无边框输入框基础样式 -->
        <Style x:Key="LoginTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="72" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Padding" Value="52,0,52,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="#F4F4F4" />
            <Setter Property="Foreground" Value="#333333" />
            <Setter Property="CaretBrush" Value="#403B5B" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border
                            Background="{TemplateBinding Background}"
                            CornerRadius="16"
                            SnapsToDevicePixels="True">
                            <Grid>
                                <!-- 占位文字 -->
                                <TextBlock
                                    x:Name="PART_Watermark"
                                    Margin="{TemplateBinding Padding}"
                                    VerticalAlignment="Center"
                                    FontSize="{TemplateBinding FontSize}"
                                    Foreground="#BBBBBB"
                                    IsHitTestVisible="False"
                                    Text="{TemplateBinding Tag}"
                                    Visibility="Collapsed" />
                                <ScrollViewer
                                    x:Name="PART_ContentHost"
                                    Margin="0"
                                    Focusable="False"
                                    HorizontalScrollBarVisibility="Hidden"
                                    VerticalScrollBarVisibility="Hidden" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="Text" Value="" />
                                    <Condition Property="IsFocused" Value="False" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="PART_Watermark" Property="Visibility" Value="Visible" />
                            </MultiTrigger>
                            <!-- Text为null时也显示占位符 -->
                            <Trigger Property="Text" Value="{x:Null}">
                                <Setter TargetName="PART_Watermark" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 无边框密码框样式 -->
        <Style x:Key="LoginPasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="Height" Value="72" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Padding" Value="52,0,52,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="#F4F4F4" />
            <Setter Property="Foreground" Value="#333333" />
            <Setter Property="CaretBrush" Value="#403B5B" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border
                            Background="{TemplateBinding Background}"
                            CornerRadius="16"
                            SnapsToDevicePixels="True">
                            <Grid>
                                <!-- 占位文字：Tag==""（无密码）时可见 -->
                                <TextBlock
                                    x:Name="PART_Watermark"
                                    Margin="{TemplateBinding Padding}"
                                    VerticalAlignment="Center"
                                    FontSize="{TemplateBinding FontSize}"
                                    Foreground="#BBBBBB"
                                    IsHitTestVisible="False"
                                    Text="请输入密码"
                                    Visibility="Collapsed" />
                                <ScrollViewer
                                    x:Name="PART_ContentHost"
                                    Margin="0"
                                    Focusable="False"
                                    HorizontalScrollBarVisibility="Hidden"
                                    VerticalScrollBarVisibility="Hidden" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- Tag 为空字符串时表示密码为空，显示水印 -->
                            <Trigger Property="Tag" Value="">
                                <Setter TargetName="PART_Watermark" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 密码可见时的文本框样式（复用 LoginTextBoxStyle） -->
        <Style
            x:Key="LoginPasswordTextBoxStyle"
            BasedOn="{StaticResource LoginTextBoxStyle}"
            TargetType="TextBox" />

        <!-- 密码可见性切换按钮样式 -->
        <Style x:Key="PasswordVisibilityButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="Margin" Value="0,0,14,0" />
            <Setter Property="Foreground" Value="#999999" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid MouseLeftButtonDown="LoginBackground_MouseLeftButtonDown">
        <!-- 中心主卡片容器 -->
        <Border
            x:Name="MainCard"
            MaxWidth="1620"
            MaxHeight="780"
            MinWidth="1620"
            MinHeight="780"
            Margin="40"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="#FFFFFF"
            CornerRadius="20">
            <Border.Effect>
                <DropShadowEffect
                    BlurRadius="20"
                    Direction="270"
                    Opacity="0.2"
                    ShadowDepth="2"
                    Color="#000000" />
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <!-- 左侧展示区约 850/1620 ≈ 52.5% -->
                    <ColumnDefinition Width="1.1*" />
                    <!-- 右侧登录区约 770/1620 ≈ 47.5% -->
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <!-- ========== 左侧展示区 ========== -->
                <Border
                    Grid.Column="0"
                    Background="#F5F8FA"
                    CornerRadius="20,0,0,20">
                    <Grid Margin="60,50,60,40">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />

                        </Grid.RowDefinitions>

                        <!-- Logo -->
                        <Image
                            Margin="0,20,0,0"
                            Grid.Row="0"
                            Height="50"
                            HorizontalAlignment="Left"
                            RenderOptions.BitmapScalingMode="HighQuality"
                            Source="/Resources/Images/Logo/logo4.png"
                            Stretch="Uniform" />

                        <!-- 产品展示图 -->
                        <Image
                            Grid.Row="1"
                            MaxWidth="660"
                            MaxHeight="400"
                            Margin="0,20,0,20"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            RenderOptions.BitmapScalingMode="HighQuality"
                            Source="/Resources/Images/Device/deviceImage.jpeg"
                            Stretch="Uniform" />

                        <!-- 系统名称 -->
                        <TextBlock
                            Margin="0,0,0,50"
                            Grid.Row="2"
                            HorizontalAlignment="Center"
                            FontSize="30"
                            FontWeight="Normal"
                            Foreground="#555555"
                            Text="{DynamicResource AppName}" />
                    </Grid>
                </Border>

                <!-- ========== 右侧登录区 ========== -->
                <Grid Grid.Column="1">
                    <!-- 关闭按钮（右上角） -->
                    <Button
                        x:Name="CloseButton"
                        Width="40"
                        Height="40"
                        Margin="0,16,16,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="CloseButton_Click"
                        Cursor="Hand"
                        ToolTip="{DynamicResource Close}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent" CornerRadius="20">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <materialDesign:PackIcon
                            Width="30"
                            Height="30"
                            Foreground="#999999"
                            Kind="Close" />
                    </Button>

                    <!-- 登录表单区 -->
                    <StackPanel
                        Width="490"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">

                        <!-- 标题"账号登录" -->
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontSize="40"
                            FontWeight="Medium"
                            Foreground="#333333"
                            Text="账号登录" />

                        <!-- 账号输入框 -->
                        <Grid Margin="0,48,0,0">
                            <TextBox
                                x:Name="UsernameTextBox"
                                MaxLength="20"
                                Style="{StaticResource LoginTextBoxStyle}"
                                Tag="请输入账号"
                                Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Return" Command="{Binding LoginCommand}" />
                                </TextBox.InputBindings>
                            </TextBox>
                            <materialDesign:PackIcon
                                Kind="AccountOutline"
                                Style="{StaticResource InputIconStyle}" />
                        </Grid>

                        <!-- 密码输入框 -->
                        <Grid Margin="0,20,0,0">
                            <!-- 隐藏密码模式 - PasswordBox -->
                            <PasswordBox
                                x:Name="PasswordBox"
                                MaxLength="20"
                                PasswordChanged="PasswordBox_PasswordChanged"
                                Style="{StaticResource LoginPasswordBoxStyle}"
                                Tag=""
                                Visibility="{Binding IsPasswordHidden, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <PasswordBox.InputBindings>
                                    <KeyBinding Key="Return" Command="{Binding LoginCommand}" />
                                </PasswordBox.InputBindings>
                            </PasswordBox>
                            <!-- 显示密码模式 - TextBox -->
                            <TextBox
                                x:Name="PasswordTextBox"
                                MaxLength="20"
                                Style="{StaticResource LoginPasswordTextBoxStyle}"
                                Tag="请输入密码"
                                Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"
                                Visibility="{Binding IsPasswordHidden, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Return" Command="{Binding LoginCommand}" />
                                </TextBox.InputBindings>
                            </TextBox>
                            <!-- 左侧锁图标 -->
                            <materialDesign:PackIcon
                                Kind="LockOutline"
                                Style="{StaticResource InputIconStyle}" />
                            <!-- 右侧密码可见性切换按钮 -->
                            <Button
                                Command="{Binding TogglePasswordVisibilityCommand}"
                                Style="{StaticResource PasswordVisibilityButtonStyle}"
                                ToolTip="{DynamicResource TogglePasswordVisibility}">
                                <materialDesign:PackIcon Width="20" Height="20">
                                    <materialDesign:PackIcon.Style>
                                        <Style TargetType="materialDesign:PackIcon">
                                            <Setter Property="Kind" Value="EyeOffOutline" />
                                            <Setter Property="Foreground" Value="#999999" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsPasswordHidden}" Value="False">
                                                    <Setter Property="Kind" Value="EyeOutline" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </materialDesign:PackIcon.Style>
                                </materialDesign:PackIcon>
                            </Button>
                        </Grid>

                        <!-- 游客登录 + 记住密码 -->
                        <Grid Margin="20,20,20,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- 游客登录 -->
                            <Button
                                Grid.Column="0"
                                Padding="0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Command="{Binding GuestLoginCommand}"
                                Cursor="Hand"
                                FontSize="18"
                                Foreground="#403B5B">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <TextBlock
                                            Cursor="Hand"
                                            FontSize="18"
                                            Foreground="#403B5B"
                                            Text="{DynamicResource GuestLogin}" />
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- 记住密码 -->
                            <StackPanel
                                Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                                <CheckBox
                                    VerticalAlignment="Center"
                                    IsChecked="{Binding RememberPassword}">
                                    <CheckBox.Style>
                                        <Style TargetType="CheckBox" BasedOn="{StaticResource MaterialDesignCheckBox}">
                                            <Setter Property="Margin" Value="0" />
                                            <Setter Property="Padding" Value="0" />
                                            <Setter Property="MinWidth" Value="0" />
                                        </Style>
                                    </CheckBox.Style>
                                </CheckBox>
                                <TextBlock
                                    Margin="4,0,0,0"
                                    VerticalAlignment="Center"
                                    FontSize="18"
                                    Foreground="#666666"
                                    Text="{DynamicResource RememberPassword}" />
                            </StackPanel>
                        </Grid>

                        <!-- 错误信息 -->
                        <TextBlock
                            Margin="0,12,0,0"
                            FontSize="14"
                            Foreground="#E53935"
                            Text="{Binding ErrorMessage}"
                            TextWrapping="Wrap"
                            Visibility="{Binding ErrorMessage, Converter={StaticResource NullableToVisibilityConverter}}" />

                        <!-- 登录按钮 -->
                        <Button
                            Height="72"
                            Margin="0,24,0,0"
                            Command="{Binding LoginCommand}"
                            Cursor="Hand"
                            FontSize="22"
                            FontWeight="Medium"
                            Foreground="White"
                            IsDefault="True">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border
                                        x:Name="LoginBtnBorder"
                                        Background="#403B5B"
                                        CornerRadius="36"
                                        SnapsToDevicePixels="True">
                                        <Border.Effect>
                                            <DropShadowEffect
                                                BlurRadius="4"
                                                Direction="270"
                                                Opacity="0.1"
                                                ShadowDepth="1"
                                                Color="#000000" />
                                        </Border.Effect>
                                        <Grid>
                                            <StackPanel
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Orientation="Horizontal">
                                                <ProgressBar
                                                    Width="22"
                                                    Height="22"
                                                    Margin="0,0,10,0"
                                                    Foreground="White"
                                                    IsIndeterminate="True"
                                                    Style="{StaticResource MaterialDesignCircularProgressBar}"
                                                    Visibility="{Binding IsLoggingIn, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                    Value="0" />
                                                <TextBlock
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    FontSize="22"
                                                    FontWeight="Medium"
                                                    Foreground="White"
                                                    Text="{DynamicResource Login}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="LoginBtnBorder" Property="Background" Value="#4E4870" />
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="LoginBtnBorder" Property="Background" Value="#332F4A" />
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="LoginBtnBorder" Property="Opacity" Value="0.5" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                    </StackPanel>
                </Grid>

            </Grid>
        </Border>

        <!-- 版本信息 -->
        <Button
            Margin="24"
            Padding="10,4"
            HorizontalAlignment="Left"
            VerticalAlignment="Bottom"
            Background="Transparent"
            BorderBrush="#C8C8C8"
            BorderThickness="1"
            Click="CameraRecordTestButton_Click"
            Cursor="Hand"
            Foreground="#777777"
            ToolTip="临时相机录制测试">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon
                    Width="16"
                    Height="16"
                    Margin="0,0,5,0"
                    Kind="Video" />
                <TextBlock FontSize="12" Text="相机测试" />
            </StackPanel>
        </Button>

        <TextBlock
            Margin="24"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            FontSize="12"
            Foreground="#999999"
            Opacity="0.8"
            Text="{Binding Version}" />
    </Grid>
</UserControl>
