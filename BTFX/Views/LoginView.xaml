<UserControl
    x:Class="BTFX.Views.LoginView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="720"
    d:DesignWidth="1280"
    Background="#009EDB"
    mc:Ignorable="d">

    <UserControl.Resources>
        <!--  文本框图标样式  -->
        <Style x:Key="InputIconStyle" TargetType="materialDesign:PackIcon">
            <Setter Property="Width" Value="20" />
            <Setter Property="Height" Value="20" />
            <Setter Property="Margin" Value="12,0,8,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="#888888" />
        </Style>

        <!--  自定义文本框样式  -->
        <Style
            x:Key="LoginTextBoxStyle"
            BasedOn="{StaticResource MaterialDesignOutlinedTextBox}"
            TargetType="TextBox">
            <Setter Property="Height" Value="48" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="40,12,12,12" />
        </Style>

        <!--  自定义密码框样式  -->
        <Style
            x:Key="LoginPasswordBoxStyle"
            BasedOn="{StaticResource MaterialDesignOutlinedPasswordBox}"
            TargetType="PasswordBox">
            <Setter Property="Height" Value="48" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="40,12,12,12" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <!--  核心登录卡片  -->
        <Border
            Width="1000"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="White"
            CornerRadius="15">
            <Border.Effect>
                <DropShadowEffect
                    BlurRadius="40"
                    Direction="270"
                    Opacity="0.25"
                    ShadowDepth="8"
                    Color="#000000" />
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.3*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <!--  左侧：品牌与设备展示区  -->
                <Grid Grid.Column="0" Margin="50,40,30,40">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!--  Logo 区域  -->
                    <Image
                        Grid.Row="0"
                        Height="60"
                        HorizontalAlignment="Left"
                        Source="/Resources/Images/Logo/logo3.png"
                        Stretch="Uniform" />

                    <!--  设备主图区域  -->
                    <Image
                        Grid.Row="1"
                        Margin="0,30,0,0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Source="/Resources/Images/Device/deviceImage.jpeg"
                        Stretch="Uniform" />
                </Grid>

                <!--  右侧：交互表单区  -->
                <Grid Grid.Column="1" Margin="30,40,50,40">
                    <StackPanel VerticalAlignment="Center">
                        <!--  系统标题  -->
                        <TextBlock
                            FontSize="24"
                            FontWeight="Bold"
                            Foreground="#0066CC"
                            Text="{DynamicResource AppName}"
                            TextWrapping="Wrap" />

                        <TextBlock
                            Margin="0,8,0,0"
                            FontSize="13"
                            Foreground="#666666"
                            Text="Gait Intelligent Analysis System"
                            TextWrapping="Wrap" />

                        <!--  账号输入框  -->
                        <Grid Margin="0,32,0,0">
                            <TextBox
                                x:Name="UsernameTextBox"
                                materialDesign:HintAssist.Hint="{DynamicResource Username}"
                                MaxLength="20"
                                Style="{StaticResource LoginTextBoxStyle}"
                                Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Return" Command="{Binding LoginCommand}" />
                                </TextBox.InputBindings>
                            </TextBox>
                            <materialDesign:PackIcon
                                HorizontalAlignment="Left"
                                Kind="Account"
                                Style="{StaticResource InputIconStyle}" />
                        </Grid>

                        <!--  密码输入框  -->
                        <Grid Margin="0,16,0,0">
                            <PasswordBox
                                x:Name="PasswordBox"
                                materialDesign:HintAssist.Hint="{DynamicResource Password}"
                                MaxLength="20"
                                PasswordChanged="PasswordBox_PasswordChanged"
                                Style="{StaticResource LoginPasswordBoxStyle}">
                                <PasswordBox.InputBindings>
                                    <KeyBinding Key="Return" Command="{Binding LoginCommand}" />
                                </PasswordBox.InputBindings>
                            </PasswordBox>
                            <materialDesign:PackIcon
                                HorizontalAlignment="Left"
                                Kind="Lock"
                                Style="{StaticResource InputIconStyle}" />
                        </Grid>

                        <!--  记住密码  -->
                        <CheckBox
                            Margin="0,16,0,0"
                            HorizontalAlignment="Right"
                            Content="{DynamicResource RememberPassword}"
                            FontSize="13"
                            Foreground="#666666"
                            IsChecked="{Binding RememberPassword}" />

                        <!--  错误信息  -->
                        <TextBlock
                            Margin="0,12,0,0"
                            FontSize="13"
                            Foreground="{DynamicResource MaterialDesign.Brush.ValidationError}"
                            Text="{Binding ErrorMessage}"
                            TextWrapping="Wrap"
                            Visibility="{Binding ErrorMessage, Converter={StaticResource NullableToVisibilityConverter}}" />

                        <!--  登录按钮  -->
                        <Button
                            Height="48"
                            Margin="0,20,0,0"
                            Background="#009EDB"
                            Command="{Binding LoginCommand}"
                            FontSize="16"
                            FontWeight="Bold"
                            Foreground="White"
                            IsDefault="True"
                            Style="{StaticResource MaterialDesignRaisedButton}">
                            <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                <ProgressBar
                                    Width="20"
                                    Height="20"
                                    Margin="0,0,8,0"
                                    IsIndeterminate="True"
                                    Style="{StaticResource MaterialDesignCircularProgressBar}"
                                    Visibility="{Binding IsLoggingIn, Converter={StaticResource BooleanToVisibilityConverter}}"
                                    Value="0" />
                                <TextBlock VerticalAlignment="Center" Text="{DynamicResource Login}" />
                            </StackPanel>
                        </Button>

                        <!--  游客登录  -->
                        <Button
                            Margin="0,16,0,0"
                            HorizontalAlignment="Center"
                            Command="{Binding GuestLoginCommand}"
                            Content="{DynamicResource GuestLogin}"
                            FontSize="13"
                            Foreground="#4DB8E8"
                            Style="{StaticResource MaterialDesignFlatButton}" />

                    </StackPanel>
                </Grid>

            </Grid>
        </Border>

        <!--  版本信息  -->
        <TextBlock
            Margin="24"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            FontSize="12"
            Foreground="White"
            Opacity="0.8"
            Text="{Binding Version}" />
    </Grid>
</UserControl>
