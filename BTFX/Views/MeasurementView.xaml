<UserControl x:Class="BTFX.Views.MeasurementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewmodels="clr-namespace:BTFX.ViewModels"
             xmlns:converters="clr-namespace:BTFX.Converters"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=viewmodels:MeasurementViewModel}">
    
    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:InverseBooleanConverter x:Key="InvertBooleanConverter"/>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" /> <!-- Video Area -->
            <ColumnDefinition Width="1*" /> <!-- Control Area -->
        </Grid.ColumnDefinitions>

        <!-- Video Preview Area -->
        <Border Grid.Column="0" 
                Background="Black" 
                CornerRadius="8" 
                Margin="0,0,16,0">
            <Grid>
                 <TextBlock Text="视频预览区域 (Placeholder)" 
                            Foreground="White" 
                            HorizontalAlignment="Center" 
                            VerticalAlignment="Center"
                            FontSize="24"/>
                 <Border Background="#33FF0000" 
                         Visibility="{Binding IsRecording, Converter={StaticResource BooleanToVisibilityConverter}}"
                         CornerRadius="8"
                         BorderBrush="Red"
                         BorderThickness="2"
                         HorizontalAlignment="Left" 
                         VerticalAlignment="Top" 
                         Margin="16">
                    <StackPanel Margin="8" Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Record" Foreground="Red" Width="20" Height="20" VerticalAlignment="Center"/>
                        <TextBlock Text="REC" Foreground="Red" FontWeight="Bold" Margin="4,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                 </Border>
            </Grid>
        </Border>

        <!-- Controls Area -->
        <materialDesign:Card Grid.Column="1" Padding="16" UniformCornerRadius="8">
            <StackPanel>
                <TextBlock Text="测量控制" Style="{StaticResource MaterialDesignHeadline5TextBlock}" Margin="0,0,0,16"/>

                <!-- Device Selection -->
                <ComboBox ItemsSource="{Binding Devices}"
                          SelectedItem="{Binding SelectedDevice}"
                          materialDesign:HintAssist.Hint="选择设备"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          Margin="0,0,0,16" />

                <!-- Connection Status -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <TextBlock Text="状态: " FontWeight="Bold"/>
                    <TextBlock Text="{Binding ConnectionStatus}" Margin="8,0,0,0"/>
                </StackPanel>

                <!-- Connection Buttons -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="连接" Command="{Binding ConnectCommand}" Margin="0,0,4,0"/>
                                        <Button Grid.Column="1" Content="断开" Command="{Binding DisconnectCommand}" Margin="4,0,0,0" Style="{StaticResource MaterialDesignOutlinedButton}"/>
                                    </Grid>

                                    <Separator Margin="0,0,0,16"/>

                                    <!-- Recording Buttons -->
                                    <Button Content="开始录制" 
                                            Command="{Binding StartRecordingCommand}" 
                                            Style="{StaticResource MaterialDesignRaisedButton}"
                                            Margin="0,0,0,8"/>

                                    <Button Content="停止录制" 
                                            Command="{Binding StopRecordingCommand}" 
                                            Style="{StaticResource MaterialDesignOutlinedButton}"/>

                                    <Separator Margin="0,16,0,16"/>

                                    <!-- Real-time Data Placeholder -->
                                    <TextBlock Text="实时数据" Style="{StaticResource MaterialDesignSubtitle1TextBlock}" Margin="0,0,0,12"/>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="步频 (steps/min)" VerticalAlignment="Center" FontSize="14"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Cadence, StringFormat=F0}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="速度 (m/s)" VerticalAlignment="Center" Margin="0,12,0,0" FontSize="14"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Speed, StringFormat=F2}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}" Margin="0,12,0,0"/>
                                    </Grid>

                                </StackPanel>
                            </materialDesign:Card>
                        </Grid>
                    </UserControl>
