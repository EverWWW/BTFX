<UserControl
    x:Class="BTFX.Views.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:BTFX.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:settings="clr-namespace:BTFX.Views.Settings"
    xmlns:vm="clr-namespace:BTFX.ViewModels"
    d:DataContext="{d:DesignInstance Type=vm:SettingsViewModel}"
    d:DesignHeight="600"
    d:DesignWidth="900"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style x:Key="SettingsTopTabHeaderTextStyle" TargetType="TextBlock">
            <Setter Property="MinWidth" Value="96" />
            <Setter Property="Height" Value="33" />
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="FontSize" Value="24" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Foreground" Value="#403B5B" />
            <Setter Property="LineHeight" Value="33" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextWrapping" Value="NoWrap" />
        </Style>

        <Style x:Key="SettingsTopTabItemStyle" TargetType="TabItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,20,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Background="Transparent">
                            <Grid Width="176" SnapsToDevicePixels="True">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="40" />
                                    <RowDefinition Height="33" />
                                    <RowDefinition Height="18" />
                                    <RowDefinition Height="4" />
                                </Grid.RowDefinitions>

                                <ContentPresenter
                                    Grid.Row="1"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    ContentSource="Header" />

                                <Border
                                    x:Name="SelectedUnderline"
                                    Grid.Row="3"
                                    Width="140"
                                    Height="4"
                                    HorizontalAlignment="Center"
                                    Background="#E4004A"
                                    CornerRadius="2"
                                    Opacity="0" />
                            </Grid>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="SelectedUnderline" Property="Opacity" Value="1" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.88" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True" />
                                    <Condition Property="IsMouseOver" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter Property="Opacity" Value="1" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsTopTabControlStyle" TargetType="TabControl">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource SettingsTopTabItemStyle}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid Background="White" KeyboardNavigation.TabNavigation="Local">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border
                                Padding="12,0,12,0"
                                Background="White"
                                BorderThickness="0">
                                <ScrollViewer
                                    HorizontalScrollBarVisibility="Auto"
                                    VerticalScrollBarVisibility="Disabled"
                                    CanContentScroll="False"
                                    Focusable="False">
                                    <TabPanel
                                        x:Name="HeaderPanel"
                                        HorizontalAlignment="Left"
                                        IsItemsHost="True"
                                        KeyboardNavigation.TabIndex="1"
                                        Panel.ZIndex="1" />
                                </ScrollViewer>
                            </Border>

                            <Border
                                Grid.Row="1"
                                Background="White"
                                BorderThickness="0"
                                KeyboardNavigation.TabIndex="2">
                                <ContentPresenter
                                    x:Name="PART_SelectedContentHost"
                                    Margin="0"
                                    ContentSource="SelectedContent"
                                    SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="0" Background="Transparent">
        <TabControl SelectedIndex="{Binding SelectedTabIndex}" Style="{StaticResource SettingsTopTabControlStyle}">
                <TabItem>
                    <TabItem.Header>
                        <TextBlock Style="{StaticResource SettingsTopTabHeaderTextStyle}" Text="{DynamicResource GeneralSettingsTab}" />
                    </TabItem.Header>
                    <settings:GeneralSettingsView DataContext="{Binding GeneralSettingsViewModel}" />
                </TabItem>

                <TabItem Visibility="{Binding ShowDeviceConfigTab, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TabItem.Header>
                        <TextBlock Style="{StaticResource SettingsTopTabHeaderTextStyle}" Text="{DynamicResource DeviceConfigTab}" />
                    </TabItem.Header>
                    <settings:DeviceConfigView DataContext="{Binding}" />
                </TabItem>

                <TabItem Visibility="{Binding ShowUserManagementTab, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TabItem.Header>
                        <TextBlock Style="{StaticResource SettingsTopTabHeaderTextStyle}" Text="{DynamicResource UserManagement}" />
                    </TabItem.Header>
                    <settings:UserManagementView DataContext="{Binding UserManagementViewModel}" />
                </TabItem>

                <TabItem Visibility="{Binding ShowDepartmentTab, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TabItem.Header>
                        <TextBlock Style="{StaticResource SettingsTopTabHeaderTextStyle}" Text="{DynamicResource DepartmentManagement}" />
                    </TabItem.Header>
                    <settings:DepartmentManagementView DataContext="{Binding DepartmentManagementViewModel}" />
                </TabItem>

                <TabItem Visibility="{Binding ShowUnitSettingsTab, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TabItem.Header>
                        <TextBlock Style="{StaticResource SettingsTopTabHeaderTextStyle}" Text="{DynamicResource UnitSettings}" />
                    </TabItem.Header>
                    <settings:UnitSettingsView DataContext="{Binding UnitSettingsViewModel}" />
                </TabItem>

                <TabItem Visibility="{Binding ShowDataManagementTab, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TabItem.Header>
                        <TextBlock Style="{StaticResource SettingsTopTabHeaderTextStyle}" Text="{DynamicResource DataManagementTab}" />
                    </TabItem.Header>
                    <settings:DataManagementSettingsView DataContext="{Binding DataManagementSettingsViewModel}" />
                </TabItem>

                <TabItem>
                    <TabItem.Header>
                        <TextBlock Style="{StaticResource SettingsTopTabHeaderTextStyle}" Text="{DynamicResource SystemInfoTab}" />
                    </TabItem.Header>
                    <settings:SystemInfoView DataContext="{Binding SystemInfoViewModel}" />
                </TabItem>
            </TabControl>
    </Grid>
</UserControl>
