<UserControl
    x:Class="BTFX.Views.ReportView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:BTFX.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:vm="clr-namespace:BTFX.ViewModels"
    d:DataContext="{d:DesignInstance Type=vm:ReportViewModel}"
    d:DesignHeight="600"
    d:DesignWidth="1200"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="400" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" MinWidth="400" />
        </Grid.ColumnDefinitions>

        <!--  左侧：报告列表/生成报告  -->
        <md:Card Grid.Column="0" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!--  Tab切换  -->
                <TabControl
                    Grid.Row="0"
                    Grid.RowSpan="2"
                    SelectedIndex="{Binding CurrentModeIndex}"
                    Style="{StaticResource MaterialDesignFilledTabControl}">

                    <!--  报告列表Tab  -->
                    <TabItem Header="报告列表">
                        <Grid Margin="16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <!--  筛选条件  -->
                            <StackPanel Grid.Row="0" Margin="0,0,0,16">
                                <WrapPanel Orientation="Horizontal">
                                    <StackPanel Margin="0,0,16,8" Orientation="Horizontal">
                                        <TextBlock VerticalAlignment="Center" Text="患者姓名：" />
                                        <TextBox
                                            Width="120"
                                            MaxLength="50"
                                            md:HintAssist.Hint="输入姓名"
                                            Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                            Text="{Binding ReportFilterPatientName, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,16,8" Orientation="Horizontal">
                                        <TextBlock VerticalAlignment="Center" Text="开始日期：" />
                                        <DatePicker
                                            Width="130"
                                            DisplayDateEnd="{Binding MaxDate, Mode=OneWay}"
                                            SelectedDate="{Binding ReportFilterStartDate}"
                                            Style="{StaticResource MaterialDesignOutlinedDatePicker}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,16,8" Orientation="Horizontal">
                                        <TextBlock VerticalAlignment="Center" Text="结束日期：" />
                                        <DatePicker
                                            Width="130"
                                            DisplayDateEnd="{Binding MaxDate, Mode=OneWay}"
                                            SelectedDate="{Binding ReportFilterEndDate}"
                                            Style="{StaticResource MaterialDesignOutlinedDatePicker}" />
                                    </StackPanel>
                                </WrapPanel>
                                <StackPanel
                                    Margin="0,8,0,0"
                                    HorizontalAlignment="Left"
                                    Orientation="Horizontal">
                                    <Button
                                        Margin="0,0,8,0"
                                        Command="{Binding SearchReportsCommand}"
                                        Content="搜索"
                                        Style="{StaticResource MaterialDesignRaisedButton}" />
                                    <Button
                                        Command="{Binding ResetReportFilterCommand}"
                                        Content="重置"
                                        Style="{StaticResource MaterialDesignOutlinedButton}" />
                                </StackPanel>
                            </StackPanel>

                            <!--  报告列表  -->
                            <DataGrid
                                Grid.Row="1"
                                AutoGenerateColumns="False"
                                CanUserAddRows="False"
                                CanUserDeleteRows="False"
                                HeadersVisibility="Column"
                                IsReadOnly="True"
                                ItemsSource="{Binding Reports}"
                                RowHeight="44"
                                SelectedItem="{Binding SelectedReport}"
                                SelectionMode="Single"
                                Style="{StaticResource MaterialDesignDataGrid}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn
                                        Width="50"
                                        Binding="{Binding RowNumber}"
                                        Header="序号" />
                                    <DataGridTextColumn
                                        Width="140"
                                        Binding="{Binding ReportNumber}"
                                        Header="报告编号" />
                                    <DataGridTextColumn
                                        Width="100"
                                        Binding="{Binding PatientName}"
                                        Header="患者姓名" />
                                    <DataGridTextColumn
                                        Width="140"
                                        Binding="{Binding GeneratedDateDisplay}"
                                        Header="生成日期" />
                                    <DataGridTemplateColumn Width="80" Header="状态">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border
                                                    Padding="8,4"
                                                    HorizontalAlignment="Center"
                                                    Background="{Binding StatusColor}"
                                                    CornerRadius="4">
                                                    <TextBlock
                                                        FontSize="12"
                                                        Foreground="White"
                                                        Text="{Binding StatusDisplay}" />
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Width="*" Header="操作">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                                    <Button
                                                        Command="{Binding DataContext.ViewReportCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}"
                                                        Content="查看"
                                                        Style="{StaticResource MaterialDesignFlatButton}" />
                                                    <Button
                                                        Command="{Binding DataContext.EditReportCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}"
                                                        Content="编辑"
                                                        Style="{StaticResource MaterialDesignFlatButton}"
                                                        Visibility="{Binding DataContext.CanEditReport, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                    <Button
                                                        Command="{Binding DataContext.DeleteReportCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}"
                                                        Content="删除"
                                                        Foreground="{DynamicResource MaterialDesign.Brush.ValidationError}"
                                                        Style="{StaticResource MaterialDesignFlatButton}"
                                                        Visibility="{Binding DataContext.CanDeleteReport, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <!--  加载中  -->
                            <Border
                                Grid.Row="1"
                                Background="#80000000"
                                Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <ProgressBar
                                        Width="32"
                                        Height="32"
                                        IsIndeterminate="True"
                                        Style="{StaticResource MaterialDesignCircularProgressBar}" />
                                    <TextBlock
                                        Margin="0,8,0,0"
                                        Foreground="White"
                                        Text="加载中..." />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </TabItem>

                    <!--  生成报告Tab  -->
                    <TabItem Header="生成报告">
                        <Grid Margin="16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!--  筛选条件  -->
                            <StackPanel Grid.Row="0" Margin="0,0,0,16">
                                <TextBlock
                                    Margin="0,0,0,8"
                                    FontSize="14"
                                    FontWeight="Medium"
                                    Text="选择测量数据" />
                                <WrapPanel Orientation="Horizontal">
                                    <StackPanel Margin="0,0,16,8" Orientation="Horizontal">
                                        <TextBlock VerticalAlignment="Center" Text="患者姓名：" />
                                        <TextBox
                                            Width="120"
                                            MaxLength="50"
                                            md:HintAssist.Hint="输入姓名"
                                            Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                            Text="{Binding MeasurementFilterPatientName, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,16,8" Orientation="Horizontal">
                                        <TextBlock VerticalAlignment="Center" Text="开始日期：" />
                                        <DatePicker
                                            Width="130"
                                            DisplayDateEnd="{Binding MaxDate, Mode=OneWay}"
                                            SelectedDate="{Binding MeasurementFilterStartDate}"
                                            Style="{StaticResource MaterialDesignOutlinedDatePicker}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,8,8" Orientation="Horizontal">
                                        <TextBlock VerticalAlignment="Center" Text="结束日期：" />
                                        <DatePicker
                                            Width="130"
                                            DisplayDateEnd="{Binding MaxDate, Mode=OneWay}"
                                            SelectedDate="{Binding MeasurementFilterEndDate}"
                                            Style="{StaticResource MaterialDesignOutlinedDatePicker}" />
                                    </StackPanel>
                                </WrapPanel>
                                <StackPanel
                                    Margin="0,8,0,0"
                                    HorizontalAlignment="Left"
                                    Orientation="Horizontal">
                                    <Button
                                        Margin="0,0,8,0"
                                        Command="{Binding SearchMeasurementsCommand}"
                                        Content="搜索"
                                        Style="{StaticResource MaterialDesignRaisedButton}" />
                                    <Button
                                        Command="{Binding ResetMeasurementFilterCommand}"
                                        Content="重置"
                                        Style="{StaticResource MaterialDesignOutlinedButton}" />
                                </StackPanel>
                            </StackPanel>

                            <!--  测量数据列表  -->
                            <DataGrid
                                Grid.Row="1"
                                AutoGenerateColumns="False"
                                CanUserAddRows="False"
                                CanUserDeleteRows="False"
                                HeadersVisibility="Column"
                                IsReadOnly="True"
                                ItemsSource="{Binding MeasurementRecords}"
                                RowHeight="44"
                                SelectedItem="{Binding SelectedMeasurement}"
                                SelectionMode="Single"
                                Style="{StaticResource MaterialDesignDataGrid}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn
                                        Width="50"
                                        Binding="{Binding RowNumber}"
                                        Header="序号" />
                                    <DataGridTextColumn
                                        Width="100"
                                        Binding="{Binding PatientName}"
                                        Header="患者姓名" />
                                    <DataGridTextColumn
                                        Width="60"
                                        Binding="{Binding GenderDisplay}"
                                        Header="性别" />
                                    <DataGridTextColumn
                                        Width="60"
                                        Binding="{Binding AgeDisplay}"
                                        Header="年龄" />
                                    <DataGridTextColumn
                                        Width="*"
                                        Binding="{Binding MeasurementDateDisplay}"
                                        Header="测量日期" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <!--  已有报告提示和生成按钮  -->
                            <StackPanel Grid.Row="2" Margin="0,16,0,0">
                                <TextBlock
                                    Margin="0,0,0,8"
                                    Foreground="{DynamicResource MaterialDesign.Brush.Secondary}"
                                    Text="{Binding ExistingReportInfo}"
                                    Visibility="{Binding HasExistingReport, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <Button
                                    HorizontalAlignment="Right"
                                    Command="{Binding GenerateReportCommand}"
                                    Content="生成报告"
                                    IsEnabled="{Binding SelectedMeasurement, Converter={StaticResource NullableToVisibilityConverter}}"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Visibility="{Binding CanGenerateReport, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            </StackPanel>

                            <!--  生成中  -->
                            <Border
                                Grid.Row="0"
                                Grid.RowSpan="3"
                                Background="#80000000"
                                Visibility="{Binding IsGenerating, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <ProgressBar
                                        Width="32"
                                        Height="32"
                                        IsIndeterminate="True"
                                        Style="{StaticResource MaterialDesignCircularProgressBar}" />
                                    <TextBlock
                                        Margin="0,8,0,0"
                                        Foreground="White"
                                        Text="正在生成报告..." />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Grid>
        </md:Card>

        <!--  右侧：报告预览  -->
        <md:Card Grid.Column="2" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--  标题  -->
                <TextBlock
                    Grid.Row="0"
                    Margin="0,0,0,16"
                    FontSize="16"
                    FontWeight="Medium"
                    Text="报告预览" />

                <!--  预览内容  -->
                <Border
                    Grid.Row="1"
                    Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                    BorderBrush="{DynamicResource MaterialDesign.Brush.TextBox.HoverBackground}"
                    BorderThickness="1"
                    CornerRadius="4">
                    <ScrollViewer Padding="16" VerticalScrollBarVisibility="Auto">
                        <TextBlock
                            FontFamily="Consolas"
                            FontSize="13"
                            Text="{Binding PreviewContent}"
                            TextWrapping="Wrap"
                            Visibility="{Binding HasPreviewContent, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </ScrollViewer>
                </Border>

                <!--  无内容提示  -->
                <TextBlock
                    Grid.Row="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="14"
                    Foreground="{DynamicResource MaterialDesignBodyLight}"
                    Text="请在左侧选择一份报告查看">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasPreviewContent}" Value="False">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!--  医生意见编辑区域  -->
                <StackPanel
                    Grid.Row="2"
                    Margin="0,16,0,0"
                    Visibility="{Binding HasPreviewContent, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Grid.Column="0"
                            FontWeight="Medium"
                            Text="医生意见" />
                        <TextBlock Grid.Column="1" Foreground="{DynamicResource MaterialDesignBodyLight}">
                            <Run Text="{Binding DoctorOpinionLength, Mode=OneWay}" />
                            <Run Text="/" />
                            <Run Text="{Binding DoctorOpinionMaxLength, Mode=OneWay}" />
                        </TextBlock>
                    </Grid>
                    <TextBox
                        Height="100"
                        Margin="0,8,0,0"
                        AcceptsReturn="True"
                        IsEnabled="{Binding CanEditReport}"
                        MaxLength="{Binding DoctorOpinionMaxLength}"
                        Style="{StaticResource MaterialDesignOutlinedTextBox}"
                        Text="{Binding DoctorOpinion, UpdateSourceTrigger=PropertyChanged}"
                        TextWrapping="Wrap"
                        VerticalScrollBarVisibility="Auto" />
                </StackPanel>

                <!--  操作按钮  -->
                <StackPanel
                    Grid.Row="3"
                    Margin="0,16,0,0"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal"
                    Visibility="{Binding HasPreviewContent, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Button
                        Margin="0,0,8,0"
                        Command="{Binding SaveReportCommand}"
                        Content="保存"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Visibility="{Binding CanEditReport, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <Button
                        Margin="0,0,8,0"
                        Command="{Binding PrintReportCommand}"
                        Content="打印"
                        Style="{StaticResource MaterialDesignOutlinedButton}" />
                    <Button
                        Command="{Binding ExportPdfCommand}"
                        Content="导出PDF"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Visibility="{Binding CanExportReport, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </StackPanel>
            </Grid>
        </md:Card>
    </Grid>
</UserControl>
