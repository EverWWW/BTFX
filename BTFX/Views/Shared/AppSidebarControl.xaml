<UserControl x:Class="BTFX.Views.AppSidebarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignHeight="928"
             d:DesignWidth="160"
             mc:Ignorable="d">

    <UserControl.Resources>
        <Style x:Key="NavigationListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled" />
        </Style>

        <Style x:Key="NavigationListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Height" Value="Auto" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Top" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Stretch"
                                              VerticalAlignment="Stretch" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                    <Setter Property="Opacity" Value="0.35" />
                    <Setter Property="IsEnabled" Value="False" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Key}" Value="DevTest">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="NavigationCardStyle" TargetType="Border">
            <Setter Property="Width" Value="96" />
            <Setter Property="Height" Value="88" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Background" Value="#403B5B" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="NavigationIconStyle" TargetType="Image">
            <Setter Property="Width" Value="48" />
            <Setter Property="Height" Value="48" />
            <Setter Property="Stretch" Value="Uniform" />
            <Setter Property="RenderOptions.BitmapScalingMode" Value="HighQuality" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Key}" Value="Measurement">
                    <Setter Property="Source" Value="/Resources/Images/NavigationItem/celiangpinggu1.png" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Key}" Value="DataManagement">
                    <Setter Property="Source" Value="/Resources/Images/NavigationItem/shujuguanli1.png" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Key}" Value="Report">
                    <Setter Property="Source" Value="/Resources/Images/NavigationItem/baogao1.png" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Key}" Value="Settings">
                    <Setter Property="Source" Value="/Resources/Images/NavigationItem/shezhi1.png" />
                </DataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Key}" Value="Measurement" />
                        <Condition Binding="{Binding IsSelected}" Value="True" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Source" Value="/Resources/Images/NavigationItem/celiangpinggu2.png" />
                </MultiDataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Key}" Value="DataManagement" />
                        <Condition Binding="{Binding IsSelected}" Value="True" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Source" Value="/Resources/Images/NavigationItem/shujuguanli2.png" />
                </MultiDataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Key}" Value="Report" />
                        <Condition Binding="{Binding IsSelected}" Value="True" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Source" Value="/Resources/Images/NavigationItem/baogao2.png" />
                </MultiDataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Key}" Value="Settings" />
                        <Condition Binding="{Binding IsSelected}" Value="True" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Source" Value="/Resources/Images/NavigationItem/shezhi2.png" />
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="NavigationTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Foreground" Value="#403B5B" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>

        <Style x:Key="LogoutButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="96" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="LogoutBorder"
                                Padding="0,12"
                                Background="Transparent"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="LogoutBorder" Property="Background" Value="#F7F7F7" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="LogoutBorder" Property="Opacity" Value="0.75" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="#FFFFFF"
            CornerRadius="8"
            SnapsToDevicePixels="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="24" />
            </Grid.RowDefinitions>

            <ListBox Grid.Row="1"
                     Margin="0,18,0,0"
                     ItemsSource="{Binding NavigationItems}"
                     SelectedItem="{Binding SelectedNavigationItem}"
                     Style="{StaticResource NavigationListBoxStyle}"
                     ItemContainerStyle="{StaticResource NavigationListBoxItemStyle}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <StackPanel Margin="0,0,0,48"
                                        VerticalAlignment="Top">
                                <Border Style="{StaticResource NavigationCardStyle}">
                                    <Grid>
                                        <Image Style="{StaticResource NavigationIconStyle}" />
                                    </Grid>
                                </Border>
                                <TextBlock Margin="0,12,0,0"
                                           Style="{StaticResource NavigationTextStyle}"
                                           Text="{Binding Title}" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Button Grid.Row="2"
                    Command="{Binding LogoutCommand}"
                    Style="{StaticResource LogoutButtonStyle}">
                <StackPanel HorizontalAlignment="Center">
                    <Image Width="32"
                           Height="32"
                           Source="/Resources/Images/NavigationItem/tuichu.png"
                           Stretch="Uniform" />
                    <TextBlock Margin="0,10,0,0"
                               HorizontalAlignment="Center"
                               FontFamily="{StaticResource AppFont}"
                               FontSize="22"
                               FontWeight="Medium"
                               Foreground="#403B5B"
                               Text="退出" />
                </StackPanel>
            </Button>
        </Grid>
    </Border>
</UserControl>
