<Window x:Class="BTFX.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BTFX"
        xmlns:controls="clr-namespace:BTFX.Controls"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="{Binding Title}"
        Height="720" Width="1280"
        MinHeight="720" MinWidth="1280"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{DynamicResource MaterialDesign.Brush.Background}"
        KeyDown="Window_KeyDown">

    <Window.InputBindings>
        <KeyBinding Key="Escape" Command="{Binding ExitFullscreenCommand}" />
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <!-- 标题栏：登录页时折叠为 0，其他页面显示 -->
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 顶部标题栏：登录页时折叠隐藏，其他页面共用 -->
        <controls:TitleBarControl
              x:Name="AppTitleBar"
              Grid.Row="0"
              Visibility="{Binding IsLoginView, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
              UserDisplayName="{Binding UserDisplayName, FallbackValue=游客}"
              MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
              controls:TitleBarControl.CloseClicked="TitleBar_CloseClicked" />

        <Grid Grid.Row="1">
            <ContentControl Content="{Binding CurrentView}">
                <ContentControl.ContentTemplate>
                    <DataTemplate>
                        <ContentPresenter Content="{Binding}" />
                    </DataTemplate>
                </ContentControl.ContentTemplate>
            </ContentControl>

            <StackPanel HorizontalAlignment="Center" 
                        VerticalAlignment="Center"
                        Visibility="{Binding CurrentView, Converter={StaticResource NullableToVisibilityConverter}, ConverterParameter=Inverse, FallbackValue=Visible}">
                <materialDesign:PackIcon Kind="Walk" 
                                         Width="100" Height="100"
                                         HorizontalAlignment="Center"
                                         Foreground="{DynamicResource MaterialDesign.Brush.Primary}" />
                <TextBlock Text="{DynamicResource AppName}" 
                           FontSize="32" 
                           FontWeight="Light"
                           HorizontalAlignment="Center"
                           Margin="0,24,0,0" />
                <TextBlock Text="Gait Analysis System Framework Ready" 
                           FontSize="16" 
                           Opacity="0.6"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0" />
                <TextBlock Text="{Binding Version, StringFormat=Version: {0}}" 
                           FontSize="14" 
                           Opacity="0.4"
                           HorizontalAlignment="Center"
                           Margin="0,16,0,0" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="0" Grid.RowSpan="2">
                        <Rectangle x:Name="ResizeLeft" Width="4" HorizontalAlignment="Left" Cursor="SizeWE" Fill="Transparent" MouseLeftButtonDown="Resize_MouseLeftButtonDown" />
                        <Rectangle x:Name="ResizeRight" Width="4" HorizontalAlignment="Right" Cursor="SizeWE" Fill="Transparent" MouseLeftButtonDown="Resize_MouseLeftButtonDown" />
                        <Rectangle x:Name="ResizeTop" Height="4" VerticalAlignment="Top" Cursor="SizeNS" Fill="Transparent" MouseLeftButtonDown="Resize_MouseLeftButtonDown" />
                        <Rectangle x:Name="ResizeBottom" Height="4" VerticalAlignment="Bottom" Cursor="SizeNS" Fill="Transparent" MouseLeftButtonDown="Resize_MouseLeftButtonDown" />
                        <Rectangle x:Name="ResizeTopLeft" Width="8" Height="8" HorizontalAlignment="Left" VerticalAlignment="Top" Cursor="SizeNWSE" Fill="Transparent" MouseLeftButtonDown="Resize_MouseLeftButtonDown" />
                        <Rectangle x:Name="ResizeTopRight" Width="8" Height="8" HorizontalAlignment="Right" VerticalAlignment="Top" Cursor="SizeNESW" Fill="Transparent" MouseLeftButtonDown="Resize_MouseLeftButtonDown" />
                        <Rectangle x:Name="ResizeBottomLeft" Width="8" Height="8" HorizontalAlignment="Left" VerticalAlignment="Bottom" Cursor="SizeNESW" Fill="Transparent" MouseLeftButtonDown="Resize_MouseLeftButtonDown" />
                        <Rectangle x:Name="ResizeBottomRight" Width="8" Height="8" HorizontalAlignment="Right" VerticalAlignment="Bottom" Cursor="SizeNWSE" Fill="Transparent" MouseLeftButtonDown="Resize_MouseLeftButtonDown" />
                    </Grid>
                </Grid>

            </Window>
