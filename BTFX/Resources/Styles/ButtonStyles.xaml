<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <!--  主按钮样式  -->
    <Style
        x:Key="PrimaryButton"
        BasedOn="{StaticResource MaterialDesignRaisedButton}"
        TargetType="Button">
        <Setter Property="Height" Value="36" />
        <Setter Property="MinWidth" Value="88" />
        <Setter Property="Padding" Value="16,0" />
        <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="4" />
    </Style>

    <!--  次要按钮样式  -->
    <Style
        x:Key="SecondaryButton"
        BasedOn="{StaticResource MaterialDesignOutlinedButton}"
        TargetType="Button">
        <Setter Property="Height" Value="36" />
        <Setter Property="MinWidth" Value="88" />
        <Setter Property="Padding" Value="16,0" />
        <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="4" />
    </Style>

    <!--  文字按钮样式  -->
    <Style
        x:Key="TextButton"
        BasedOn="{StaticResource MaterialDesignFlatButton}"
        TargetType="Button">
        <Setter Property="Height" Value="36" />
        <Setter Property="MinWidth" Value="64" />
        <Setter Property="Padding" Value="8,0" />
    </Style>

    <!--  图标按钮样式  -->
    <Style
        x:Key="IconButton"
        BasedOn="{StaticResource MaterialDesignIconButton}"
        TargetType="Button">
        <Setter Property="Width" Value="40" />
        <Setter Property="Height" Value="40" />
        <Setter Property="Padding" Value="8" />
    </Style>

    <!--  危险操作按钮样式（红色）  -->
    <Style
        x:Key="DangerButton"
        BasedOn="{StaticResource MaterialDesignRaisedButton}"
        TargetType="Button">
        <Setter Property="Height" Value="36" />
        <Setter Property="MinWidth" Value="88" />
        <Setter Property="Padding" Value="16,0" />
        <Setter Property="Background" Value="#F44336" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="4" />
    </Style>

    <!--  危险操作轮廓按钮样式  -->
    <Style
        x:Key="DangerOutlinedButton"
        BasedOn="{StaticResource MaterialDesignOutlinedButton}"
        TargetType="Button">
        <Setter Property="Height" Value="36" />
        <Setter Property="MinWidth" Value="88" />
        <Setter Property="Padding" Value="16,0" />
        <Setter Property="Foreground" Value="#F44336" />
        <Setter Property="BorderBrush" Value="#F44336" />
        <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="4" />
    </Style>

    <!--  工具栏按钮样式  -->
    <Style
        x:Key="ToolbarButton"
        BasedOn="{StaticResource MaterialDesignFlatButton}"
        TargetType="Button">
        <Setter Property="Height" Value="32" />
        <Setter Property="Padding" Value="12,0" />
        <Setter Property="Margin" Value="4,0" />
    </Style>

    <!--  小型按钮样式  -->
    <Style
        x:Key="SmallButton"
        BasedOn="{StaticResource MaterialDesignRaisedButton}"
        TargetType="Button">
        <Setter Property="Height" Value="28" />
        <Setter Property="MinWidth" Value="64" />
        <Setter Property="Padding" Value="8,0" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="4" />
    </Style>

    <!--  标题栏按钮样式  -->
    <Style
        x:Key="TitleBarButton"
        BasedOn="{StaticResource MaterialDesignIconForegroundButton}"
        TargetType="Button">
        <Setter Property="Width" Value="46" />
        <Setter Property="Height" Value="32" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Foreground}" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource MaterialDesign.Brush.TextBox.HoverBackground}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!--  标题栏关闭按钮样式  -->
    <Style
        x:Key="TitleBarCloseButton"
        BasedOn="{StaticResource TitleBarButton}"
        TargetType="Button">
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#E81123" />
                <Setter Property="Foreground" Value="White" />
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>