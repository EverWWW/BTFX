<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <!--  标准文本框样式  -->
    <Style
        x:Key="StandardTextBox"
        BasedOn="{StaticResource MaterialDesignOutlinedTextBox}"
        TargetType="TextBox">
        <Setter Property="Height" Value="56" />
        <Setter Property="Padding" Value="12,16,12,8" />
        <Setter Property="materialDesign:TextFieldAssist.HasClearButton" Value="False" />
        <Setter Property="materialDesign:HintAssist.FloatingScale" Value="0.75" />
    </Style>

    <!--  带清除按钮的文本框样式  -->
    <Style
        x:Key="ClearableTextBox"
        BasedOn="{StaticResource MaterialDesignOutlinedTextBox}"
        TargetType="TextBox">
        <Setter Property="Height" Value="56" />
        <Setter Property="Padding" Value="12,16,12,8" />
        <Setter Property="materialDesign:TextFieldAssist.HasClearButton" Value="True" />
        <Setter Property="materialDesign:HintAssist.FloatingScale" Value="0.75" />
    </Style>

    <!--  搜索框样式  -->
    <Style
        x:Key="SearchTextBox"
        BasedOn="{StaticResource MaterialDesignOutlinedTextBox}"
        TargetType="TextBox">
        <Setter Property="Height" Value="40" />
        <Setter Property="Padding" Value="8,8,32,8" />
        <Setter Property="materialDesign:TextFieldAssist.HasClearButton" Value="True" />
        <Setter Property="materialDesign:HintAssist.Hint" Value="搜索..." />
        <Setter Property="materialDesign:TextFieldAssist.DecorationVisibility" Value="Collapsed" />
    </Style>

    <!--  密码框样式  -->
    <Style
        x:Key="StandardPasswordBox"
        BasedOn="{StaticResource MaterialDesignOutlinedPasswordBox}"
        TargetType="PasswordBox">
        <Setter Property="Height" Value="56" />
        <Setter Property="Padding" Value="12,16,12,8" />
        <Setter Property="materialDesign:HintAssist.FloatingScale" Value="0.75" />
    </Style>

    <!--  多行文本框样式  -->
    <Style
        x:Key="MultilineTextBox"
        BasedOn="{StaticResource MaterialDesignOutlinedTextBox}"
        TargetType="TextBox">
        <Setter Property="MinHeight" Value="80" />
        <Setter Property="Padding" Value="12" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="AcceptsReturn" Value="True" />
        <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="materialDesign:HintAssist.FloatingScale" Value="0.75" />
    </Style>

    <!--  数字输入框样式  -->
    <Style
        x:Key="NumericTextBox"
        BasedOn="{StaticResource MaterialDesignOutlinedTextBox}"
        TargetType="TextBox">
        <Setter Property="Height" Value="56" />
        <Setter Property="Padding" Value="12,16,12,8" />
        <Setter Property="materialDesign:HintAssist.FloatingScale" Value="0.75" />
        <Setter Property="InputMethod.IsInputMethodEnabled" Value="False" />
    </Style>

    <!--  填充式文本框样式  -->
    <Style
        x:Key="FilledTextBox"
        BasedOn="{StaticResource MaterialDesignFilledTextBox}"
        TargetType="TextBox">
        <Setter Property="Height" Value="56" />
        <Setter Property="Padding" Value="12,20,12,8" />
        <Setter Property="materialDesign:HintAssist.FloatingScale" Value="0.75" />
    </Style>

    <!--  紧凑型文本框样式  -->
    <Style
        x:Key="CompactTextBox"
        BasedOn="{StaticResource MaterialDesignOutlinedTextBox}"
        TargetType="TextBox">
        <Setter Property="Height" Value="40" />
        <Setter Property="Padding" Value="8" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="materialDesign:HintAssist.FloatingScale" Value="0.8" />
    </Style>

    <!--  日期选择器样式  -->
    <Style
        x:Key="StandardDatePicker"
        BasedOn="{StaticResource MaterialDesignOutlinedDatePicker}"
        TargetType="DatePicker">
        <Setter Property="Height" Value="56" />
        <Setter Property="Padding" Value="12,16,12,8" />
        <Setter Property="materialDesign:HintAssist.FloatingScale" Value="0.75" />
    </Style>

    <!--  下拉框样式  -->
    <Style
        x:Key="StandardComboBox"
        BasedOn="{StaticResource MaterialDesignOutlinedComboBox}"
        TargetType="ComboBox">
        <Setter Property="Height" Value="56" />
        <Setter Property="Padding" Value="12,16,12,8" />
        <Setter Property="materialDesign:HintAssist.FloatingScale" Value="0.75" />
    </Style>

</ResourceDictionary>