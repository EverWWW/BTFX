<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <!-- 标准文本框样式 -->
    <Style x:Key="StandardTextBox" TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
        <Setter Property="Height" Value="56" />
        <Setter Property="Padding" Value="12,16,12,8" />
        <Setter Property="materialDesign:TextFieldAssist.HasClearButton" Value="False" />
        <Setter Property="materialDesign:HintAssist.FloatingScale" Value="0.75" />
    </Style>

    <!-- 带清除按钮的文本框样式 -->
    <Style x:Key="ClearableTextBox" TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
        <Setter Property="Height" Value="56" />
        <Setter Property="Padding" Value="12,16,12,8" />
        <Setter Property="materialDesign:TextFieldAssist.HasClearButton" Value="True" />
        <Setter Property="materialDesign:HintAssist.FloatingScale" Value="0.75" />
    </Style>

    <!-- 搜索框样式 -->
    <Style x:Key="SearchTextBox" TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
        <Setter Property="Height" Value="40" />
        <Setter Property="Padding" Value="8,8,32,8" />
        <Setter Property="materialDesign:TextFieldAssist.HasClearButton" Value="True" />
        <Setter Property="materialDesign:HintAssist.Hint" Value="搜索..." />
        <Setter Property="materialDesign:TextFieldAssist.DecorationVisibility" Value="Collapsed" />
    </Style>

    <!-- 密码框样式 -->
    <Style x:Key="StandardPasswordBox" TargetType="PasswordBox" BasedOn="{StaticResource MaterialDesignOutlinedPasswordBox}">
        <Setter Property="Height" Value="56" />
        <Setter Property="Padding" Value="12,16,12,8" />
        <Setter Property="materialDesign:HintAssist.FloatingScale" Value="0.75" />
    </Style>

    <!-- 多行文本框样式 -->
    <Style x:Key="MultilineTextBox" TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
        <Setter Property="MinHeight" Value="80" />
        <Setter Property="Padding" Value="12" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="AcceptsReturn" Value="True" />
        <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="materialDesign:HintAssist.FloatingScale" Value="0.75" />
    </Style>

    <!-- 数字输入框样式 -->
    <Style x:Key="NumericTextBox" TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
        <Setter Property="Height" Value="56" />
        <Setter Property="Padding" Value="12,16,12,8" />
        <Setter Property="materialDesign:HintAssist.FloatingScale" Value="0.75" />
        <Setter Property="InputMethod.IsInputMethodEnabled" Value="False" />
    </Style>

    <!-- 填充式文本框样式 -->
    <Style x:Key="FilledTextBox" TargetType="TextBox" BasedOn="{StaticResource MaterialDesignFilledTextBox}">
        <Setter Property="Height" Value="56" />
        <Setter Property="Padding" Value="12,20,12,8" />
        <Setter Property="materialDesign:HintAssist.FloatingScale" Value="0.75" />
    </Style>

    <!-- 紧凑型文本框样式 -->
    <Style x:Key="CompactTextBox" TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
        <Setter Property="Height" Value="40" />
        <Setter Property="Padding" Value="8" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="materialDesign:HintAssist.FloatingScale" Value="0.8" />
    </Style>

    <!-- 日期选择器样式 -->
    <Style x:Key="StandardDatePicker" TargetType="DatePicker" BasedOn="{StaticResource MaterialDesignOutlinedDatePicker}">
        <Setter Property="Height" Value="56" />
        <Setter Property="Padding" Value="12,16,12,8" />
        <Setter Property="materialDesign:HintAssist.FloatingScale" Value="0.75" />
    </Style>

    <!-- 下拉框样式 -->
    <Style x:Key="StandardComboBox" TargetType="ComboBox" BasedOn="{StaticResource MaterialDesignOutlinedComboBox}">
        <Setter Property="Height" Value="56" />
        <Setter Property="Padding" Value="12,16,12,8" />
        <Setter Property="materialDesign:HintAssist.FloatingScale" Value="0.75" />
    </Style>

</ResourceDictionary>