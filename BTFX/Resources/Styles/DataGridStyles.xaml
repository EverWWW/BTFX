<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <!--  斑马纹行样式  -->
    <Style
        x:Key="ZebraRowStyle"
        BasedOn="{StaticResource MaterialDesignDataGridRow}"
        TargetType="DataGridRow">
        <Setter Property="Background" Value="Transparent" />
        <Style.Triggers>
            <!--  斑马纹：奇数行  -->
            <Trigger Property="AlternationIndex" Value="1">
                <Setter Property="Background" Value="{DynamicResource MaterialDesign.Brush.Card.Background}" />
            </Trigger>
            <!--  选中状态  -->
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource MaterialDesign.Brush.Primary.Light}" />
                <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Primary.Foreground}" />
            </Trigger>
            <!--  鼠标悬停  -->
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="IsMouseOver" Value="True" />
                    <Condition Property="IsSelected" Value="False" />
                </MultiTrigger.Conditions>
                <Setter Property="Background" Value="{DynamicResource MaterialDesign.Brush.TextBox.HoverBackground}" />
            </MultiTrigger>
        </Style.Triggers>
    </Style>

    <!--  标准DataGrid样式  -->
    <Style
        x:Key="StandardDataGrid"
        BasedOn="{StaticResource MaterialDesignDataGrid}"
        TargetType="DataGrid">
        <Setter Property="AutoGenerateColumns" Value="False" />
        <Setter Property="CanUserAddRows" Value="False" />
        <Setter Property="CanUserDeleteRows" Value="False" />
        <Setter Property="CanUserReorderColumns" Value="False" />
        <Setter Property="CanUserResizeRows" Value="False" />
        <Setter Property="SelectionMode" Value="Single" />
        <Setter Property="SelectionUnit" Value="FullRow" />
        <Setter Property="IsReadOnly" Value="True" />
        <Setter Property="GridLinesVisibility" Value="Horizontal" />
        <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource MaterialDesign.Brush.TextBox.HoverBackground}" />
        <Setter Property="RowHeight" Value="48" />
        <Setter Property="AlternationCount" Value="2" />
        <Setter Property="RowStyle" Value="{StaticResource ZebraRowStyle}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesign.Brush.TextBox.HoverBackground}" />
    </Style>

    <!--  列标题样式  -->
    <Style
        x:Key="StandardColumnHeader"
        BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}"
        TargetType="DataGridColumnHeader">
        <Setter Property="Height" Value="48" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Padding" Value="16,0" />
        <Setter Property="Background" Value="{DynamicResource MaterialDesign.Brush.Primary}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
    </Style>

    <!--  全局CenteredTextColumnStyle样式  -->
    <Style x:Key="CenteredTextColumnStyle" TargetType="TextBlock">
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!--  单元格样式  -->
    <Style
        x:Key="StandardCell"
        BasedOn="{StaticResource MaterialDesignDataGridCell}"
        TargetType="DataGridCell">
        <Setter Property="Padding" Value="16,0" />
        <!--  确保内容垂直居中  -->
        <!--<Setter Property="VerticalContentAlignment" Value="Center" />-->
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <!--<Setter Property="Background" Value="Transparent" />-->
                <Setter Property="Background" Value="{DynamicResource MaterialDesign.Brush.Selection}" />
                <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Foreground}" />
                <Setter Property="BorderThickness" Value="0" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!--  全局DataGridCell样式 - 去除焦点边框  -->
    <Style BasedOn="{StaticResource MaterialDesignDataGridCell}" TargetType="DataGridCell">
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />

        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <!--<Setter Property="Background" Value="Transparent"/>-->
                <Setter Property="Background" Value="{DynamicResource MaterialDesign.Brush.Selection}" />
                <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Foreground}" />
                <Setter Property="BorderThickness" Value="0" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!--  全局DataGridRow样式 - 去除焦点边框  -->
    <Style BasedOn="{StaticResource MaterialDesignDataGridRow}" TargetType="DataGridRow">
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
    </Style>

    <!--  操作列按钮样式  -->
    <Style
        x:Key="DataGridActionButton"
        BasedOn="{StaticResource MaterialDesignIconButton}"
        TargetType="Button">
        <Setter Property="Width" Value="32" />
        <Setter Property="Height" Value="32" />
        <Setter Property="Padding" Value="4" />
        <Setter Property="Margin" Value="2,0" />
    </Style>

    <!--  编辑按钮样式  -->
    <Style
        x:Key="EditActionButton"
        BasedOn="{StaticResource DataGridActionButton}"
        TargetType="Button">
        <Setter Property="ToolTip" Value="{DynamicResource Edit}" />
        <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Primary}" />
    </Style>

    <!--  删除按钮样式  -->
    <Style
        x:Key="DeleteActionButton"
        BasedOn="{StaticResource DataGridActionButton}"
        TargetType="Button">
        <Setter Property="ToolTip" Value="{DynamicResource Delete}" />
        <Setter Property="Foreground" Value="#F44336" />
    </Style>

    <!--  紧凑型DataGrid样式  -->
    <Style
        x:Key="CompactDataGrid"
        BasedOn="{StaticResource StandardDataGrid}"
        TargetType="DataGrid">
        <Setter Property="RowHeight" Value="36" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <!--  分页控件文本样式  -->
    <Style x:Key="PaginationText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.ForegroundLight}" />
    </Style>

    <!--  分页按钮样式  -->
    <Style
        x:Key="PaginationButton"
        BasedOn="{StaticResource MaterialDesignFlatButton}"
        TargetType="Button">
        <Setter Property="Height" Value="32" />
        <Setter Property="MinWidth" Value="32" />
        <Setter Property="Padding" Value="8,0" />
        <Setter Property="Margin" Value="2,0" />
    </Style>
</ResourceDictionary>